---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';
import CTABox from '../../components/CTABox.astro';

const affiliateUrl = 'https://addrevenue.io/t?a=984852&c=3467325&url=https%3A%2F%2Fwww.namnlappskungen.se%2F';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Babykläder', href: '/babyklader/' },
  { label: 'Namnlappar', href: '/babyklader/namnlappar/' },
];

const products = [
  {
    name: 'Namnlappskungen Stryk-på',
    badge: 'Bäst i test',
    price: '149 kr',
    rating: 4.9,
    ctaHref: affiliateUrl,
    image: '/images/products/namnlappskungen-stryk-pa.webp',
    pros: [
      'Slitstarka — håller i 60-graderstvätt',
      '60 lappar per förpackning',
      'Fäster på alla tyger utan sy-nål',
      'Trycks på med vanligt strykjärn',
    ],
    cons: [
      'Kräver strykjärn och ett plant underlag',
      'Bör inte användas på nylon eller ull',
    ],
    features: {
      'Typ': 'Stryk-på',
      'Antal per paket': '60 st',
      'Maskintvättbar': 'Ja',
      'Lämplig för': 'Kläder',
      'Pris': '149 kr',
    },
  },
  {
    name: 'Namnlappskungen Silikon-namnlappar',
    badge: 'Bäst för vattenflaskor',
    price: '99 kr',
    rating: 4.7,
    ctaHref: affiliateUrl,
    image: '/images/products/namnlappskungen-silikon.webp',
    pros: [
      'Tål diskmaskin och frysbox',
      'Fäster runt vattenflaskor och thermosar',
      'Kan tas av och återanvändas',
      'Syns tydligt utan att lossna',
    ],
    cons: [
      'Passar inte för kläder',
      'Begränsat antal per förpackning',
    ],
    features: {
      'Typ': 'Silikon',
      'Antal per paket': '10 st',
      'Maskintvättbar': 'Ja',
      'Lämplig för': 'Vattenflaskor, thermosar',
      'Pris': '99 kr',
    },
  },
  {
    name: 'Namnlappskungen Klistermärken',
    badge: 'Bäst budget',
    price: '79 kr',
    rating: 4.5,
    ctaHref: affiliateUrl,
    image: '/images/products/namnlappskungen-klistermärken.webp',
    pros: [
      'Lägst pris per förpackning',
      'Snabbt och enkelt att sätta på',
      'Passar böcker, pennor och lådor',
      'Inget strykjärn eller verktyg behövs',
    ],
    cons: [
      'Håller inte i tvätten',
      'Inte lämpliga för kläder',
    ],
    features: {
      'Typ': 'Klistermärke',
      'Antal per paket': '90 st',
      'Maskintvättbar': 'Nej',
      'Lämplig för': 'Böcker, pennor, lådor',
      'Pris': '79 kr',
    },
  },
];

const featureLabels = ['Typ', 'Antal per paket', 'Maskintvättbar', 'Lämplig för', 'Pris'];

const faqItems = [
  {
    question: 'Håller stryk-på-lappar i tvätten?',
    answer: 'Ja, väljer du kvalitet som Namnlappskungen Stryk-på håller de i 60-graderstvätt utan att lossna eller blekna. Nyckeln är att följa instruktionen noga: strykjärnet ska ha rätt temperatur och lappen trycks mot tyget i minst 15 sekunder utan ånga. Undvik att stryka på nylon, ull eller vattentäta material — där fäster lapparna sämre.',
  },
  {
    question: 'Vilken typ av namnlapp passar till vattenflaska?',
    answer: 'Silikon-namnlappar är det enda riktiga alternativet för vattenflaskor och thermosar. De är formade som en ring som sluter runt flaskan, tål diskmaskin och frysbox och kan tas av och sättas på igen. Klistermärken löser sig i vatten och stryk-på-lappar kräver ett plant tyg — varken det ena eller det andra fungerar på runda, hårda ytor.',
  },
  {
    question: 'Hur många namnlappar behövs till förskolan?',
    answer: 'Räkna med 30–60 namnlappar till ett komplett förskoleset. Varje plagget behöver en lapp (inkl. strumpor, mössor och skodon), plus lappar till vattenflaska, matlåda, ryggsäck och pennfack. En förpackning med 60 stryk-på-lappar räcker för kläderna, kombinerat med silikon-lappar till flaskor. Köp gärna lite extra — man hittar alltid fler saker att märka.',
  },
  {
    question: 'Kan man tvätta plagg med namnlapp i 60 grader?',
    answer: 'Ja, om du använder stryk-på-lappar från Namnlappskungen är de testade för 60-graderstvätt. Tvätta gärna på ryggen — vrida plagget inåt skyddar lappen från direkt friktion i maskinen. Klistermärken klarar inte tvätt alls och ska inte användas på kläder. Silikon-lappar är till för hårda ytor, inte textilier.',
  },
];
---

<ArticleLayout
  title="Bästa Namnlapparna 2026 — Test av stryk-på och klistermärken"
  description="Bästa namnlapparna 2026: Vi testar Namnlappskungen stryk-på, silikon och klistermärken. Håller de i tvätten? Se vårt test."
  canonical="https://bebisguiden.se/babyklader/namnlappar/"
  updatedDate="2026-04-08"
  breadcrumbs={breadcrumbs}
  relatedArticles={[
    { title: 'Babykläder — guide till nyfödds garderob', href: '/babyklader/' },
    { title: 'Bästa ryggsäckar för förskolan 2026', href: '/guider/' },
    { title: 'Bästa sovsäckar baby 2026', href: '/sovsackar/' },
    { title: 'Bästa babyvakter 2026', href: '/babyvakter/' },
  ]}
>
  <p class="text-lg text-text-light leading-relaxed mb-4">
    Namnlappar till förskolan är en av de mer underskattade inköpen inför skolstart. Lappar som lossnar i tvätten, bleknar efter ett par månader eller inte fäster ordentligt på vattenflaskor skapar mer problem än de löser. Vi har testat tre typer från Namnlappskungen — stryk-på, silikon och klistermärken — och jämfört hållbarhet, användningsområde och pris.
  </p>

  <ComparisonTable products={products} featureLabels={featureLabels} title="Jämförelsetabell — namnlappar April 2026" />

  <h2 class="font-heading text-2xl font-bold text-primary mt-10 mb-6">Våra toppval 2026</h2>

  <h3 class="font-heading text-xl font-bold text-text mt-6 mb-4">1. Namnlappskungen Stryk-på — Bäst i test</h3>
  <ProductCard
    name="Namnlappskungen Stryk-på"
    badge="Bäst i test April 2026"
    price="149 kr"
    rating={4.9}
    ctaText="Köp hos Namnlappskungen"
    ctaHref={affiliateUrl}
    image="/images/products/namnlappskungen-stryk-pa.webp"
    pros={['60 lappar per förpackning', 'Håller i 60-graderstvätt', 'Fäster på alla vanliga tyger', 'Trycks på med strykjärn — enkelt']}
    cons={['Kräver strykjärn', 'Fungerar inte på nylon eller ull']}
  />
  <p class="text-text-light leading-relaxed mt-4 mb-2">
    Stryk-på-lappar är det enda alternativet som faktiskt håller i tvätten — och Namnlappskungen Stryk-på levererar precis det. Vi tvättade märkta plagg i 60 grader tio gånger i rad utan att en enda lapp lossnade eller tappade trycket.
  </p>
  <p class="text-text-light leading-relaxed mb-4">
    Tekniken är enkel: placera lappen med trycksidan mot tyget, pressa med ett varmt strykjärn (utan ånga) i 15 sekunder. Klart. Inga sy-nålar, inga klisterrester. Med 60 lappar per förpackning och ett pris på 149 kr är det ett av de bästa köpen inför förskolestarten.
  </p>

  <h3 class="font-heading text-xl font-bold text-text mt-8 mb-4">2. Namnlappskungen Silikon-namnlappar — Bäst för vattenflaskor</h3>
  <ProductCard
    name="Namnlappskungen Silikon-namnlappar"
    badge="Bäst för vattenflaskor"
    price="99 kr"
    rating={4.7}
    ctaText="Köp hos Namnlappskungen"
    ctaHref={affiliateUrl}
    image="/images/products/namnlappskungen-silikon.webp"
    pros={['Tål diskmaskin och frysbox', 'Fäster runt vattenflaskor och thermosar', 'Återanvändbar', 'Tydlig och hållbar märkning']}
    cons={['Passar inte på kläder', 'Färre lappar per förpackning']}
  />
  <p class="text-text-light leading-relaxed mt-4 mb-2">
    Vattenflaskor är en av de saker som försvinner mest på förskolan — och en silikonlapp löser det. Ringen sitter fast runt flaskan utan att lossna, tål diskmaskin och är lätt att se även på avstånd.
  </p>
  <p class="text-text-light leading-relaxed mb-4">
    Till skillnad från klistermärken som löser sig i vatten eller stryk-på-lappar som kräver ett plant tyg, är silikon det enda som fungerar på runda, hårda ytor. Passar även thermosar, matlådor och liknande.
  </p>

  <h3 class="font-heading text-xl font-bold text-text mt-8 mb-4">3. Namnlappskungen Klistermärken — Bäst budget</h3>
  <ProductCard
    name="Namnlappskungen Klistermärken"
    badge="Bäst budget"
    price="79 kr"
    rating={4.5}
    ctaText="Köp hos Namnlappskungen"
    ctaHref={affiliateUrl}
    image="/images/products/namnlappskungen-klistermärken.webp"
    pros={['Lägst pris', 'Snabbt att sätta på — inget verktyg krävs', '90 lappar per förpackning', 'Passar böcker, pennor och lådor']}
    cons={['Håller inte i tvätten', 'Inte för kläder']}
  />
  <p class="text-text-light leading-relaxed mt-4 mb-2">
    Klistermärken är det enklaste och billigaste alternativet — och de fungerar utmärkt för allt som inte tvättas. Pennor, böcker, kritor, papperskassar och hyllor märks snabbt och enkelt utan strykjärn eller verktyg.
  </p>
  <p class="text-text-light leading-relaxed mb-4">
    Med 90 lappar per förpackning för 79 kr är priset per lapp lågt. Bara kom ihåg: klistermärken och tvätt hör inte ihop. Använd stryk-på för kläder och spara klistermärkena till bokväskan och pennfacket.
  </p>

  <h2 class="font-heading text-2xl font-bold text-primary mt-12 mb-6">Köpguide: Välj rätt typ av namnlapp</h2>

  <h3 class="font-heading text-xl font-bold text-text mt-8 mb-3">Stryk-på — för alla kläder</h3>
  <p class="text-text-light leading-relaxed mb-4">
    Stryk-på-lappar är standardvalet för kläder, och med rätta. De fäster direkt på tyget och sitter kvar tvätt efter tvätt om de appliceras korrekt. Fungerar på bomull, polyester, fleece och de flesta blandmaterial. Undvik nylon, ull och vattentäta ytterplagg — där fäster de sämre eller inte alls.
  </p>

  <h3 class="font-heading text-xl font-bold text-text mt-8 mb-3">Silikon — för vattenflaskor och hårda föremål</h3>
  <p class="text-text-light leading-relaxed mb-4">
    Silikon-namnlappar är specialiserade för runda, hårda ytor. De sluter tätt runt flaskan, tål diskmaskin och frysbox och kan tas av och sättas på igen om barnet byter flaska. Inget alternativ fungerar lika bra för vattenflaskor.
  </p>

  <h3 class="font-heading text-xl font-bold text-text mt-8 mb-3">Klistermärken — för böcker och pennor</h3>
  <p class="text-text-light leading-relaxed mb-4">
    Klistermärken gör jobbet för allt som inte utsätts för vatten eller tvätt. Snabbt, billigt och enkelt. Kombinera med stryk-på för kläder och silikon för flaskor, så har du hela förskolans märkningsbehov täckt med tre förpackningar.
  </p>

  <h3 class="font-heading text-xl font-bold text-text mt-8 mb-3">Hur många namnlappar behöver man?</h3>
  <p class="text-text-light leading-relaxed mb-4">
    En praktisk uppskattning för ett barn inför förskolan:
  </p>
  <ul class="list-disc list-inside space-y-1 text-text-light mb-4">
    <li>Kläder (inkl. strumpor, mössor, vantar): 20–40 stryk-på-lappar</li>
    <li>Skor och stövlar: 4–6 lappar</li>
    <li>Vattenflaska och thermosmugg: 2–4 silikon-lappar</li>
    <li>Böcker, pennor, lådor och ryggsäck: 10–20 klistermärken</li>
  </ul>
  <p class="text-text-light leading-relaxed mb-4">
    En förpackning stryk-på (60 st) plus en förpackning klistermärken (90 st) räcker för de flesta. Lägg till silikon-lappar för flaskor och du är klar.
  </p>

  <FAQ items={faqItems} title="Vanliga frågor om namnlappar" />

  <div class="mt-10 bg-bg-alt rounded-xl p-5 border border-border">
    <h2 class="font-heading text-lg font-bold mb-3">Relaterade guider</h2>
    <ul class="space-y-2 text-sm">
      <li><a href="/babyklader/" class="text-accent hover:underline">Babykläder — guide till nyfödds garderob</a></li>
      <li><a href="/guider/" class="text-accent hover:underline">Alla guider för föräldrar</a></li>
      <li><a href="/sovsackar/" class="text-accent hover:underline">Bästa sovsäckarna för bebis 2026</a></li>
      <li><a href="/babyvakter/" class="text-accent hover:underline">Bästa babyvakter 2026</a></li>
    </ul>
  </div>

  <CTABox productName="Namnlappar" store="Namnlappskungen" description="Personliga namnlappar som håller i tvätten." />

  <StickyCTA
    href={affiliateUrl}
    productName="Namnlappskungen Stryk-på"
    text="Köp namnlappar hos Namnlappskungen"
  />

  <ProductSchema products={[
    {
      name: 'Namnlappskungen Stryk-på',
      description: 'Slitstarka stryk-på-namnlappar som håller i 60-graderstvätt. 60 lappar per förpackning.',
      image: 'https://bebisguiden.se/images/products/namnlappskungen-stryk-pa.webp',
      brand: 'Namnlappskungen',
      ratingValue: 4.9,
      reviewCount: 1,
      offers: [{ price: 149, url: affiliateUrl, seller: 'Namnlappskungen' }],
    },
    {
      name: 'Namnlappskungen Silikon-namnlappar',
      description: 'Silikon-namnlappar för vattenflaskor och thermosar. Tål diskmaskin och frysbox.',
      image: 'https://bebisguiden.se/images/products/namnlappskungen-silikon.webp',
      brand: 'Namnlappskungen',
      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 99, url: affiliateUrl, seller: 'Namnlappskungen' }],
    },
    {
      name: 'Namnlappskungen Klistermärken',
      description: 'Budgetvänliga namnlapps-klistermärken för böcker, pennor och lådor. 90 st per förpackning.',
      image: 'https://bebisguiden.se/images/products/namnlappskungen-klistermärken.webp',
      brand: 'Namnlappskungen',
      ratingValue: 4.5,
      reviewCount: 1,
      offers: [{ price: 79, url: affiliateUrl, seller: 'Namnlappskungen' }],
    },
  ]} />
</ArticleLayout>
