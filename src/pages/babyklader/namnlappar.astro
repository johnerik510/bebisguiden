    accentColor: '#0d9488', bgColor: '#1a365d',
    desc: 'Silikon-namnlappar för vattenflaskor och thermosar. Tål diskmaskin och frysbox.',
    features: {
      'Typ': 'Silikon',
      'Antal per paket': '10 st',
