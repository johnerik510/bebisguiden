const featureLabels = ['Material', 'Certifiering', 'Storlek', 'Kläddelar', 'Stängning'];

const faqItems = [
 {
 question: 'Vilken storlek passar en nyfödd?',
 answer: 'De flesta nyfödda startar i storlek 50 (upp till cirka 3 kilo) eller 56 (3 till 4,5 kilo). Storlek 50 till 56 används i snitt bara 6 till 8 veckor, så köp få plagg i minsta storleken och fler i storlek 62 till 68 som håller längre. Kontrollera alltid tillverkarens vikttabell snarare än åldersguiden, märken skiljer sig märkbart.',
 },
 {
 question: 'Vilka material är bäst mot bebisens hud?',
 answer: 'Ekologisk bomull med GOTS-certifiering är förstahandsvalet för vardagskläder, mjuk, andningsbar och fri från skadliga kemikalier. Bambuviskos är extra mjuk och fuktabsorberande men dyrare och tar längre att torka. Fleece och ull passar för vinterytterkläder. Undvik polyester direkt mot huden på nyfödda, den andas sämre och kan irritera känslig hud.',
 },
 {
 question: 'Vad är skillnaden mellan OEKO-TEX och GOTS?',
 answer: 'OEKO-TEX Standard 100 är en miniminivå som garanterar att den färdiga textilen inte innehåller skadliga ämnen över gränsvärden. GOTS (Global Organic Textile Standard) går ett steg längre och certifierar hela produktionskedjan från fält till färdig produkt, med krav på ekologisk odling, kemikalierestriktioner och sociala arbetsförhållanden. För babykläder är GOTS en starkare garanti, OEKO-TEX är acceptabelt om GOTS inte finns.',
 },
 {
 question: 'Hur många plagg behöver en nyfödd?',
 answer: 'En praktisk basgarderob: 5 till 7 kortärmade bodys, 3 till 5 sparkdräkter, 2 till 3 byxor, 2 till 3 mössor och par strumpor, plus 1 till 2 varmare plagg eller ytterkläder beroende på säsong. Räkna med tvätt två till tre gånger i veckan på grund av kräkningar och blöjläckor. Investera mer i storlek 62 till 68 som används i 2 till 3 månader än i 50 till 56 som passar i 6 veckor.',
 },
 {
 question: 'Ska jag tvätta nya babykläder innan användning?',
 answer: 'Ja, alltid. Nya plagg kan innehålla formaldehyd från impregneringar och andra rester från tillverkning och frakt. Första tvätten görs på 60 grader om plagget tål det, annars 40. Använd parfymfritt tvättmedel, hoppa över sköljmedel de första månaderna. Bebisens hud är känsligare och doftämnen är en vanlig orsak till utslag som föräldrar tror är allergi.',
 },
 {
 question: 'Hur klär jag bebisen rätt för svenska temperaturer?',
 answer: 'Inomhus vid 20 grader räcker tunn body plus sparkdräkt. Känn på nacken, inte händerna, för att kontrollera värmen. Utomhus i sommarvärme behövs UV-skyddande dräkt med UPF 50+ plus solhatt med nackskydd. Höst och vinter klär du i lager: body, tjockare sparkdräkt och fleece eller vinterdräkt ytterst. Tumregeln är ett lager mer än vad du själv har på dig, eftersom bebisen inte rör sig lika mycket.',
 },
];
