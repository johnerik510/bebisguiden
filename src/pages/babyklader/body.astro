    },
    {
      name: 'Body randig – Polarn O. Pyret',
      description: 'Långärmad babybody i GOTS-certifierad ekologisk bomull. Klassiskt randigt mönster. Tryckknappar vid skrevet. Passar nyfödd till 24 månader.',
      image: 'https://bebisguiden.se/images/products/polarnopyret-body-randig.webp',
      brand: 'Polarn O. Pyret',
      ratingValue: 4.8,
      reviewCount: 1,
