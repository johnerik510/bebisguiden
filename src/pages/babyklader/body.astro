      description: 'Kortärmad babybody i GOTS-certifierad ekologisk bomull. Tryckknappar vid skrevet. Passar nyfödd till 24 månader.',
      image: 'https://bebisguiden.se/images/products/hummel-mini-body.webp',
      brand: 'Hummel',
      ratingValue: 4.6,
      reviewCount: 1,
      offers: [{ price: 249, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnklader%2Fbodys-bodysuits%2Fbodys%2Fhummel-mini-bold-bee-body-polignac', seller: 'Jollyroom' }],
    },
  ]} />
  <CTABox productName="Body bebis" store="Polarn O. Pyret" description="GOTS-certifierade babybodys i ekologisk bomull sedan 1976." />
  <CTABox productName="Babykläder" store="Knattis" description="Babykläder och barnkläder för alla åldrar." />

</ArticleLayout>

