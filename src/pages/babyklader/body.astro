import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';
import CTABox from '../../components/CTABox.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Babykläder', href: '/babyklader/' },
  { label: 'Body bebis' },
];

const products = [
  {
    name: 'Joha Body Merinomix, Dark Rose',
    badge: 'Bäst i test',
    price: '209 kr',
    rating: 4.8,
    image: '/images/products/joha-body-merinomix.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnklader%2Fbodys-bodysuits%2Fbodys%2Fjoha-body-merinomix-dark-rose',
    features: {
      'Material': 'Merinoull/bomull',
      'Certifiering': 'OEKO-TEX',
      'Stängning': 'Tryckknappar',
