      <li><a href="/sovsackar/" class="text-accent hover:underline">Bästa sovsäckar baby 2026</a></li>
      <li><a href="/guider/bebis-checklista/" class="text-accent hover:underline">Bebis-checklista — klädlista för nyfödda</a></li>
    </ul>
  </div>

  <FAQ items={faqItems} />

  <ProductSchema products={[
    {
      name: 'Joha Body Merinomix, Dark Rose',
      description: 'Babybody i merinoull/bomullsmix. Temperaturreglerande, OEKO-TEX-certifierad, tvättbar i maskin. Passar nyfödd till 18 månader.',
      image: 'https://bebisguiden.se/images/products/joha-body-merinomix.webp',
      brand: 'Joha',
