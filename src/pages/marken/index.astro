---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import RetailerCTAs from '../../components/RetailerCTAs.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Märken' },
];

const brands = [
  {
    name: 'Britax Römer',
    href: '/marken/britax/',
    description: 'Ett av Europas mest välkända märken för bilbarnstolar. Vi recenserar Baby-Safe iSense, Dualfix M Plus och Kidfix M — och svarar på om Britax är värt premiumpriset.',
    category: 'Bilbarnstolar',
  },
  {
    name: 'BabyBjörn',
    href: '/marken/babybjorn/',
    description: 'Svenskt familjeföretag grundat 1961. Vi recenserar den ikoniska bärselen Harmony, Video Baby Monitor och High Chair — tre av märkets mest populära produkter.',
    category: 'Bärsele, babyvakt & matstol',
  },
  {
    name: 'Stokke',
    href: '/marken/stokke/',
    description: 'Norskt premiumvarumärke känt för produkter som växer med barnet. Vi recenserar Tripp Trapp, Xplory X och Sleepi V3 — och utvärderar om det höga priset är motiverat.',
    category: 'Barnvagn, matstol & spjälsäng',
  },
  {
    name: 'Bugaboo',
    href: '/marken/bugaboo/',
    description: 'Nederländskt premiummärke grundat 1999 i Amsterdam. Vi recenserar Fox 5, Donkey 5 Duo och Dragonfly — och svarar på om Bugaboos höga prislapp är motiverad.',
    category: 'Barnvagnar',
  },
  {
    name: 'Emmaljunga',
    href: '/marken/emmaljunga/',
    description: 'Sveriges äldsta barnvagnsmärke, grundat 1925 i Skåne. Vi recenserar NXT90, City Cross och Scooter — klassisk svensk kvalitet testad och utvärderad.',
    category: 'Barnvagnar',
  },
  {
    name: 'Cybex',
    href: '/marken/cybex/',
    description: 'Tyskt premiumvarumärke grundat 2005 i Bayern med stark säkerhetsprofil. Vi recenserar Sirona T i-Size, Priam 4 och Gazelle S — bilbarnstolar och barnvagnar.',
    category: 'Bilbarnstolar & barnvagnar',
  },
  {
    name: 'Nuna',
    href: '/marken/nuna/',
    description: 'Holländskt premiumvarumärke grundat 2007 med stark säkerhetsprofil. Vi recenserar Mixx Next, Triv och Demi Grow — barnvagnar för alla livssituationer.',
    category: 'Barnvagnar',
  },
  {
    name: 'Maxi-Cosi',
    href: '/marken/maxi-cosi/',
    description: 'Holländskt babyutrustningsvarumärke grundat 1984 och ett av Europas mest sålda märken för bilbarnstolar. Vi recenserar Pebble 360 Pro, Coral 360, Pearl 360 Pro och Leona 3.',
    category: 'Bilbarnstolar & barnvagnar',
  },
  {
    name: 'Joie',
    href: '/marken/joie/',
    description: 'Brittiskt babyutrustningsvarumärke grundat 2010, ägt av Dorel Industries (samma som Maxi-Cosi). Känt för prisvärda i-Size-bilbarnstolar — bra säkerhet till lägre pris.',
    category: 'Bilbarnstolar & barnvagnar',
  },
  {
    name: 'UPPAbaby',
    href: '/marken/uppababy/',
    description: 'Amerikanskt premiumvarumärke grundat 2006. Vista V3 och Cruz V2 är populäraste barnvagnarna i Sverige — känt för starkt syskonvagnssystem och god build quality till lägre pris än Bugaboo.',
    category: 'Barnvagnar',
  },
  {
    name: 'Ergobaby',
    href: '/marken/ergobaby/',
    description: 'Amerikanskt bärselemärke grundat 2003, känt för ergonomiska bärselar med M-position. Vi recenserar Omni 360, Omni Deluxe och Embrace — och utvärderar vilken som passar bäst för svenska föräldrar.',
    category: 'Bärselar',
  },
  {
    name: 'Medela',
    href: '/marken/medela/',
    description: 'Schweiziskt företag grundat 1961, världsledande inom bröstpumpar och amningsprodukter. Vi recenserar Swing Maxi Flex, Freestyle Flex och amningsprodukter för att hitta rätt för dig.',
    category: 'Amning & bröstpumpar',
  },
  {
    name: 'BeSafe',
    href: '/marken/besafe/',
    description: 'Norskt säkerhetsmärke grundat 1986 med fokus på bakåtvända bilbarnstolar. Vi recenserar iZi Modular RF X1, iZi Go Modular och Stretch — skandinavisk säkerhet i toppklass.',
    category: 'Bilbarnstolar',
  },
  {
    name: 'Hauck',
    href: '/marken/hauck/',
    description: 'Tyskt babyutrustningsföretag grundat 1923. Vi recenserar Walk N Care, Rapid 4 och Echo — prisvärda barnvagnar och babyutrustning för den budgetmedvetna familjen.',
    category: 'Barnvagnar & babyutrustning',
  },
  {
    name: 'Kinderkraft',
    href: '/marken/kinderkraft/',
    description: 'Polskt babyutrustningsvarumärke grundat 1994 med fokus på prisvärda produkter. Vi recenserar HELSI 2, NEWLY och SELECT — terrängvagnar och babyutrustning till konkurrenskraftiga priser.',
    category: 'Barnvagnar & babyutrustning',
  },
];
---

<ArticleLayout
  title="Barnvagnsmärken 2026 – Bugaboo, Britax & Emmaljunga"
  description="Jämför populära barnproduktmärken. Bugaboo, Britax Römer, Emmaljunga, Stokke och Cybex recenserade med betyg 2026."
  breadcrumbs={breadcrumbs}
  updatedDate="2026-04-14"
  showDisclaimer={false}
>
  <p class="text-base text-text-light mb-6 max-w-2xl">
    Att välja rätt babyutrustning är enklare när du förstår styrkorna och svagheterna hos de stora märkena. Har samlar vi vara märkesrecensioner — grundliga genomgangar av sortiment, säkerhet, pris och vad som faktiskt är värt pengarna.
  </p>

  <div class="space-y-4">
    {brands.map((brand) => (
      <a
        href={brand.href}
        class="block bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent/40 transition-all"
      >
        <div class="flex items-start justify-between gap-3">
          <div>
            <span class="text-xs font-semibold text-accent-dark bg-accent/10 px-2 py-0.5 rounded-full">{brand.category}</span>
            <h2 class="font-heading text-lg font-bold text-text mt-1.5 mb-1">{brand.name}</h2>
            <p class="text-sm text-text-light leading-relaxed">{brand.description}</p>
          </div>
          <svg class="w-5 h-5 text-text-lighter flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    ))}
  </div>

  <h2 class="font-heading text-xl font-bold mt-10 mb-4">Vår topprekommendation 2026</h2>
  <ProductCard
    name="Bugaboo Fox 5"
    badge="Bäst i test barnvagnar"
    price="14 990 kr"
    rating={4.8}
    ageRange="0–4 år"
    pros={['Bästa körkomfort i test', 'Enkel att vika med en hand', 'Hållbar för svenska underlag', 'Kan vändas mot/från föräldrar']}
    cons={['Hög prisklass', 'Tung chassi 12,4 kg']}
    ctaText="Se pris hos Reirei"
    ctaHref="https://to.babyworld.se/t/t?a=1945556823&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babysam.se%2Fbarnvagnar"
  />

  <StickyCTA href="https://at.storochliten.se/t/t?a=1060728464&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.storochliten.se%2F" productName="Bugaboo Fox 5" text="Se bästa pris — Bugaboo Fox 5" />

  <div class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold mb-3">Fler guider</h2>
    <ul class="space-y-2 text-sm">
      <li>
        <a href="/bilbarnstolar/" class="text-accent hover:underline">Bästa bilbarnstolen April 2026 — komplett test och jämförelse</a>
      </li>
      <li>
        <a href="/barnvagnar/" class="text-accent hover:underline">Bästa barnvagnen 2026</a>
      </li>
      <li>
        <a href="/matstolar/" class="text-accent hover:underline">Bästa matstolen 2026</a>
      </li>
    </ul>
  </div>


  <RetailerCTAs heading="Jämför pris hos våra partnerbutiker" compact />
</ArticleLayout>
