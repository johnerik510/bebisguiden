 />

 <ProductCard
 name="Stokke Xplory X"
 image="/images/products/stokke-xplory-x.webp"
 badge="Premiumvagn"
 rating={4.6}
 ageRange="0 till 22 kg (från födseln till ca 4 till 5 år)"
