 ctaText="Baby V"
 ctaHref="https://go.adt231.net/t/t?a=1487384745&as=2065068845&t=2&tk=1&cupa_sku=PaketXploryX&url=https://www.babyv.se/sv/articles/1.107.176/stokke-xplory-x"
 />

 <ProductCard
 name="Stokke Sleepi V3"
 image="/images/products/stokke-sleepi-v3.webp"
 badge="Bästa spjälsängen"
 rating={4.7}
 ageRange="0 till 25 kg (från födseln, konvertibel till juniorsäng)"
 pros={['Oval form, inga farliga hörn, tar mindre plats', 'Konvertiblas till juniorsäng och bänkar', 'Hög materialkvalitet i massivt bokträ']}
 cons={['Högt pris jämfort med rektangulara alternativ', 'Oval form kräver egna Stokke-madrasser']}
