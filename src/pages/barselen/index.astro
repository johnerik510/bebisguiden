---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Barselen' },
];

const faqItems = [
  {
    question: 'Fran vilken ålder kan man använda bärsele?',
    answer: 'De flesta bärselen kan användas från födseln om de har körrekt stöd for nyfödda (inlagg eller justerbar sittbredd). Kontrollera alltid att barnets huvud och nacke far tillräckligt stöd. Mjuka wraps är ofta bast for de allra minsta.',
  },
  {
    question: 'Vad är skillnaden mellan bärsele och sjal?',
    answer: 'En bärsele har fasta spannen och struktur -- snabbt att sätta pa. En barsjal (wrap) är ett langt tygstycke som knyts runt kroppen -- mjukare och närmare men tar längre att lagga. Många borjar med sjal och gar over till bärsele när barnet vaxer.',
  },
  {
    question: 'Hur längre kan man bara barn i bärsele?',
    answer: 'De flesta bärselen är gjorda for barn upp till 15-20 kg (ca 3 ar). I praktiken slutar många använda bärsele runt 12-18 månaders ålder när barnet vill ga själv. For längre vandringar kan en barsel användas längre.',
  },
];
---

<ArticleLayout
  title="Bästa bärselen 2026 - Test och jämförelse"
  description="Vi har testat de bästa bärselarna 2026. Fran nyfödd till större barn -- jämför ergonomi, komfort och pris."
  breadcrumbs={breadcrumbs}
  updatedDate="2026-03-28"
>
  <p class="text-base text-text-light mb-4 max-w-2xl">
    En bra bärsele ger närhet till barnet och frigör handerna. Vi har jämfört de populäraste bärselarna for att hjälpa dig välja ratt.
  </p>

  <h2 class="font-heading text-xl font-bold mt-6 mb-4">Vara toppval 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Ergobaby Omni Breeze"
      badge="Bast i test"
      price="2 290 kr"
      rating={4.8}
      ageRange="0-4 är (3,2-20 kg)"
      pros={['Andningsbart mesh-tyg', 'Ergonomisk M-position', 'Fyra barpositioner']}
      cons={['Hogre prisklass', 'Varmt på sommaren trots mesh']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="#"
    />

    <ProductCard
      name="BabyBjorn Harmony"
      badge="Premiumval"
      price="2 490 kr"
      rating={4.7}
      ageRange="0-3 är (3,2-15 kg)"
      pros={['Mycket mjuk och skon', 'Enkel att ta pa', 'Svensktillverkad']}
      cons={['Lagre maxvikt (15 kg)', 'Dyrast i testet']}
      ctaText="Se pris hos Babyshop"
      ctaHref="#"
    />

    <ProductCard
      name="Najell Easy"
      badge="Prisvaart"
      price="1 290 kr"
      rating={4.5}
      ageRange="0-3 är (3,5-15 kg)"
      pros={['Bra pris', 'Latt att använda', 'Svenskt marke']}
      cons={['Farre barpositioner', 'Mindre vaddering']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="#"
    />
  </div>

  <FAQ items={faqItems} />
</ArticleLayout>
