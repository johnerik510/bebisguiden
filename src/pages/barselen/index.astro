      ratingValue: 4.8,
      reviewCount: 1,
      offers: [{ price: 1699, url: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Fwww.reirei.se%2Fbarselen', seller: 'Reirei' }],
    },
    {
