      brand: 'BabyBjörn',
      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 1749, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarselar-barsjalar%2Fbarselar%2Fbabybjorn-one-air-barsele-3d-mesh-black', seller: 'Jollyroom' }],
    },
    {
      name: 'Ergobaby Embrace Bärsele, Pure Black',
      description: 'Mjuk nyföddbärsele med korsbara axelremmar. HIPS-certifierad. Från nyfödd till 11,3 kg (0-6 månader).',
      image: 'https://bebisguiden.se/images/products/ergobaby-embrace.webp',
      brand: 'Ergobaby',
      ratingValue: 4.6,
      reviewCount: 1,
      offers: [{ price: 1199, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarselar-barsjalar%2Fbarselar%2Fergobaby-embrace-barsele-pure-black', seller: 'Jollyroom' }],
