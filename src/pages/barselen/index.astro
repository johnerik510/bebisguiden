---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Bärselen' },
];

const faqItems = [
  {
    question: 'Fran vilken ålder kan man använda bärsele?',
    answer: 'De flesta bärselen kan användas från födseln om de har korrekt stöd för nyfödda (inlagg eller justerbar sittbredd). Kontrollera alltid att barnets huvud och nacke far tillräckligt stöd. Mjuka wraps är ofta bast för de allra minsta.',
  },
  {
    question: 'Vad är skillnaden mellan bärsele och sjal?',
    answer: 'En bärsele har fasta spannen och struktur -- snabbt att sätta pa. En barsjal (wrap) är ett långt tygstycke som knyts runt kroppen -- mjukår och närmår men tar längre att lägga. Många börjar med sjal och går över till bärsele när barnet växer.',
  },
  {
    question: 'Hur längre kan man bara barn i bärsele?',
    answer: 'De flesta bärselen är gjorda för barn upp till 15-20 kg (ca 3 år). I praktiken slutar många använda bärsele runt 12-18 månaders ålder när barnet vill ga själv. För längre vandringar kan en bärsel användas längre.',
  },
];
---

<ArticleLayout
  title="Bästa bärselen 2026 - Test och jämförelse"
  description="Vi har testat de bästa bärselarna 2026. Fran nyfödd till större barn -- jämför ergonomi, komfort och pris."
  breadcrumbs={breadcrumbs}
  updatedDate="2026-03-28"
>
  <p class="text-base text-text-light mb-4 max-w-2xl">
    En bra bärsele ger närhet till barnet och frigör handerna. Vi har jämfört de populäraste bärselarna för att hjälpa dig välja ratt.
  </p>

  <h2 class="font-heading text-xl font-bold mt-6 mb-4">Våra toppval 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Ergobaby Omni Breeze"
      badge="Bäst i test"
      price="2 290 kr"
      rating={4.8}
      ageRange="0-4 år (3,2–20 kg)"
      pros={['Andningsbart mesh-tyg', 'Ergonomisk M-position', 'Fyra barpositioner']}
      cons={['Högre prisklass', 'Varmt på sommårn trots mesh']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://www.jollyroom.se/babyprodukter/barselar-barsjalar/barselar/ergobaby-omni-breeze-barsele-natural-beige"
    />

    <ProductCard
      name="BabyBjorn Harmony"
      badge="Premiumval"
      price="2 490 kr"
      rating={4.7}
      ageRange="0-3 år (3,2-15 kg)"
      pros={['Mycket mjuk och skon', 'Enkel att ta pa', 'Svensktillverkad']}
      cons={['Lägre maxvikt (15 kg)', 'Dyrast i testet']}
      ctaText="Se pris hos Babyshop"
      ctaHref="https://www.jollyroom.se/babyprodukter/barselar-barsjalar/barselar/babybjorn-harmony-barsele-3d-mesh-silver"
    />

    <ProductCard
      name="Najell Easy"
      badge="Prisvärt"
      price="1 290 kr"
      rating={4.5}
      ageRange="0-3 år (3,5-15 kg)"
      pros={['Bra pris', 'Lätt att använda', 'Svenskt marke']}
      cons={['Färre barpositioner', 'Mindre vaddering']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://www.najell.se/products/easy-barsele"
    />
  </div>

  <FAQ items={faqItems} />
</ArticleLayout>
