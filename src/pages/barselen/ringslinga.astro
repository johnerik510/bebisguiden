    <p class="text-sm text-text-light"><strong>Beemoo CARE Carry</strong> är bäst budget. <strong>Love Radius HoodieCarrier 2</strong> är populärast för amning och nyfödda. <strong>Manduca First</strong> är bäst ergonomi för lång användning.</p>
  </div>

  <h2 class="font-heading text-xl font-bold mt-8 mb-4">Våra toppval 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Beemoo CARE Carry Comfort 4-in-1 Bärsele & Höftbärare, Black"
      badge="Bäst för nyfödd"
      price="219 kr"
      rating={4.4}
      image="/images/products/beemoo-care-carry.webp"
      ageRange="3,5–15 kg"
      pros={['Mycket prisvärd', '4 bärpositioner', 'Fungerar från nyfödda', 'Enkel att lära sig', 'Höftbärare ingår']}
      cons={['Enklare material', 'Andas sämre vid värme', 'Kräver korrekt bindningsteknik']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarselar-barsjalar%2Fbarselar"
    />

    <ProductCard
      name="Love Radius HoodieCarrier 2 Bärsele, Black Forest"
      badge="Populär sjalbärsele"
      price="1 349 kr"
      rating={4.6}
      image="/images/products/love-radius-hoodiecarrier.webp"
      ageRange="3–15 kg"
      pros={['Mjuk bomull/elastan', 'Perfekt för nyfödda och amning', 'Inbyggd huva för regn och sol', 'Enkel att ta på', 'Går att bära ensam utan hjälp']}
      cons={['Lär sig ta tid för perfekt passform', 'Varmare vid hetta']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarselar-barsjalar%2Fbarselar"
    />

    <ProductCard
      name="Manduca First PureCotton Bärsele, Night Black"
      badge="Ergonomisk"
      price="1 349 kr"
      rating={4.7}
      image="/images/products/manduca-first-barsele.webp"
