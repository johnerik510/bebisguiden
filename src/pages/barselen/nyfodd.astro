const featureLabels = ['Vikt barn', 'Positioner', 'Material', 'Ergonomi', 'Pris'];

const faqItems = [
  {
    question: 'Från vilken ålder kan man använda bärsele för nyfödd?',
    answer: 'De flesta bärselen för nyfödda är godkända från födseln – från ca 3,2–3,5 kg. Det viktigaste är att bebisens huvud och nacke har fullgott stöd, och att bärselen håller barnets rygg i en naturlig C-form. BabyBjörn Mini och Ergobaby Embrace är speciellt konstruerade för de allra minsta och kräver inget separat insert.',
