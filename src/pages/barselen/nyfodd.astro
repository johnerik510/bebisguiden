      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarselar-barsjalar%2Fbarselar%2Fmanduca-xt-barsele-denim-blue-toffee"
    />

    <ProductCard
      name="Didymos Didy Meh Dai"
      image="/images/products/didymos-didy-meh-dai.webp"
      badge="Hybrid-bärare"
      price="849 kr"
      rating={4.4}
      ageRange="0–2 år (3,5–15 kg)"
      pros={['Hybrid mellan bärsjal och bärsele', 'Vävt tyg med mjukt stöd', 'M-position säkerställd', 'Kan användas på fram och rygg']}
      cons={['Kräver mer inlärning', 'Tar längre att ta på än spännesystem']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarselar-barsjalar%2Fbarselar%2Fbabybjorn-harmony-barsele-3d-mesh-morkgron"
    />
