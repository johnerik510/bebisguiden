      image="/images/products/pampers-baby-dry-stl4.webp"
      pros={['Bäst i test för 5–12 månader', 'Upp till 12 timmars absorptionsförmåga', 'Extra absorberande kärna', 'Ekonomiskt storpack 120-pack']}
      cons={['Vanlig vikblöja — svårare att byta på rörligt barn', 'Något tjockare under kläderna']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Fpampers-baby-dry-night-pants-blojor-stl-5-12-17-kg-160-pack"
