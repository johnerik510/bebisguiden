      image: 'https://bebisguiden.se/images/products/pampers-baby-dry-stl4.webp',
      brand: 'Pampers',
      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 379, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Fpampers-baby-dry-blojor-stl-4-9-14-kg-120-pack', seller: 'Jollyroom' }],
