      badge="Bäst i test"
      price="449 kr"
      rating={4.8}
      image="/images/products/pampers-baby-dry-night-pants-stl-6-15-kg-138-pack.webp"
      pros={['Upp till 12 timmars torr sömn', 'Byxblöja — enkel att ta av stående', 'Extra absorberade kärna med 3 lager', 'Passar aktiva barn som sover rörigt']}
      cons={['Dyrare per blöja än dagsblöjor', 'Byxformat passar inte nyfödda']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Fpampers-baby-dry-night-pants-blojor-stl-6-15-kg-138-pack"
    />

    <ProductCard
      name="Pampers Baby-Dry Blöjor Stl 4 9-14 kg 120-pack"
  image="/images/products/pampers-baby-dry-stl4.webp"
      badge="Bäst nattblöja stl 4"
      price="379 kr"
