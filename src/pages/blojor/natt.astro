    usps: ['Mjukt material, känslig hud', 'Liberos nattvariant', 'Lättillgänglig i butik'],
    store: '',
    affiliateUrl: '',
    imageUrl: '/images/products/libero-comfort-blojor-stl-5-10-14-kg-56-pack.webp',
    accentColor: '#2563eb', bgColor: '#1e3a8a',
    desc: 'Libero Comfort passar känslig babyhud med mjukt material och hög absorptionsförmåga för natten. Finns lättillgänglig i svenska butiker.',
