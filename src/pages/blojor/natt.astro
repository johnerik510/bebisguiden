const featureLabels = ['Typ', 'Storlek', 'Absorptionsförmåga', 'Antal', 'Pris/st'];

const faqItems = [
 {
 question: 'Vad är skillnaden mellan nattblöja och vanlig blöja?',
 answer: 'Nattblöjor har en förstärkt absorberande kärna som klarar upp till 12 timmar utan att behöva bytas. Vanliga dagsblöjor är designade för snabba byten och absorberar bra men håller inte lika länge. Nattblöjor är också ofta tjockare och lite stramare runt benen för att förhindra läckage när bebisen ligger ner.',
 },
 {
 question: 'Från vilken ålder kan man använda nattblöja?',
 answer: 'Du kan börja använda nattblöjor (eller blöjor med extra absorptionsförmåga) från födseln, men det är viktigast när bebisen börjar sova längre perioder utan att vakna, typiskt 3 till 6 månaders ålder. Nyfödda som ammas behöver bytas oftare även nattetid, så nattblöjor är mindre relevanta de första månaderna.',
 },
 {
 question: 'Ska jag välja nattblöja i samma storlek som dagsblöja?',
 answer: 'Ja, välj nattblöjan i samma storlek som dagsblöjan baserat på barnets vikt. Nattblöjor är inte storleksmässigt annorlunda, de är tjockare och mer absorberande men samma vikt- och åldersgränser gäller. Välj aldrig en storlek upp för nattblöjan, en för stor blöja läcker lättare.',
 },
 {
 question: 'Varför läcker blöjan nattetid?',
 answer: 'Vanliga orsaker till nattläckage: blöjan är för liten (nattblöjor sitter extra tajt, justera storleken), blöjan är en vanlig dagsblöja som inte håller hela natten, bebisen rör sig mycket och benen skapar glapp, eller blöjan har nått sin maximala kapacitet. Byt till en nattblöja, kontrollera passformen och se till att benkanter sitter tätt mot benen.',
 },
 {
 question: 'Är det OK att inte byta blöja nattetid?',
 answer: 'Ja, om bebisen sover igenom och blöjan håller är det fullt okej att inte byta mitt i natten. Moderna nattblöjor är designade för 10 till 12 timmar utan byte. Det finns inget medicinskt skäl att väcka en sovande bebis för blöjbyte om blöjan fungerar. Undantag: vid blöjeksem eller hudirrititation kan täta byten rekommenderas av läkare.',
 },
];
