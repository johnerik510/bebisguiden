    alsoAt: [],
  },
  {
    name: 'Pampers Baby Dry Pants Blöjor 11-17 kg',
    brand: 'Pampers',
    rating: 4.7,
    badge: 'Bäst pris per blöja',
    usps: ['Byxblöja för aktiv bebis', 'Extra nattskydd', 'Passar 11-17 kg'],
    store: 'Jollyroom',
    affiliateUrl: 'https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=10331271&url=https://www.jollyroom.se/babyprodukter/halsa-hygien/blojor/pampers-baby-dry-pants-blojor',
