const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Blöjor', href: '/blojor/' },
  { label: 'Nattblöja' },
];

// No-price-policy. Affiliate-länkar/bilder oförändrade (verifierade, NOLLTOLERANS).
const products = [
  {
    name: 'Pampers Premium Protection Pants',
    brand: 'Pampers',
    rating: 4.8,
    badge: 'Bäst i test',
    usps: ['Upp till 12 timmars torr sömn', 'Premium byxmodell', 'Extra hög absorption'],
    store: 'Jollyroom',
    affiliateUrl: 'https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=10331280&url=https://www.jollyroom.se/babyprodukter/halsa-hygien/blojor/pampers-premium-protection-pants-blojor',
    imageUrl: '/images/products/pampers-premium-protection-pants.webp',
    accentColor: '#b34558', bgColor: '#4a5568',
    desc: 'Premium nattbyxblöja med extra hög absorption och upp till 12 timmars torr sömn. Byxmodell, enkel att ta av stående.',
    features: { 'Typ': 'Premium nattbyxblöja', 'Storlek': 'Stl 5-6 (11-17 kg)', 'Absorptionsförmåga': 'Extra hög (12 timmar)', 'Modell': 'Byxblöja' },
    alsoAt: [],
  },
  {
    name: 'Pampers Baby Dry Blöjor Stl 4 9-15 kg 108-pack',
    brand: 'Pampers',
    rating: 4.7,
