      ctaText="Se pris hos Babyland"
      ctaHref="https://pin.babyland.se/t/t?a=1066444612&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babyland.se%2F"
    />

    <ProductCard
      name="Muumi Baby Eco Blöjor Stl 3 5-9 kg 54-pack"
      badge="Nordisk favorit"
      price="219 kr"
      rating={4.6}
      image="/images/products/muumi-baby-stl3.webp"
      pros={['Nordic Swan-certifierad', 'Finsk design med hög kvalitet', 'Bäst pris per blöja bland Nordic Swan-blöjor', 'Mjukt och hudvänligt material']}
