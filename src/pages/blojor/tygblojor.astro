    },
    {
      name: 'Thirsties Duo Wrap',
      description: 'Överdel i hållbar PUL-konstruktion som passar de flesta insatstyper. Lågt inköpspris och snabb torktid.',
      brand: 'Thirsties',
      ratingValue: 4.6,
      reviewCount: 1,
      offers: [{ price: 139, url: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning', seller: 'Reirei' }],
    },
    {
      name: 'Bambino Mio miosolo',
      description: 'All-in-one tygblöja som används precis som en engångsblöja. Perfekt för dagis och barnvakt. Startpaket tillgängligt.',
      brand: 'Bambino Mio',
      ratingValue: 4.5,
      reviewCount: 1,
      offers: [{ price: 199, url: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning', seller: 'Reirei' }],
