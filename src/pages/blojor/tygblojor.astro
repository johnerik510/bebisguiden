---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import ProductSchema from '../../components/ProductSchema.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Blöjor', href: '/blojor/' },
  { label: 'Tygblöjor' },
];

const products = [
  {
    name: 'GroVia Hybrid',
    badge: 'Bäst i test',
    price: '159 kr/blöja',
    rating: 4.8,
    ctaHref: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning',
    features: {
      'System': 'Hybrid (engångs + tyg)',
      'Material': 'Polyester yttertyg',
      'Tvättbarheter': 'Obegränsad',
      'Pris/blöja': 'ca 159 kr',
      'Startpaket': 'Ja',
    },
  },
  {
    name: 'TotsBots Bamboozle',
    badge: 'Bäst absorption',
    price: '179 kr/blöja',
    rating: 4.7,
    ctaHref: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning',
    features: {
      'System': 'Prefold',
      'Material': 'Bambu',
      'Tvättbarheter': 'Obegränsad',
      'Pris/blöja': 'ca 179 kr',
      'Startpaket': 'Ja',
    },
  },
  {
    name: 'Thirsties Duo Wrap',
    badge: 'Bäst överdel',
    price: '139 kr/blöja',
    rating: 4.6,
    ctaHref: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning',
    features: {
      'System': 'Överdel + insats',
      'Material': 'Polyester/PUL',
      'Tvättbarheter': 'Obegränsad',
      'Pris/blöja': 'ca 139 kr',
      'Startpaket': 'Nej',
    },
  },
  {
    name: 'Bambino Mio miosolo',
    badge: 'Enklast att använda',
    price: '199 kr/blöja',
    rating: 4.5,
    ctaHref: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning',
    features: {
      'System': 'All-in-one',
      'Material': 'Mikrofiber/bomull',
      'Tvättbarheter': 'Obegränsad',
      'Pris/blöja': 'ca 199 kr',
      'Startpaket': 'Ja',
    },
  },
  {
    name: 'Charlie Banana',
    badge: 'Bäst premium',
    price: '229 kr/blöja',
    rating: 4.4,
    ctaHref: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning',
