      brand: 'Charlie Banana',
      ratingValue: 4.4,
      reviewCount: 1,
      offers: [{ price: 229, url: 'https://www.jollyroom.se/-kin-tygblojor-ateranvandning', seller: 'Reirei' }],
    },
  ]} />
</ArticleLayout>
