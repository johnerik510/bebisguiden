      brand="Libero"
      name="Libero Newborn Blöjor Stl 1 2-5 kg 30-pack"
      rating={4.7}
      rank={3}
      badge="Svensk favorit"
      accentColor="#7c3aed" bgColor="#4c1d95"
      imageUrl="/images/products/libero-newborn-stl1.webp"
