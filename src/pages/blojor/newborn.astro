        <li><a href="/blojor/ekologisk/" class="text-accent underline">Bästa ekologisk blöja 2026, miljövänliga alternativ</a></li>
        <li><a href="/blojor/natt/" class="text-accent underline">Bästa nattblöja 2026, extra absorberande</a></li>
        <li><a href="/blojor/storlek-guide/" class="text-accent underline">Blöjstorlek guide 2026, vilken storlek passar?</a></li>
        <li><a href="/blojor/libero-vs-pampers/" class="text-accent underline">Libero vs Pampers 2026, vilket märke passar ditt barn?</a></li>
      </ul>
    </div>

  </div>

  {/* 6. ItemList + Product JSON-LD (utan Offer/price, no-price-policy) */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Bästa newborn-blöjor 2026",
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.name,
        "image": `https://bebisguiden.se${p.imageUrl}`,
        "description": p.desc,
        "brand": { "@type": "Brand", "name": p.brand },
