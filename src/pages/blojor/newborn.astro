const specLabels = ['Storlek', 'Navelurringning', 'Fuktindikator', 'Antal i förpackning'];

const faqItems = [
  {
    question: 'Vilken blöja är bäst för nyfödda?',
    answer: 'Pampers New Baby är ett av de mest populära valen för nyfödda tack vare navelurringningen i storlek 1 och 2 samt den mjuka inre ytan. Libero Newborn är ett bra alternativ som är lättillgängligt i svenska butiker. Huggies Extra Care passar nyfödda med sin anpassade formgivning. Prova ett litet paket innan du köper storpack.',
