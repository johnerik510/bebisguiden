---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Blöjor', href: '/blojor/' },
  { label: 'Newborn' },
];

const products = [
  {
    name: 'Pampers New Baby Blöjor Stl 1 2-5 kg 44-pack',
    badge: 'Bäst i test',
    price: '119 kr',
    rating: 4.9,
    image: '/images/products/pampers-new-baby-stl1.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Fpampers-new-baby-blojor-stl-1-2-5-kg-44-pack',
    features: {
      'Storlek': 'Stl 1 — 2–5 kg',
      'Navelurringning': 'Ja',
      'Fuktindikator': 'Ja',
      'Antal i förpackning': '44-pack',
      'Pris/st': 'ca 2,70 kr',
    },
  },
  {
    name: 'Pampers Premium Protection Stl 2 4-8 kg 46-pack',
    badge: 'Mjukast',
    price: '149 kr',
    rating: 4.8,
    image: '/images/products/pampers-premium-stl2.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Fpampers-premium-protection-blojor-stl-2-4-8-kg-46-pack',
    features: {
      'Storlek': 'Stl 2 — 4–8 kg',
      'Navelurringning': 'Ja',
      'Fuktindikator': 'Ja',
      'Antal i förpackning': '46-pack',
      'Pris/st': 'ca 3,24 kr',
    },
  },
  {
    name: 'Libero Newborn Blöjor Stl 1 2-5 kg 30-pack',
    badge: 'Svensk favorit',
    price: '89 kr',
    rating: 4.7,
    image: '/images/products/libero-newborn-stl1.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Flibero-newborn-blojor-stl-1-2-5-kg-30-pack',
    features: {
      'Storlek': 'Stl 1 — 2–5 kg',
      'Navelurringning': 'Ja',
      'Fuktindikator': 'Ja',
      'Antal i förpackning': '30-pack',
      'Pris/st': 'ca 2,97 kr',
    },
  },
  {
    name: 'Huggies Extra Care Blöjor Stl 1 2-5 kg 25-pack',
    badge: 'Bäst passform',
    price: '79 kr',
    rating: 4.6,
    image: '/images/products/huggies-extra-care-stl1.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fhalsa-hygien%2Fblojor%2Fhuggies-extra-care-blojor-stl-1-2-5-kg-25-pack',
