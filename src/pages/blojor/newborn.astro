    trackedUrl="https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=10307494&url=https://www.jollyroom.se/babyprodukter/halsa-hygien/blojor/pampers-new-baby-blojor-stl-1-2-5-kg-44-pack"
    store="Jollyroom"
    description="Vinnare newborn-blöjor 2026. Navelurringning skyddar naveln de första veckorna, fuktindikatorn visar när bytet behövs och det dubbla läckageskyddet håller även vid lösa ammade avföringar. Mjuk inre yta mot den känsliga huden."
  />

  {/* 4. Jämförelsetabell (scan-and-click) */}
  <MoneyComparisonTable products={products} title="Jämförelsetabell - Newborn-blöjor 2026" />

  {/* 5. Detaljerad genomgång (auto-TOC byggs in i .mp-prose) */}
  <div class="mp-prose">

    {/* Vinnar-callout bevarad från prod */}
    <div class="not-prose bg-accent/10 border border-accent/30 rounded-xl p-4 mt-4 mb-4">
      <p class="text-sm font-semibold text-accent-dark mb-1">Bäst i test 2026</p>
      <p class="text-sm text-text-light"><strong>Pampers New Baby stl 1</strong> är bäst för nyfödda tack vare navelurringning, fuktindikator och mjuk yta. <strong>Libero Newborn</strong> är bäst för den som vill ha ett lättillgängligt alternativ i svenska butiker.</p>
    </div>

    <h2 class="font-heading text-2xl font-bold text-primary mt-8 mb-6">1. Pampers New Baby Stl 1, bäst i test</h2>
    <MoneyProductCard
      brand="Pampers"
      name="Pampers New Baby Blöjor Stl 1 2-5 kg 44-pack"
      rating={4.9}
      rank={1}
      badge="Bäst i test"
      accentColor="#b34558" bgColor="#4a5568"
      imageUrl="/images/products/pampers-new-baby-blojor-stl-1-2-5-kg-44-pack.webp"
