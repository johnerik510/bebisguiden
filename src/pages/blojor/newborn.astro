      pros={['Samma mjuka material som stl 1', 'Navelurringning i stl 2', 'Fuktindikator visar när det är dags att byta', 'Större förpackning']}
      cons={['Passar först när barnet väger 4+ kg', 'Inte ekologisk']}
    />
