    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fblojor-hygien-o-hud%2Fblojor%2F',
    features: {
      'Material': 'Naturliga fibrer',
      'Ekologisk': 'Nej',
      'Navelurringning': 'Ja (stl 1–2)',
      'Pris/st': 'ca 0,60 kr',
      'Betyg': '4.6/5',
    },
  },
  {
    name: 'HIPP Bambo Nature',
    badge: 'Bäst ekologisk',
    price: '0,75 kr/st',
    rating: 4.5,
    image: '/images/products/hipp-bambo-nature.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fblojor-hygien-o-hud%2Fblojor%2F',
    features: {
      'Material': 'FSC-certifierad bambu',
      'Ekologisk': 'Ja',
      'Navelurringning': 'Ja (stl 1–2)',
      'Pris/st': 'ca 0,75 kr',
      'Betyg': '4.5/5',
    },
  },
  {
    name: 'Blöjorna.se Eco',
    badge: 'Bäst budget eco',
    price: '0,45 kr/st',
    rating: 4.2,
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fblojor-hygien-o-hud%2Fblojor%2F',
