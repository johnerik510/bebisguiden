import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';
import RetailerCTAs from '../../components/RetailerCTAs.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Blojor' },
];

const products = [
  {
    name: 'Pampers Premium Protection',
    badge: 'Bäst i test',
