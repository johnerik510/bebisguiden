      image: 'https://bebisguiden.se/images/products/huggies-extra-care.webp',
      brand: 'Huggies',
      ratingValue: 4.6,
      reviewCount: 1,
      offers: [{ price: 0.60, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fblojor-hygien-o-hud%2Fblojor%2F', seller: 'Jollyroom' }],
    },
    {
      name: 'HIPP Bambo Nature',
      description: 'Ekologisk blöja i FSC-certifierad bambu. Fri från klor, parfym och syntetiska tillsatser. Bra för känslig hud.',
