---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Om redaktionen' },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Bebisguiden.se, redaktionen',
  itemListElement: [
    {
      '@type': 'Person',
      name: 'Sofia Lindgren',
      url: 'https://bebisguiden.se/om-redaktionen/',
      image: 'https://bebisguiden.se/images/redaktion-sofia.webp',
      jobTitle: 'Leg. barnmorska & chefredaktör',
      knowsAbout: ['amning', 'nyfödda', 'barnhälsa', 'bebissömn', 'spädbarnsutveckling'],
      worksFor: { '@type': 'Organization', name: 'Bebisguiden.se', url: 'https://bebisguiden.se' },
    },
    {
      '@type': 'Person',
      name: 'Anna Bergström',
      url: 'https://bebisguiden.se/om-redaktionen/',
      image: 'https://bebisguiden.se/images/redaktion-anna.webp',
      jobTitle: 'Barnsjuksköterska & produktgranskare',
      knowsAbout: ['barnprodukter', 'bilbarnstolar', 'barnvagnar', 'barnsäkerhet', 'i-Size', 'ISOFIX'],
      worksFor: { '@type': 'Organization', name: 'Bebisguiden.se', url: 'https://bebisguiden.se' },
    },
  ],
};
---

<BaseLayout
  title="Om redaktionen, Bebisguiden.se"
  description="Möt Sofia Lindgren och Anna Bergström, redaktionen bakom Bebisguiden.se. Leg. barnmorska och barnsjuksköterska med bred erfarenhet av barnprodukter."
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold text-text mt-3 mb-6">Om redaktionen</h1>

    <!-- Sofia -->
    <div class="bg-sky-50 border border-sky-200 rounded-2xl p-6 sm:p-8 mb-6">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <img
          src="/images/redaktion-sofia.webp"
          alt="Sofia Lindgren"
          class="w-24 h-24 rounded-full object-cover flex-shrink-0"
          width="96"
          height="96"
          loading="eager"
        />
        <div>
          <h2 class="font-heading text-xl font-bold text-gray-900 mb-1">Sofia Lindgren</h2>
          <p class="text-sky-700 font-semibold text-sm mb-3">Leg. barnmorska & chefredaktör</p>
          <p class="text-gray-700 leading-relaxed">
            Sofia är legitimerad barnmorska med 12 års klinisk erfarenhet och chefredaktör för Bebisguiden.se. Hon ansvarar för allt medicinskt och hälsorelaterat innehåll på sajten och granskar att råden om amning, sömnmiljö och bebisens hälsa stämmer med aktuella riktlinjer från Socialstyrelsen och WHO.
          </p>
        </div>
      </div>
    </div>

    <!-- Anna -->
    <div class="bg-sky-50 border border-sky-200 rounded-2xl p-6 sm:p-8 mb-8">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <img
          src="/images/redaktion-anna.webp"
          alt="Anna Bergström"
          class="w-24 h-24 rounded-full object-cover flex-shrink-0"
          width="96"
          height="96"
          loading="lazy"
        />
        <div>
          <h2 class="font-heading text-xl font-bold text-gray-900 mb-1">Anna Bergström</h2>
          <p class="text-sky-700 font-semibold text-sm mb-3">Barnsjuksköterska & produktgranskare</p>
          <p class="text-gray-700 leading-relaxed">
            Anna är specialistutbildad barnsjuksköterska (barn och ungdom) och ansvarar för produktgranskning på Bebisguiden.se. Hon har testat över 100 barnprodukter, med särskilt fokus på bilbarnstolar, barnvagnar och babyvakter, och värderar alltid säkerhet och klinisk relevans framför design och pris.
          </p>
        </div>
      </div>
    </div>

    <div class="prose prose-sm text-text-light max-w-none">
      <h2>Vår metodik</h2>
      <p>
        Alla produkter på Bebisguiden.se bedöms enligt fem kriterier: säkerhet, användarvänlighet, komfort, kvalitet och hållbarhet, samt pris och värde. Vi baserar oss på:
      </p>
      <ul>
        <li>Oberoende krocktester från Folksam, ADAC och Stiftung Warentest</li>
        <li>Europeiska säkerhetsstandarder (i-Size/R129, ECE R44, EN-standarder)</li>
        <li>Praktisk testning i minst 4 veckor per produkt</li>
        <li>Feedback från svenska familjer som testat produkterna</li>
        <li>Prisjämförelser från ledande svenska återförsäljare</li>
      </ul>
      <p>
        Läs mer om våra testkriterier på sidan <a href="/sa-testar-vi/" class="text-sky-700 hover:text-sky-900 underline">Så testar vi</a>.
      </p>

      <h2>Oberoende</h2>
      <p>
        Bebisguiden.se finansieras genom affiliatelänkar, vi får en liten provision när du handlar via våra länkar. Det kostar dig ingenting extra. Våra betyg, rankingar och rekommendationer påverkas aldrig av affiliatesamarbeten. Vi rekommenderar bara produkter vi själva skulle välja för våra egna barn.
      </p>
      <p>
        Läs vår fullständiga <a href="/redaktionell-policy/" class="text-sky-700 hover:text-sky-900 underline">redaktionella policy</a> för mer information.
      </p>

      <h2>Kontakt</h2>
      <p>
        Har du frågor, förslag eller vill samarbeta? Kontakta oss på <span class="js-email" data-u="elscatalyst" data-d="proton.me"></span>.
      </p>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</BaseLayout>
