const faqItems = [
 {
 question: 'Måste man sterilisera nappflaskor?',
 answer: '1177 rekommenderar sterilisering av nappflaskor, nappar och bröstpumpsdelar för nyfödda och barn under fyra månader. Anledningen är att immunförsvaret fortfarande är omoget och bakterier som annars är ofarliga kan orsaka magsjuka eller infektioner. Efter fyra månader räcker diskning i diskmaskin på minst 60 grader för friska barn.',
