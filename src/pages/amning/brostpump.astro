      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 3999, url: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbrostpumpar', seller: 'Reirei' }],
    },
