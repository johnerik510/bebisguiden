      brand: 'Spectra',
      ratingValue: 4.6,
      reviewCount: 1,
      offers: [{ price: 2499, url: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbrostpumpar', seller: 'Reirei' }],
    },
  ]} />
</ArticleLayout>

<StickyCTA
  href="https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbrostpumpar"
