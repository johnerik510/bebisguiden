const featureLabels = ['Typ', 'Bälta', 'Material', 'Öppning', 'Användning'];

const faqItems = [
  {
    question: 'När ska man börja använda amnings-BH?',
    answer: 'Många börjar använda amnings-BH under graviditeten, runt vecka 36–38, när brösten förbereder sig för amning och vanliga BH:ar börjar kännas obekväma. En amnings-BH utan bygel är bra att ha från förlossningen och framåt. Ha minst 2–3 amnings-BH:ar så att du alltid har rena när en är i tvätten.',
  },
  {
    question: 'Hur hittar man rätt storlek på amnings-BH?',
    answer: 'Mät undertill (runt revbenen direkt under brösten) och sätt dit rätt kupstorlek. Brösten förändras under amning — de svullnar när mjölken kommer in och krymper lite när amningsfrekvensen minskar. Välj en BH med lite rörlighet i bandstorleken (t.ex. hakarna på mittlaget) så att du kan justera. Carriwell och Medela har generösa storleksguider på sina webbplatser.',
  },
  {
    question: 'Ska man ha amnings-BH med eller utan bygel?',
    answer: 'Under de första 3–6 månaderna rekommenderas BH utan bygel, särskilt nattetid. En bygel som sitter fel kan trycka mot mjölkgångarna och orsaka igentäppning eller mastit. När amningen är etablerad (efter 3–6 månader) och bröststorleken har stabiliserats kan du bära en välpassad amnings-BH med bygel under dagen om det känns bekvämare.',
  },
  {
    question: 'Hur många amnings-BH:ar behöver man?',
    answer: 'Räkna med att behöva minst 3–4 amnings-BH:ar. Under amningsperioden förekommer läckage och du behöver byta BH dagligen. Tvättas ofta i 40–60°C vilket sliter på materialet snabbare. Ha alltid minst en ren i beredskap. Köp 2–3 i din primära storlek och en extra om du är tveksam på om storleken stämmer.',
  },
  {
    question: 'Kan man använda en vanlig sport-BH för amning?',
    answer: 'Nej — en vanlig sport-BH saknar amningsöppning och är svår att öppna diskret. Dessutom sitter sport-BH:ar ofta tight runt brösten, vilket kan öka risken för igentäppta mjölkgångar. Välj en amnings-BH eller en sport-amnings-BH specifikt utformad för amning. Carriwell erbjuder amnings-sport-BH:ar om du vill träna under amningsperioden.',
  },
];
---

<ArticleLayout
  title="Bästa amnings-BH 2026 — komfort och funktion under amning"
  description="En bra amnings-BH gör amningen enklare. Vi testar och rankar bästa modellerna 2026 — med och utan bygel, för dag och natt."
  breadcrumbs={breadcrumbs}
  canonical="https://bebisguiden.se/amning/amningsbh/"
  updatedDate="2026-04-14"
>
  <p class="text-base text-text-light mb-3 max-w-2xl">
    En välpassad amnings-BH gör stor skillnad för komforten under amningsperioden. Vi guidar dig genom de viktigaste egenskaperna och rekommenderar bästa modellerna.
  </p>

  <h2 class="font-heading text-xl font-bold mt-2 mb-3">Jämförelsetabell — amnings-BH 2026</h2>
