      cons={['Ger inte lika mycket lyft som bygel-BH', 'Storleksanpassning kan behövas', 'Begränsade färgval']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fmamma%2Fmammaklader%2Famningsklader%2Famnings-bh%2Fcarriwell-vadderad-gravid-och-amnings-bh-svart"
