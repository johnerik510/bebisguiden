      'Typ': 'Resematstol med 360-rotation',
      'Vikt': '2,0 kg',
      'Ålder': '6 mån–3 år',
      'Bältessystem': '5-punkts',
      'Fästs vid stol': 'Ja',
    },
  },
  {
    name: 'BabyBjörn Sittdyna Booster Seat',
    badge: 'Bäst design',
    price: '1 099 kr',
    rating: 4.6,
    image: '/images/products/babybjorn-sittdyna-booster-seat.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarnstolar-tillbehor%2Fbarnmatstolar%2Fstokke-tripp-trapp-matstol-oak-natural',
    features: {
      'Typ': 'Premium boostersits',
      'Vikt': '1,4 kg',
      'Ålder': '6 mån–3 år',
      'Bältessystem': '5-punkts',
      'Fästs vid stol': 'Ja',
    },
  },
  {
    name: 'Inglesina Fast Table Chair',
    badge: 'Bäst budget',
    price: '799 kr',
    rating: 4.4,
    image: '/images/products/inglesina-fast-table-chair.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarnstolar-tillbehor%2Fbarnmatstolar%2Fstokke-tripp-trapp-matstol-oak-natural',
    features: {
      'Typ': 'Bordmonterad stol',
      'Vikt': '2,0 kg',
      'Ålder': '6 mån–3 år',
      'Bältessystem': '3-punkts',
      'Fästs vid stol': 'Ja (bordskant)',
    },
  },
