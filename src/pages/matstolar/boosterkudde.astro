---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';
import CTABox from '../../components/CTABox.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Matstolar', href: '/matstolar/' },
  { label: 'Boosterkudde' },
];

const products = [
  {
    name: 'Chicco Pocket Snack Booster Seat',
    badge: 'Bäst i test',
    price: '499 kr',
    rating: 4.8,
    image: '/images/products/chicco-pocket-snack-booster-seat.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fbarnstolar-tillbehor%2Fbarnmatstolar%2Fstokke-tripp-trapp-matstol-oak-natural',
    features: {
      'Typ': 'Boostersits',
      'Vikt': '1,8 kg',
      'Ålder': '6 mån–3 år',
      'Bältessystem': '3-punkts',
      'Fästs vid stol': 'Ja',
    },
  },
  {
    name: 'Chicco 360 Travel Highchair',
    badge: 'Bäst för resor',
    price: '799 kr',
