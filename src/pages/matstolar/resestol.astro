const featureLabels = ['Typ', 'Ålder', 'Maxvikt', 'Bälte', 'Pris'];

const faqItems = [
  {
    question: 'Vilken typ av resematstol passar bäst?',
    answer: 'Det beror på hur du reser och vad du behöver. Stokke Clikk är bäst för semesterboenden med egna stolar som inte har matstol – den är enkel att packa och ta med. Bordsklämmare (Chicco Pocket Snack, Inglesina) passar restauranger och familjer med kompakt bagage. Summer Infant Pop n Sit är bäst för extrem minimalism – den tar nästan inget utrymme alls.',
  },
