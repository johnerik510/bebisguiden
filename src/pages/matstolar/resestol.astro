      'Typ': 'Bordsklämma',
      'Ålder': '6 mån – 3 år',
      'Maxvikt': '15 kg',
      'Bälte': '3-punkts (ingår)',
      'Pris': '799 kr',
    },
  },
  {
    name: 'Joie MimzySnacker',
    badge: 'Liten fotavtryck',
    price: '699 kr',
    rating: 4.4,
    ctaHref: 'https://to.babyworld.se/t/t?a=1945556823&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babysam.se%2Fmatstolar',
    features: {
      'Typ': 'Kompakt matstol',
      'Ålder': '6 mån – 3 år',
