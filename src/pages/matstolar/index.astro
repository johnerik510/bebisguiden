      pros={['7 höjdlägen passar alla bord', 'Babysitter-tillbehör för de allra minsta', 'Modulärt: byggs på med Cybex-tillbehör', 'Ikonisk minimalistisk design']}
      cons={['Grundmodell utan bricka, köps separat', 'Bricka och babysitter kostar extra', 'Tyngre att flytta (ca 12 kg)']}
