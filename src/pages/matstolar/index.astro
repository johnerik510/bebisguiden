      'Ålder': '6 mån – 3 år',
      'Maxvikt': '15 kg',
      'Tillverkning': 'Plast',
      'Anpassningsbar': 'Nej',
      'Bältessystem': '3-punkts (ingår)',
    },
  },
  {
    name: 'BabyBjörn High Chair',
    badge: 'Bäst komfort',
    image: '/images/products/babybjorn-high-chair.jpg',
    price: '3 790 kr',
    rating: 4.7,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'Ålder': '6 mån – 3 år',
      'Maxvikt': '15 kg',
      'Tillverkning': 'Sverige',
      'Anpassningsbar': 'Ja – bord och fotbräda',
      'Bältessystem': '5-punkts (ingår)',
    },
  },
  {
    name: 'Chicco Polly Magic Relax',
    badge: 'Bäst mångsidig',
    price: '1 990 kr',
    rating: 4.5,
    image: '/images/products/chicco-polly-magic.jpg',
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'Ålder': '0 mån – 3 år',
      'Maxvikt': '15 kg',
      'Tillverkning': 'Italien',
      'Anpassningsbar': 'Ja – 7 höjdlägen, 4 rygglägen',
