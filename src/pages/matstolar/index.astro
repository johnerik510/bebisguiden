  </div>

  {/* 5. Detaljerad genomgång (auto-TOC byggs in i .mp-prose) */}
  <div class="mp-prose">

    <h2 class="font-heading text-2xl font-bold text-primary mt-8 mb-6">1. Stokke Tripp Trapp Oak Natural, bäst i test 2026</h2>
    <MoneyProductCard
      brand="Stokke"
      name="Stokke Tripp Trapp Oak Natural"
      rating={4.9}
      rank={1}
      badge="Bäst i test"
      accentColor="#b34558" bgColor="#4a5568"
      imageUrl="/images/products/stokke-tripp-trapp-oak-natural.webp"
      imageAlt="Stokke Tripp Trapp Oak Natural matstol"
