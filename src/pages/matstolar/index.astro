    <MoneyCTABox store="Jollyroom" affiliateUrl="https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=10194466&url=https://www.jollyroom.se/babyprodukter/barnstolar-tillbehor/barnmatstolar/cybex-lemo-matstol-suede-grey" />

