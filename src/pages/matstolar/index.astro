      rank={3}
      badge="Bäst premium"
      accentColor="#7c3aed" bgColor="#4c1d95"
      imageUrl="/images/products/nuna-bryn-matstol.webp"
      imageAlt="Nuna Bryn Matstol Heritage"
      store="Baby V"
      buyUrl="https://go.adt231.net/t/t?a=1487384745&as=2065068845&t=2&tk=1&cupa_sku=1HC17101HRIGL&url=https://www.babyv.se/sv/articles/1.107.24387/nuna-bryn-matstol-heritage"
      pros={['9 höjdlägen, mest av alla i testet', '5-punktsbälte ingår utan extra kostnad', 'Skandinavisk premiumdesign', 'Mjukt avtagbart kuddsystem']}
      cons={['Högt pris ca 4 995 kr', 'Kortare åldersspann än Tripp Trapp', 'Begränsad tillgänglighet i Sverige']}
    />
