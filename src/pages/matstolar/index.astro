    price: '2 990 kr',
    rating: 4.9,
    image: '/images/products/stokke-tripp-trapp.jpg',
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'Ålder': 'Från 6 mån (med tillbehör)',
      'Maxvikt': '136 kg (vuxen)',
      'Tillverkning': 'Norge – bok/ek',
      'Anpassningsbar': 'Ja – följer barnet',
