    meta: 'EN 716 · säker sovmiljö',
  },
  {
    href: '/sovsackar/',
    name: 'Sovsäckar',
    img: '/images/cat-sovsack.webp',
    lede: 'Rätt TOG-värde för rätt rumstemperatur. Vi förklarar hur du väljer — och testar material, passform och tvättbarhet.',
    meta: 'TOG-guide och materialtest',
  },
  {
    href: '/amning/',
    name: 'Amning & matning',
    img: '/images/cat-amning.webp',
    lede: 'Bröstpumpar, nappflaskor och sterilisatorer jämförda utifrån faktisk användning — samt guider om amning, BLW och fast föda.',
    meta: 'Redaktionella guider · produkttester',
  },
];

const guidehubbar = [
  { name: 'Hälsa & symptom', href: '/guider/halsa-och-symptom/', desc: 'Feber, kolik, magont, utslag — när du ska vara orolig och när det är normalt.', anchor: 'Läs guider om barns hälsa', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Sömn', href: '/guider/somn/', desc: 'Säker sovmiljö enligt barnläkarpraxis, sovrutiner och regression.', anchor: 'Läs guider om bebissömn', icon: 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z' },
  { name: 'Mat & amning', href: '/guider/mat-och-amning/', desc: 'Amning, fast föda, BLW och introduktion av allergener.', anchor: 'Läs guider om amning och mat', icon: 'M12 2v20M6 8c0-2.21 1.79-4 4-4h4c2.21 0 4 1.79 4 4v12H6V8z' },
  { name: 'Utrustning', href: '/guider/utrustning/', desc: 'Vad du faktiskt behöver — och vad du kan hoppa över.', anchor: 'Läs guider om babyutrustning', icon: 'M5 13l4 4L19 7' },
  { name: 'Förberedelser', href: '/guider/forberedelser/', desc: 'Checklistor inför förlossningen, packlista och graviditetsveckor.', anchor: 'Läs guider om förberedelser', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
];

const senasteNyheter = [
  {
    href: '/guider/bilbarnstol-regler/',
    title: 'Nya regler för bilbarnstolar 2026 — så gäller i-Size och ECE R44',
    anchor: 'Läs hela guiden om bilbarnstolsregler 2026',
    category: 'Säkerhet',
    date: '2026-04-20',
    dateLabel: '20 april 2026',
    excerpt: 'Vad gäller för bakåtvänt åkande, ISOFIX och vilka stolar som snart fasas ut enligt R44-04.',
    image: '/images/cat-bilbarnstol.webp',
    imageAlt: 'Bilbarnstol monterad i bil — regler och standarder 2026',
  },
  {
    href: '/guider/bebis-kolik/',
    title: 'Kolik hos bebis: symptom, tröstmetoder och när du ska kontakta BVC',
    anchor: 'Läs guiden om kolik hos bebis',
    category: 'Hälsa',
    date: '2026-04-19',
    dateLabel: '19 april 2026',
    excerpt: 'Så skiljer du vanlig spädbarnsgråt från kolik — och vilka tröstmetoder som faktiskt är bevisade.',
    image: '/images/hero-bebis.webp',
    imageAlt: 'Nyfödd bebis i förälders famn',
  },
  {
    href: '/guider/bebis-feber/',
    title: 'Feber hos bebis — när bör du söka vård?',
    anchor: 'Läs guiden om feber hos bebis',
    category: 'Hälsa',
    date: '2026-04-19',
    dateLabel: '19 april 2026',
    excerpt: 'Temperaturgränser, vanliga missförstånd och en tydlig checklista för när 1177 är rätt steg.',
    image: '/images/cat-babyvakt.webp',
    imageAlt: 'Bebis som sover — feber och temperatur',
  },
  {
    href: '/guider/vad-behover-nyfodd/',
    title: 'Vad behöver en nyfödd? Realistisk checklista för första veckorna',
    anchor: 'Läs checklistan för nyfödd utrustning',
    category: 'Förberedelser',
    date: '2026-04-19',
    dateLabel: '19 april 2026',
    excerpt: 'Vi har skurit ned de fluffiga 200-poster-listorna till det du faktiskt använder månad ett.',
    image: '/images/cat-babyklader.webp',
    imageAlt: 'Babykläder och nyföddutrustning',
  },
  {
    href: '/guider/blw-guide/',
    title: 'BLW-guide: starta baby-led weaning tryggt från sex månader',
    anchor: 'Läs hela BLW-guiden',
    category: 'Mat & amning',
    date: '2026-04-19',
    dateLabel: '19 april 2026',
    excerpt: 'Första maten, säkra bitstorlekar och vad barnläkare egentligen tycker om metoden.',
    image: '/images/cat-matstol.webp',
    imageAlt: 'Bebis i matstol som testar fast föda',
  },
  {
    href: '/guider/bebis-sovschema/',
    title: 'Sovschema för bebis månad för månad — så ser ett realistiskt dygn ut',
    anchor: 'Läs guiden om bebisens sovschema',
    category: 'Sömn',
    date: '2026-04-18',
    dateLabel: '18 april 2026',
    excerpt: 'Från nyfödd till 12 månader — genomsnittlig sömn, vakenintervall och vanliga regressioner.',
    image: '/images/cat-sovsack.webp',
    imageAlt: 'Bebis som sover i sovsäck',
  },
];
---

<BaseLayout
  title="Bebisguiden — Oberoende granskning av barnprodukter"
  description="Redaktionell guide för svenska föräldrar. Vi läser krocktester, följer europeiska säkerhetsstandarder och testar produkter i verklig miljö innan vi rekommenderar."
>
  <link slot="head" rel="preload" as="image" href="/images/hero-bebis.webp" type="image/webp" />

  <!-- Hero -->
  <section class="text-white relative overflow-hidden min-h-[680px] md:min-h-[760px] flex flex-col">
    <img
      src="/images/hero-bebis.webp"
      alt="Förälder med nyfödd bebis"
      width="1920"
      height="1280"
      class="absolute inset-0 w-full h-full object-cover -z-10"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Layered cinematic gradients för djup -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#3d0a1f] via-primary/90 to-primary/40 -z-10" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-black/30 -z-10" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(255,255,255,0.12),transparent_55%)] -z-10" aria-hidden="true"></div>
    <div class="absolute inset-0 opacity-[0.12] mix-blend-overlay -z-10" aria-hidden="true" style="background-image: radial-gradient(circle at 1px 1px, white 0.8px, transparent 0); background-size: 3px 3px;"></div>
    <!-- Glödande accent-orb -->
    <div class="absolute -top-20 -right-20 w-[520px] h-[520px] rounded-full bg-accent/20 blur-[140px] -z-10" aria-hidden="true"></div>
    <div class="absolute -bottom-40 left-1/4 w-[420px] h-[420px] rounded-full bg-primary-dark/40 blur-[120px] -z-10" aria-hidden="true"></div>

    <!-- Editorial masthead (topp) -->
    <div class="relative border-b border-white/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between text-[11px] font-semibold uppercase tracking-[0.22em] text-white/75">
        <div class="flex items-center gap-5">
          <span class="inline-flex items-center gap-2">
            <span class="italic font-normal normal-case tracking-normal text-sm text-white/90" style="font-family: Georgia, 'Times New Roman', serif;">Nº</span>
            <span class="text-white/90">04 / April 2026</span>
          </span>
          <span class="hidden md:inline-block w-8 h-px bg-accent/60"></span>
          <span class="hidden md:inline text-white/60">Oberoende redaktion</span>
        </div>
        <div class="flex items-center gap-5">
          <span class="hidden sm:inline text-white/60">Uppdaterad 23 april 2026</span>
          <span class="hidden sm:inline-block w-8 h-px bg-accent/60"></span>
          <span class="flex items-center gap-2">
            <span class="relative flex h-1.5 w-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent"></span>
            </span>
            Live
          </span>
        </div>
      </div>
    </div>

    <!-- Huvudinnehåll -->
    <div class="flex-1 flex items-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 relative w-full">
        <!-- Stor signaturstämpel bakom allt -->
        <div class="absolute -top-10 right-0 lg:right-8 text-[280px] lg:text-[380px] font-heading font-black text-white/[0.03] leading-none select-none pointer-events-none" aria-hidden="true" style="font-family: Georgia, 'Times New Roman', serif;">B</div>

        <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center relative">
          <!-- Vänstersida: rubrik + text + CTA -->
          <div class="lg:col-span-7 relative">
            <!-- Liten pre-kicker med serif -->
            <div class="flex items-center gap-3 mb-6">
              <span class="w-12 h-px bg-rose-300"></span>
              <span class="text-[11px] font-bold uppercase tracking-[0.28em] text-rose-200">Bebisguiden</span>
              <span class="italic text-sm text-white/60" style="font-family: Georgia, 'Times New Roman', serif;">est. 2026</span>
            </div>

            <!-- H1 med editorial highlight -->
            <h1 class="font-heading text-5xl sm:text-6xl lg:text-[5.5rem] font-bold leading-[0.98] mb-7 tracking-[-0.02em]">
              Tryggare val
              <br class="hidden sm:inline">
              <span class="text-white/55 font-normal">för </span><span class="relative inline-block">
                <span class="relative z-10 italic" style="font-family: Georgia, 'Times New Roman', serif; font-weight: 500;">nyblivna</span>
              </span>
              <br class="hidden sm:inline">
              <span class="relative inline-block">
                <span class="relative z-10">föräldrar.</span>
                <svg class="absolute -bottom-3 left-0 w-full z-0 text-accent" aria-hidden="true" viewBox="0 0 300 12" preserveAspectRatio="none">
                  <path d="M2 8 Q 75 2, 150 6 T 298 5" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" fill="none"/>
                </svg>
              </span>
            </h1>

            <!-- Brödtext med drop-cap-känsla -->
            <p class="text-lg sm:text-xl text-white/85 leading-relaxed mb-8 max-w-xl">
              En oberoende redaktion som läser krocktester, följer europeiska säkerhetsstandarder och testar barnprodukter i verkliga hem <span class="italic text-white/70" style="font-family: Georgia, 'Times New Roman', serif;">— så att du kan välja rätt utan att lägga timmar i forumtrådar.</span>
            </p>

            <!-- CTA-knappar -->
            <div class="flex flex-wrap gap-3 mb-10">
              <a href="/bilbarnstolar/" class="group inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-semibold px-6 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30 hover:shadow-xl hover:shadow-accent/40 hover:-translate-y-0.5">
                Se bästa bilbarnstolarna
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <a href="/barnvagnar/" class="inline-flex items-center gap-2 bg-white/[0.08] hover:bg-white/[0.15] backdrop-blur-sm border border-white/20 text-white font-semibold px-6 py-3.5 rounded-xl transition-all">
                Bästa barnvagnarna
              </a>
            </div>

            <!-- Stats som editorial mini-kolumner med serif-accent -->
            <div class="grid grid-cols-3 gap-0 max-w-xl border-t border-b border-white/20 divide-x divide-white/15 bg-white/[0.03] backdrop-blur-[2px]">
              <div class="py-5 px-4 sm:px-5">
                <div class="flex items-baseline gap-1">
                  <span class="font-heading text-4xl sm:text-5xl font-bold text-white leading-none tracking-tight">100</span>
                  <span class="font-heading text-2xl font-bold text-rose-200 leading-none italic" style="font-family: Georgia, serif;">+</span>
                </div>
                <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.18em] text-white/60 mt-2.5 leading-tight font-semibold">Produkter<br class="hidden sm:inline">testade</div>
              </div>
              <div class="py-5 px-4 sm:px-5">
                <div class="font-heading text-4xl sm:text-5xl font-bold text-white leading-none tracking-tight">13</div>
                <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.18em] text-white/60 mt-2.5 leading-tight font-semibold">Kategorier<br class="hidden sm:inline">granskade</div>
              </div>
              <div class="py-5 px-4 sm:px-5">
                <div class="flex items-baseline gap-1.5">
                  <span class="font-heading text-4xl sm:text-5xl font-bold text-white leading-none tracking-tight">0</span>
                  <svg class="w-4 h-4 text-rose-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </div>
                <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.18em] text-white/60 mt-2.5 leading-tight font-semibold">Sponsrade<br class="hidden sm:inline">omdömen</div>
              </div>
            </div>
          </div>

          <!-- Högersida: editorial polaroid-stack -->
          <aside class="lg:col-span-5 hidden lg:block relative">
            <!-- Bakgrundskort (lutar) -->
            <div class="absolute inset-0 bg-white/[0.04] backdrop-blur-sm border border-white/10 rounded-2xl transform rotate-[3deg] translate-x-4 translate-y-3" aria-hidden="true"></div>
            <div class="absolute inset-0 bg-white/[0.05] backdrop-blur-sm border border-white/12 rounded-2xl transform -rotate-[1.5deg]" aria-hidden="true"></div>

            <!-- Huvudkort -->
            <div class="relative bg-gradient-to-br from-white/[0.12] to-white/[0.06] backdrop-blur-xl border border-white/20 rounded-2xl shadow-2xl overflow-hidden">
              <!-- Topp-etikett -->
              <div class="flex items-center justify-between px-6 pt-5 pb-3 border-b border-white/10">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
                  <span class="text-[10px] font-bold uppercase tracking-[0.28em] text-rose-200">Månadens test</span>
                </div>
                <span class="italic text-[11px] text-white/50" style="font-family: Georgia, serif;">april 2026</span>
              </div>

              <!-- Bild-strip -->
              <div class="relative h-40 overflow-hidden border-b border-white/10">
                <img src="/images/cat-bilbarnstol.webp" alt="Bilbarnstol i test" class="w-full h-full object-cover opacity-90" loading="eager" />
                <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-primary/20 to-transparent"></div>
                <div class="absolute bottom-3 left-4 right-4 flex items-end justify-between gap-3">
                  <span class="inline-flex items-center gap-1.5 bg-accent/95 backdrop-blur-sm rounded-full px-2.5 py-1 text-[10px] font-bold text-white uppercase tracking-wider shadow-lg">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    Bäst i test
                  </span>
                  <span class="text-[10px] font-semibold text-white/80 uppercase tracking-wider">14 modeller</span>
                </div>
              </div>

              <!-- Innehåll -->
              <div class="px-6 py-5">
                <h2 class="font-heading text-2xl font-bold text-white leading-tight mb-2.5">
                  Bästa <span class="italic font-semibold" style="font-family: Georgia, serif;">bilbarnstolen</span> 2026
                </h2>
                <p class="text-sm text-white/75 leading-relaxed mb-5">
                  Testat enligt <span class="text-rose-200 font-semibold">i-Size/R129</span> och Folksams krocktester. Fyra modeller klarade alla krav.
                </p>

                <!-- Delar / betygsindikatorer -->
                <div class="space-y-2.5 mb-5 pb-5 border-b border-white/10">
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-xs text-white/70 font-medium">Säkerhet</span>
                    <div class="flex gap-1 items-center">
                      {[1,2,3,4,5].map(() => <span class="w-5 h-1.5 rounded-full bg-gradient-to-r from-accent to-accent-dark"></span>)}
                      <span class="ml-1.5 text-[11px] font-bold text-white">5.0</span>
                    </div>
                  </div>
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-xs text-white/70 font-medium">Installation</span>
                    <div class="flex gap-1 items-center">
                      {[1,2,3,4].map(() => <span class="w-5 h-1.5 rounded-full bg-gradient-to-r from-accent to-accent-dark"></span>)}
                      <span class="w-5 h-1.5 rounded-full bg-white/15"></span>
                      <span class="ml-1.5 text-[11px] font-bold text-white/80">4.2</span>
                    </div>
                  </div>
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-xs text-white/70 font-medium">Komfort</span>
                    <div class="flex gap-1 items-center">
                      {[1,2,3,4].map(() => <span class="w-5 h-1.5 rounded-full bg-gradient-to-r from-accent to-accent-dark"></span>)}
                      <span class="w-5 h-1.5 rounded-full bg-white/15"></span>
                      <span class="ml-1.5 text-[11px] font-bold text-white/80">4.5</span>
                    </div>
                  </div>
                </div>

                <!-- CTA -->
                <a href="/bilbarnstolar/" class="group flex items-center justify-between w-full text-sm font-semibold text-white hover:text-accent transition-colors">
                  <span class="inline-flex items-center gap-2.5">
                    <span class="w-8 h-px bg-accent group-hover:w-12 transition-all"></span>
                    Läs hela testet
                  </span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>

            <!-- Liten byline under kortet -->
            <div class="mt-5 flex items-center gap-2.5 text-[11px] text-white/55 pl-2">
              <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span>Källbelagd · granskad av redaktionen</span>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <!-- Scroll-indikator & källor-ribbon -->
    <div class="relative border-t border-white/10 bg-black/20 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between text-[11px] font-semibold uppercase tracking-[0.22em] text-white/60">
        <span class="inline-flex items-center gap-2.5">
          <svg class="w-3.5 h-3.5 animate-bounce text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          <span class="hidden sm:inline">Scrolla för att läsa</span>
        </span>
        <span class="flex items-center gap-2.5 sm:gap-4">
          <span class="italic normal-case tracking-normal text-white/50 text-xs hidden md:inline" style="font-family: Georgia, serif;">Vi bygger på:</span>
          <span class="text-white/70">Folksam</span>
          <span class="text-accent/60">·</span>
          <span class="text-white/70">ADAC</span>
          <span class="text-accent/60 hidden sm:inline">·</span>
