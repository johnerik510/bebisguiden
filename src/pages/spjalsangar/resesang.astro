      ctaHref="https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fvaggor"
    />

    <ProductCard
      name="Hauck Dream N Play Plus"
      badge="Bäst budget"
