      pros={['Meshsidor för utmärkt luftcirkulation', 'Fem justerbara höjdlägen', 'Fällbar sidopanel för enkel nattamning', 'Välkänt varumärke med stark säkerhetsprofil', 'Ingår mjuk madrass och förvaringspåse']}
