  />

  {/* 4. Jämförelsetabell (scan-and-click) */}
  <MoneyComparisonTable products={products} title="Jämförelsetabell - Bedside cribs 2026" />

  {/* 5. Detaljerad genomgång (auto-TOC byggs in i .mp-prose) */}
  <div class="mp-prose">

    <h2 class="font-heading text-2xl font-bold text-primary mt-8 mb-6">1. Maxi-Cosi Tori Beyond Bedside Crib, bäst totalt</h2>
    <MoneyProductCard
      brand="Maxi-Cosi"
