const featureLabels = ['Höjdjustering', 'Sidopanel', 'Mått (insida)', 'Åldersgrupp', 'Pris'];

const faqItems = [
  {
    question: 'Vad är en bedside crib?',
    answer: 'En bedside crib (även kallad sidovagga) är en liten säng som fästs eller ställs intill föräldrasängen med en sida öppen eller fällbar. Bebisen sover i sin egen säkra yta men nära föräldrarna. Det gör nattamning enklare och minskar risken för SIDS jämfört med samsovning i vuxensängen.',
  },
  {
    question: 'Är bedside crib säkrare än att ha bebisen i vuxensängen?',
    answer: 'Ja. Socialstyrelsen och Folkhälsomyndigheten avråder generellt från samsovning i vuxensängen under barnets första levnadsmånader på grund av kvävningsrisk. En bedside crib ger bebisen sin egen fasta och säkra sovyta med rätt madrass och utan lösa sängkläder, samtidigt som närheten bevaras för amning och trygghet.',
  },
  {
    question: 'Hur länge kan bebisen sova i en bedside crib?',
    answer: 'De flesta bedside cribs passar bebisen fram till ungefär 6 månaders ålder, när barnet börjar rulla och försöka resa sig. Kontrollera alltid tillverkarens viktgräns och åldersrekommendation för din modell — Joie Roomie och Shnuggle Air anger båda upp till 6 månader eller tills barnet kan resa sig på knäna.',
  },
  {
    question: 'Kan alla sängar använda en bedside crib?',
    answer: 'De flesta bedside cribs fungerar med standardsängar och är höjdjusterbara för att matcha olika sänghöjder. Modellerna i denna guide passar madrasshöjder mellan ca 25 och 60 cm. Mät alltid sänghöjden (topp på madrass till golv) innan köp och jämför med tillverkarens specifikationer.',
  },
  {
    question: 'Vad är skillnaden på en bedside crib och en vagga?',
    answer: 'En vagga är en fristående liten säng, ofta med gungfunktion, som inte ansluts till föräldrasängen. En bedside crib fästs mot föräldrasängen med en sida öppen så att föräldern enkelt kan nå bebisen utan att resa sig. För nattamning är bedside crib praktiskare; för rörlighet i hemmet kan en vagga vara bättre.',
  },
  {
    question: 'Behövs speciella lakan till en bedside crib?',
    answer: 'Ja, bedside cribs har vanligtvis mått som skiljer sig från vanliga spjälsängar. De flesta tillverkare säljer passande lakan separat. Köp alltid lakan som är gjorda för din specifika modell — ett lakan som inte sitter tight mot madrassen är en kvävningsrisk.',
  },
  {
    question: 'Kan jag använda bedside crib som resesäng?',
    answer: 'En bedside crib är inte en fullvärdig resesäng — de flesta modeller går att fälla men är skrymmande att transportera. Om du reser ofta kan det vara värt att komplettera med en separat resesäng. Joie har en Roomie Glide-modell som kombinerar bedside crib och resesäng om du vill ha en lösning som fungerar åt båda hållen.',
  },
  {
    question: 'Vad kostar en bedside crib?',
