      imageAlt="Joie Roomie Bedside Crib sidovagga"
      store="Jollyroom"
      buyUrl={joieRoomieUrl}
      pros={['Tydligt lägst pris bland riktiga bedside cribs', '5 höjdpositioner', 'Lutningsfunktion (vid t.ex. förkylning)', 'Enkel snabbmontering']}
