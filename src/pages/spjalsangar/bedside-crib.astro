    <MoneyProductCard
      brand="Snüz"
      name="Snüz SnuzPod Studio Bedside Crib"
      rating={4.5}
      rank={2}
      badge="Bäst ventilation"
      accentColor="#0d9488" bgColor="#1a365d"
