      rating={4.7}
      rank={4}
      badge="Bäst design"
      accentColor="#2563eb" bgColor="#1e3a8a"
      imageUrl="/images/products/leander-luna-omvandlingsbar-spjalsang.webp"
      imageAlt="Leander Luna omvandlingsbar spjälsäng"
      pros={['FSC-certifierad massiv bok', 'Ren modern skandinavisk design', 'Omvandlas till juniorsäng upp till 7 år', 'Högt andrahandsvärde']}
