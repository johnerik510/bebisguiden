    </p>
    <MoneyCTABox store="Jollyroom" affiliateUrl="https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=10224822&url=https://www.jollyroom.se/barnrummet/barnsangar-tillbehor/spjalsangar/stokke-sleepi-sang-v3-vit" />

    <h2 class="font-heading text-2xl font-bold text-primary mt-8 mb-6">2. Leander Classic Spjälsäng, bäst design</h2>
    <MoneyProductCard
      brand="Leander"
      name="Leander Classic Spjälsäng Natural"
      rating={4.7}
      rank={2}
      badge="Bäst design"
      accentColor="#0d9488" bgColor="#1a365d"
      imageUrl="/images/products/leander-classic-spjalsang-natural.webp"
      imageAlt="Leander Classic Spjälsäng Natural omvandlingsbar spjälsäng"
      store="Jollyroom"
      buyUrl="https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=910437&url=https://www.jollyroom.se/barnrummet/barnsangar-tillbehor/spjalsangar/leander-classic-baby-cot-wood"
