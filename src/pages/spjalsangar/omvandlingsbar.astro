  </div>

  {/* 5. Detaljerad genomgång (auto-TOC byggs in i .mp-prose) */}
  <div class="mp-prose">

    <h2 class="font-heading text-2xl font-bold text-primary mt-8 mb-6">1. Stokke Sleepi V3 Natural, bäst i test</h2>
    <MoneyProductCard
      brand="Stokke"
      name="Stokke Sleepi V3 Natural"
      rating={4.9}
      rank={1}
      badge="Bäst i test"
      accentColor="#b34558" bgColor="#4a5568"
      imageUrl="/images/products/stokke-sleepi-v3-natural.webp"
      imageAlt="Stokke Sleepi V3 Natural omvandlingsbar spjälsäng"
      store="Jollyroom"
