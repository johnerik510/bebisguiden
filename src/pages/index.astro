---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import { currentMonthYear } from '../utils/currentDate';

const now = new Date();
const monthNum = String(now.getMonth() + 1).padStart(2, '0');
const monthYear = currentMonthYear();
const monthYearCap = monthYear.charAt(0).toUpperCase() + monthYear.slice(1);

const granskningsomraden = [
 {
 href: '/bilbarnstolar/',
 name: 'Bilbarnstolar',
 ctaLabel: 'bilbarnstolarna',
 img: '/images/cat-bilbarnstol.webp',
 lede: 'Vi läser Folksams och ADAC:s senaste krocktester, kontrollerar i-Size och ECE R44, och testar installation i verkliga bilar innan vi rankar.',
 meta: 'Folksam · ADAC · i-Size R129',
 },
 {
 href: '/barnvagnar/',
 name: 'Barnvagnar',
 ctaLabel: 'barnvagnarna',
 img: '/images/cat-barnvagn.webp',
 lede: 'Duovagnar, sittvagnar, jogging- och lättviktsvagnar, vi går igenom hantering, komfort, fällmekanism och hållbarhet över flera månaders bruk.',
 meta: '4+ veckors praktiskt test per modell',
 },
 {
 href: '/babyvakter/',
