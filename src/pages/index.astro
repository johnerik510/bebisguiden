---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';

const topprodukter = [
  {
    name: 'Britax Römer Dualfix 5Z i-Size',
    badge: 'Bäst i test — bilbarnstolar',
    price: '4 990 kr',
    rating: 4.8,
    ageRange: '0–4 år (40–105 cm)',
    pros: ['Toppbetyg i ADAC-krocktest', '360-graders rotation', 'ISOFIX + stödben'],
    cons: ['Tung (14,8 kg)'],
    ctaText: 'Se pris hos Reirei',
    ctaHref: 'https://www.jollyroom.se/amning/brostpumpar/bilbarnstolar-c-3%2F',
    image: '/images/britax-romer-dualfix-5z.jpg',
  },
  {
    name: 'Cybex Melio Carbon',
    badge: 'Bäst i test — barnvagnar',
    price: '9 990 kr',
    rating: 4.7,
    pros: ['Ultralätt (5,9 kg)', 'Carbon-ram', 'Vändbar liggdel'],
    cons: ['Högt pris'],
    ctaText: 'Jämför barnvagnar',
    ctaHref: 'https://www.jollyroom.se/barnvagnar/',
    image: '/images/cybex-melio-carbon.jpg',
  },
  {
    name: 'Philips Avent SCD843',
    badge: 'Bäst i test — babyvakter',
    price: '1 299 kr',
    rating: 4.5,
    pros: ['Rörelsedetektor', 'Nattljus inbyggt', 'Räckvidd 300 m'],
    cons: ['Ingen app-koppling'],
    ctaText: 'Se pris hos Reirei',
    ctaHref: 'https://www.jollyroom.se/amning/brostpumpar/',
    image: '/images/philips-avent-scd843.jpg',
  },
];
---

<BaseLayout
  title="Bebisguiden.se — Bästa barnprodukter i test 2026"
  description="Oberoende tester av bilbarnstolar, barnvagnar, babyvakter och mer. Vi jämför och rankar barnprodukter sa att du väljer säkert och smart 2026."
>
  <!-- Hero -->
  <section class="text-white relative overflow-hidden min-h-[380px] sm:min-h-[440px] md:min-h-[500px] flex flex-col justify-center">
    <img
      src="/images/hero-bebis.webp"
      alt="Förälder med nyfödd bebis"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary/50"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12 relative w-full">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-3 py-1 text-xs font-semibold text-white/80 uppercase tracking-wide mb-4">
          <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
          Oberoende guide 2026
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold leading-tight mb-4">
          Oberoende tester<br>av barnprodukter
        </h1>
        <p class="text-white/80 text-lg max-w-lg mb-8">
          Vi granskar bilbarnstolar, barnvagnar, babyvakter och mer — så du väljer säkert och smart för ditt barn.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <a href="/bilbarnstolar/" class="inline-flex items-center justify-center bg-accent hover:opacity-90 text-white font-bold py-4 px-8 rounded-xl transition-opacity text-base shadow-lg">
            Se alla tester
          </a>
          <a href="/barnvagnar/" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-semibold py-4 px-8 rounded-xl transition-colors text-base border border-white/25">
            Barnvagnar
          </a>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/60 font-medium">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            100+ produkter testade
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Oberoende recensioner
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Uppdaterat 2026
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Topprodukter — synliga direkt -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-heading text-2xl font-bold text-text">Bäst i test 2026</h2>
        <p class="text-text-light text-sm mt-1">Tre kategorier — en testvinnare per kategori</p>
      </div>
    </div>
    <div class="space-y-4">
      {topprodukter.map((p) => (
        <ProductCard {...p} />
      ))}
    </div>
  </section>

  <!-- Category cards -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">

      <a href="/bilbarnstolar/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-bilbarnstol.webp?v=3" alt="Bilbarnstolar" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Bilbarnstolar</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Krocktestade och rankade.</p>
        </div>
      </a>

      <a href="/barnvagnar/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-barnvagn.webp?v=3" alt="Barnvagnar" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Barnvagnar</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Duovagnar, sittvagnar och syskonvagnar.</p>
        </div>
      </a>

      <a href="/babyvakter/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-babyvakt.webp?v=3" alt="Babyvakter" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Babyvakter</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Ljud, video och WiFi jämförda.</p>
        </div>
      </a>

      <a href="/barselen/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-barsele.webp?v=3" alt="Bärselen" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Bärselen</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Ergonomi och komfort testat.</p>
        </div>
      </a>

      <a href="/matstolar/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-matstol.webp?v=3" alt="Matstolar" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Matstolar</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Tripp Trapp, Antilop och BabyBjörn.</p>
        </div>
      </a>

      <a href="/spjalsangar/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-spjalsang.webp?v=3" alt="Spjälsängar" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Spjälsängar</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Standard, bedside crib och resesäng.</p>
        </div>
      </a>

      <a href="/babyklader/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-babyklader.webp?v=3" alt="Babykläder" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Babykläder</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">GOTS, OEKO-TEX och rätt storlek.</p>
        </div>
      </a>

      <a href="/sovsackar/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-sovsack.webp?v=3" alt="Sovsäckar bebis" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Sovsäckar bebis</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Voksi, HALO och Leander.</p>
        </div>
      </a>

      <a href="/amning/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-amning.webp?v=3" alt="Amning och matning" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Amning & matning</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Bröstpumpar, kuddar och nappflaskor.</p>
        </div>
      </a>

      <a href="/badkar/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-badkar.webp?v=3" alt="Badkar bebis" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Badkar bebis</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Med termometer, hopfällbara och badstöd.</p>
        </div>
      </a>

      <a href="/sterilisatorer/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-sterilisator.webp?v=3" alt="Sterilisatorer" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Sterilisatorer</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Philips Avent, Tommee Tippee och NUK.</p>
        </div>
      </a>

      <a href="/blojor/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-bloja.webp?v=3" alt="Blöjor" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Blöjor</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Engångsblöjor och tygblöjor testade.</p>
        </div>
      </a>

      <a href="/leksaker/" class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all group">
        <div class="relative h-36 sm:h-40 overflow-hidden">
          <img src="/images/cat-leksaker.webp?v=3" alt="Leksaker 0-12 mån" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
        <div class="p-3 sm:p-4">
          <h2 class="font-heading text-sm sm:text-base font-bold text-text group-hover:text-accent transition-colors">Leksaker 0-12 mån</h2>
          <p class="text-xs sm:text-sm text-text-light mt-0.5">Babygym, skallror och stimulerande leksaker.</p>
        </div>
      </a>

    </div>
  </section>

  <!-- Trust signals -->
  <section class="bg-bg-alt py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div>
          <p class="font-heading text-2xl font-bold text-accent">100+</p>
          <p class="text-sm text-text-light mt-1">Produkter testade</p>
        </div>
        <div>
          <p class="font-heading text-2xl font-bold text-accent">100%</p>
          <p class="text-sm text-text-light mt-1">Oberoende recensioner</p>
        </div>
        <div>
          <p class="font-heading text-2xl font-bold text-accent">2026</p>
          <p class="text-sm text-text-light mt-1">Uppdaterat innehåll</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About section for E-E-A-T -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="font-heading text-xl font-bold mb-4">Därför Bebisguiden</h2>
    <div class="prose prose-sm text-text-light max-w-none">
      <p>Att välja rätt barnprodukt är ett av de viktigaste besluten du fattar som föräldrar. Vi på Bebisguiden granskar varje produkt noggrant — från Folksams krocktester till faktisk användarvänlighet i vardagen.</p>
      <p>Alla våra tester är oberoende. Vi tjänar pengar genom affiliatelänkar, men det påverkar aldrig våra betyg eller rekommendationer. Vi rekommenderar bara produkter vi själva skulle välja för våra barn.</p>
    </div>
  </section>
</BaseLayout>
