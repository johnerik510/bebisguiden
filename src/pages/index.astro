 },
 {
 href: '/barselen/',
 name: 'Bärselen',
 ctaLabel: 'bärselarna',
 img: '/images/cat-barsele.webp',
 lede: 'Ergonomiska höftpositioner, material och värmereglering testas mot Hip Dysplasia Institutes rekommendationer och barnläkarpraxis.',
 meta: 'Ergonomi och höftutveckling',
 },
 {
 href: '/matstolar/',
