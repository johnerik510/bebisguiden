---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';

const topprodukter = [
  {
    name: 'Britax Römer Dualfix 5Z i-Size',
    badge: 'Bäst i test — bilbarnstolar',
    price: '4 990 kr',
    rating: 4.8,
    ageRange: '0–4 år (40–105 cm)',
    pros: ['Toppbetyg i ADAC-krocktest', '360-graders rotation', 'ISOFIX + stödben'],
    cons: ['Tung (14,8 kg)'],
    ctaText: 'Se pris hos Jollyroom',
    ctaHref: 'https://www.jollyroom.se/bilstolar/bilbarnstolar/bakatvanda/britax-romer-dualfix-5z-bilbarnstol-harbor-blue',
    image: '/images/britax-romer-dualfix-5z.jpg',
  },
  {
    name: 'Cybex Melio Carbon',
    badge: 'Bäst i test — barnvagnar',
    price: '9 990 kr',
    rating: 4.7,
    pros: ['Ultralätt (5,9 kg)', 'Carbon-ram', 'Vändbar liggdel'],
    cons: ['Högt pris'],
    ctaText: 'Se pris hos Jollyroom',
    ctaHref: 'https://www.jollyroom.se/barnvagnar/sittvagnar/cybex-melio-carbon-barnvagn-moon-black',
    image: '/images/cybex-melio-carbon.jpg',
  },
  {
    name: 'Philips Avent SCD843',
    badge: 'Bäst i test — babyvakter',
    price: '1 299 kr',
    rating: 4.5,
    pros: ['Rörelsedetektor', 'Nattljus inbyggt', 'Räckvidd 300 m'],
    cons: ['Ingen app-koppling'],
    ctaText: 'Se pris hos Jollyroom',
    ctaHref: 'https://www.jollyroom.se/babyvakter/philips-avent-scd843-26-avancerad-babyvakt',
    image: '/images/philips-avent-scd843.jpg',
  },
];
---

<BaseLayout
  title="Bebisguiden.se – Oberoende tester av barnprodukter 2026"
  description="Oberoende tester och jämförelser av bilbarnstolar, barnvagnar, babyvakter och mer. Vi hjälper dig välja ratt och säkert för ditt barn."
>
  <!-- Hero: compact, products visible above fold -->
  <section class="bg-primary text-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold">Oberoende tester av barnprodukter</h1>
      <p class="mt-2 text-gray-300 text-base sm:text-lg max-w-2xl">Vi granskar bilbarnstolar, barnvagnar, babyvakter och mer — så du väljer säkert och smart för ditt barn.</p>
    </div>
  </section>

  <!-- Topprodukter — synliga direkt -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-heading text-2xl font-bold text-text">Bäst i test 2026</h2>
        <p class="text-text-light text-sm mt-1">Tre kategorier — en testvinnare per kategori</p>
      </div>
    </div>
    <div class="space-y-4">
      {topprodukter.map((p) => (
        <ProductCard {...p} />
      ))}
    </div>
  </section>

  <!-- Category cards -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/bilbarnstolar/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Bilbarnstolar</h2>
        <p class="text-sm text-text-light mt-1">Krocktestade och rankade. Hitta säkraste stolen för ditt barn.</p>
      </a>

      <a href="/barnvagnar/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Barnvagnar</h2>
        <p class="text-sm text-text-light mt-1">Duovagnar, sittvagnar och syskonvagnar -- jämförda och testade.</p>
      </a>

      <a href="/babyvakter/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Babyvakter</h2>
        <p class="text-sm text-text-light mt-1">Ljud, video och WiFi -- vi jämför funktioner och räckvidd.</p>
      </a>

      <a href="/barselen/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Bärselen</h2>
        <p class="text-sm text-text-light mt-1">För nyfödda och större barn. Ergonomi och komfort testat.</p>
      </a>

      <a href="/matstolar/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Matstolar</h2>
        <p class="text-sm text-text-light mt-1">Tripp Trapp, Antilop och BabyBjörn jämförda. Från 249 kr.</p>
      </a>

      <a href="/spjalsangar/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM4 9h16v6H4V9z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Spjälsängar</h2>
        <p class="text-sm text-text-light mt-1">Standard, bedside crib och resesäng -- jämförda och testade.</p>
      </a>

      <a href="/babyklader/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Babykläder</h2>
        <p class="text-sm text-text-light mt-1">GOTS, OEKO-TEX och rätt storlek – guide till nyfödds garderob.</p>
      </a>

      <a href="/sterilisatorer/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Sterilisatorer</h2>
        <p class="text-sm text-text-light mt-1">Philips Avent, Tommee Tippee och NUK jämförda – elektrisk ånga och mikrovåg.</p>
      </a>

      <a href="/sovsackar/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Sovsäckar bebis</h2>
        <p class="text-sm text-text-light mt-1">Voksi, HALO och Leander jämförda – TOG-guide ingår.</p>
      </a>

      <a href="/amning/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Amning & matning</h2>
        <p class="text-sm text-text-light mt-1">Bröstpumpar, amningskuddar och nappflaskor testade och jämförda.</p>
      </a>

      <a href="/blojor/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Blöjor</h2>
        <p class="text-sm text-text-light mt-1">Engångsblöjor och tygblöjor testade -- hitta rätt blöja för din bebis.</p>
      </a>

      <a href="/badkar/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 6h18M3 14h18M3 18h18"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Badkar bebis</h2>
        <p class="text-sm text-text-light mt-1">Babybadkar med termometer, hopfällbara och badstöd jämförda.</p>
      </a>

      <a href="/leksaker/" class="bg-white rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:border-accent transition-all group">
        <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">Leksaker 0-12 mån</h2>
        <p class="text-sm text-text-light mt-1">Babygym, skallror och stimulerande leksaker for de minsta.</p>
      </a>
    </div>
  </section>

  <!-- Trust signals -->
  <section class="bg-bg-alt py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div>
          <p class="font-heading text-2xl font-bold text-accent">100+</p>
          <p class="text-sm text-text-light mt-1">Produkter testade</p>
        </div>
        <div>
          <p class="font-heading text-2xl font-bold text-accent">100%</p>
          <p class="text-sm text-text-light mt-1">Oberoende recensioner</p>
        </div>
        <div>
          <p class="font-heading text-2xl font-bold text-accent">2026</p>
          <p class="text-sm text-text-light mt-1">Uppdaterat innehåll</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About section for E-E-A-T -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="font-heading text-xl font-bold mb-4">Därför Bebisguiden</h2>
    <div class="prose prose-sm text-text-light max-w-none">
      <p>Att välja rätt barnprodukt är ett av de viktigaste besluten du fattar som föräldrar. Vi på Bebisguiden granskar varje produkt noggrant -- från Folksams krocktester till faktisk användarvanlighet i vardagen.</p>
      <p>Alla våra tester är oberoende. Vi tjänar pengar genom affiliatelänkar, men det påverkar aldrig våra betyg eller rekommendationer. Vi rekommenderar bara produkter vi själva skulle välja for våra barn.</p>
    </div>
  </section>
</BaseLayout>
