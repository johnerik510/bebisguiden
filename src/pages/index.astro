 },
 {
 href: '/sakerhet/babygrindar/',
 name: 'Babygrindar',
 ctaLabel: 'babygrindar',
 img: '/images/cat-babygrindar.webp',
 lede: 'Skruvgrindar för trappor och spänngrindar för dörröppningar testas på installationssäkerhet, material och bredd. Vi rekommenderar bara grindar som uppfyller EN 1930.',
 meta: 'EN 1930 · trapp · utan borrning',
 },
];

const guidehubbar = [
 { name: 'Hälsa & symptom', href: '/guider/halsa-och-symptom/', desc: 'Feber, kolik, magont, utslag, när du ska vara orolig och när det är normalt.', anchor: 'Läs guider om barns hälsa', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
 { name: 'Sömn', href: '/guider/somn/', desc: 'Säker sovmiljö enligt barnläkarpraxis, sovrutiner och regression.', anchor: 'Läs guider om bebissömn', icon: 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z' },
 { name: 'Mat & amning', href: '/guider/mat-och-amning/', desc: 'Amning, fast föda, BLW och introduktion av allergener.', anchor: 'Läs guider om amning och mat', icon: 'M12 2v20M6 8c0-2.21 1.79-4 4-4h4c2.21 0 4 1.79 4 4v12H6V8z' },
 { name: 'Utrustning', href: '/guider/utrustning/', desc: 'Vad du faktiskt behöver, och vad du kan hoppa över.', anchor: 'Läs guider om babyutrustning', icon: 'M5 13l4 4L19 7' },
 { name: 'Förberedelser', href: '/guider/forberedelser/', desc: 'Checklistor inför förlossningen, packlista och graviditetsveckor.', anchor: 'Läs guider om förberedelser', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
];

const categoryFallbackImages: Record<string, string> = {
 'Bilbarnstolar': '/images/cat-bilbarnstol.webp',
 'Barnvagnar': '/images/cat-barnvagn.webp',
 'Babyvakter': '/images/cat-babyvakt.webp',
 'Bärselen': '/images/cat-barsele.webp',
 'Matstolar': '/images/cat-matstol.webp',
 'Spjälsängar': '/images/cat-spjalsang.webp',
 'Sovsäckar': '/images/cat-sovsack.webp',
 'Amning': '/images/cat-amning.webp',
 'Blöjor': '/images/cat-bloja.webp',
 'Babykläder': '/images/cat-babyklader.webp',
 'Badkar': '/images/cat-badkar.webp',
 'Leksaker': '/images/cat-leksaker.webp',
 'Sterilisatorer': '/images/cat-sterilisator.webp',
 'Babysitter': '/images/cat-babysitter.webp',
 'Lära-gå-stolar': '/images/cat-lara-ga-stol.webp',
 'Babygrindar': '/images/cat-babygrindar.webp',
 'Guider': '/images/hero-bebis.webp',
}

const allMods = import.meta.glob('./**/*.astro', { eager: true })
type ArtMeta = { title: string; description: string; publishDate: string; category: string; image: string }
const senasteNyheter = Object.entries(allMods)
  .filter(([path, mod]) => path !== './index.astro' && !path.endsWith('/index.astro') && !!(mod as any).articleMeta)
.map(([path, mod]) => {
 const meta = (mod as any).articleMeta as ArtMeta
 const href = '/' + path.replace(/^\.\//, '').replace(/\.astro$/, '/')
 const image = meta.image || categoryFallbackImages[meta.category] || '/images/hero-bebis.webp'
 return {...meta, image, href }
 })
.sort((a, b) => b.publishDate.localeCompare(a.publishDate))
.slice(0, 6)

function fmtDate(d: string) {
 return new Date(d + 'T12:00:00').toLocaleDateString('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' })
}

const homeFaqItems = [
 {
  question: 'Vad behöver man till bebis?',
  answer: 'Det absolut nödvändiga är: en i-Size-godkänd bilbarnstol (lagkrav för transport från sjukhuset), en trygg sovplats (spjälsäng eller bedside crib) och en barnvagn. Utöver det är bröstpump, nappflaskor och blöjor praktiska att ha hemma i förväg. Leksaker, babysitter och aktivitetscenter kan vänta tills du ser vad barnet faktiskt behöver. Undvik att köpa för mycket innan födseln, de flesta nyfödda har väldigt enkla behov de första veckorna.',
 },
 {
  question: 'Vilken barnvagn är bäst 2026?',
  answer: 'Cybex Priam är bäst i test 2026 med fullfjädrat chassi och vändbar sittdel, bra för längre promenader på ojämnt underlag. Cybex EOS Lux är bäst pris/kvalitet i mellansegmentet (runt 7 000 kr) och lättviktigare för stadsliv. Kinderkraft MOOV 2 är budgetvinnaren under 4 000 kr. Välj duovagn (med liggdel) om du vill ha en vagn som räcker från nyfödd, annars klarar sig en sittvagn om barnet är minst 6 månader.',
 },
 {
  question: 'Vilken bilbarnstol är säkrast?',
  answer: 'Britax Römer Dualfix 5Z toppade ADAC:s krocktest 2024 och är säkrast totalt med bakåtvänt till 105 cm och 360-graders rotation. Cybex Sirona T är premiumvalet med magnetiskt bälteslås och Linear Side-impact Protection. Alla moderna bilbarnstolar ska uppfylla i-Size R129, den strängaste europeiska standarden, som kräver obligatorisk sidokrocktestning och bakåtvänt minst till 15 månader. Undvik alltid begagnade bilbarnstolar, en osynlig spricka kan innebära att skyddet uteblir vid krock.',
 },
 {
  question: 'Hur länge ska bebis sova i föräldrarnas rum?',
  answer: 'Socialstyrelsen och WHO rekommenderar att bebisen sover i samma rum som föräldrarna men i egen säng de första sex månaderna, helst upp till ett år. Det minskar risken för plötslig spädbarnsdöd (SIDS) med upp till 50 procent. En bedside crib som fästs vid sängen är ett praktiskt kompromiss som gör nattkoll och amning enklare utan att dela säng. Bebisen ska alltid sova på rygg, på fast och plan madrass utan kuddar eller lösa täcken.',
 },
 {
  question: 'Vilken blöja är bäst för nyfödda?',
  answer: 'Pampers New Baby Stl 1 (2 till 5 kg) är bäst för nyfödda tack vare navelurringningen som skyddar det ömma navelsträngsomfånget. Kit & Kin Eco är bäst för känslig hud och ekologiska familjer, fri från klor och parfym. Pampers Premium Protection är starkast på läckageskydd och passar bra från 3 till 4 kg och uppåt. En nyfödd byter blöja 8 till 12 gånger per dygn, köp inte för stora lager i en enda storlek, barnet växer snabbt.',
 },
 {
  question: 'Vilken babyvakt ska man ha?',
  answer: 'Det beror på om du vill ha en lokal DECT-monitor eller en WiFi-kamera du kan kolla via telefon. DECT-monitorer (Philips Avent, Motorola) är enklare, kräver ingen internetuppkoppling och anses av många som säkrare ur integritetssynpunkt. WiFi-kameror (Arlo, Nanit) ger mer funktioner men är beroende av internetuppkoppling och app. Väljer du WiFi, kontrollera alltid att kameran har kryptering och tvåfaktorsautentisering. En babyvakt med temperaturlarm är extra praktiskt under vintermånaderna.',
 },
 {
  question: 'Vad kostar babyutrustning totalt?',
  answer: 'En rimlig totalbudget för det nödvändiga är 15 000 till 30 000 kr: barnvagn (3 000 till 12 000 kr), bilbarnstol (3 000 till 8 000 kr), spjälsäng inklusive madrass (2 000 till 5 000 kr) och övrig utrustning. Väljer du begagnat på barnvagn och spjälsäng och nytt på bilbarnstol och madrass kan du komma ner mot 10 000 kr. Premiumalternativ med helt ny utrustning kan kosta 40 000 till 60 000 kr. Prioritera säkerhet framför pris på bilbarnstol och sovmiljö.',
 },
 {
  question: 'Kan man köpa babyutrustning begagnat?',
  answer: 'Ja, men det finns viktiga undantag. Köp aldrig begagnad bilbarnstol om du inte känner ägaren personligen och vet att den aldrig varit med i krock. Köp aldrig begagnad madrass till spjälsäng av hygienskäl, risken för SIDS ökar med använda madrasser från okänd källa. Barnvagnar, spjälsängar, matstolar och kläder kan köpas begagnat utan problem, de håller generellt länge. Blocket, Facebook Marketplace och Tradera har bra utbud av barnvagnar i bra skick.',
 },
];

---

<BaseLayout
 title="Bebisguiden 2026: bäst i test barnvagn, bilbarnstol, blöjor"
 description="Bebisguiden rankar bästa barnvagnen, bilbarnstolen, blöjorna, bedside crib och bröstpumpen 2026. Krocktester, ADAC, Folksam och i-Size R129 i botten."
>
 <link slot="head" rel="preload" as="image" href="/images/hero-bebis.webp" type="image/webp" />

 <!-- Hero -->
 <section class="text-white relative overflow-hidden min-h-[380px] md:min-h-[440px] flex flex-col">
 <img
 src="/images/hero-bebis.webp"
 alt="Förälder med nyfödd bebis"
 width="1920"
 height="1280"
 class="absolute inset-0 w-full h-full object-cover -z-10"
 loading="eager"
 fetchpriority="high"
 />
 <!-- Layered cinematic gradients för djup -->
 <div class="absolute inset-0 bg-gradient-to-br from-[#3d0a1f] via-primary/90 to-primary/40 -z-10" aria-hidden="true"></div>
 <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-black/30 -z-10" aria-hidden="true"></div>
 <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(255,255,255,0.12),transparent_55%)] -z-10" aria-hidden="true"></div>
 <div class="absolute inset-0 opacity-[0.12] mix-blend-overlay -z-10" aria-hidden="true" style="background-image: radial-gradient(circle at 1px 1px, white 0.8px, transparent 0); background-size: 3px 3px;"></div>
 <!-- Glödande accent-orb -->
 <div class="absolute -top-20 -right-20 w-[520px] h-[520px] rounded-full bg-accent/20 blur-[140px] -z-10" aria-hidden="true"></div>
 <div class="absolute -bottom-40 left-1/4 w-[420px] h-[420px] rounded-full bg-primary-dark/40 blur-[120px] -z-10" aria-hidden="true"></div>

 <!-- Editorial masthead (topp) -->
 <div class="relative border-b border-white/10">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between text-[11px] font-semibold uppercase tracking-[0.22em] text-white/75">
 <div class="flex items-center gap-5">
 <span class="inline-flex items-center gap-2">
 <span class="italic font-normal normal-case tracking-normal text-sm text-white/90" style="font-family: Georgia, 'Times New Roman', serif;">Nº</span>
 <span class="text-white/90">{monthNum} / {monthYearCap}</span>
 </span>
 <span class="hidden md:inline-block w-8 h-px bg-accent/60"></span>
 <span class="hidden md:inline text-white/60">Oberoende redaktion</span>
 </div>
 <div class="flex items-center gap-5">
 <span class="hidden sm:inline text-white/60">Uppdaterad {monthYearCap}</span>
 <span class="hidden sm:inline-block w-8 h-px bg-accent/60"></span>
 <span class="flex items-center gap-2">
 <span class="relative flex h-1.5 w-1.5">
 <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
 <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent"></span>
 </span>
 Live
 </span>
 </div>
 </div>
 </div>

 <!-- Huvudinnehåll -->
 <div class="flex-1 flex items-center">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10 relative w-full">
 <!-- Stor signaturstämpel bakom allt -->
 <div class="absolute -top-10 right-0 lg:right-8 text-[280px] lg:text-[380px] font-heading font-black text-white/[0.03] leading-none select-none pointer-events-none" aria-hidden="true" style="font-family: Georgia, 'Times New Roman', serif;">B</div>

 <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center relative">
 <!-- Vänstersida: rubrik + text + CTA -->
 <div class="lg:col-span-12 relative">
 <!-- Liten pre-kicker med serif -->
 <div class="flex items-center gap-3 mb-6">
 <span class="w-12 h-px bg-rose-300"></span>
 <span class="text-[11px] font-bold uppercase tracking-[0.28em] text-rose-200">Bebisguiden</span>
 <span class="italic text-sm text-white/60" style="font-family: Georgia, 'Times New Roman', serif;">est. 2026</span>
 </div>

 <!-- H1: SEO-optimerad mot top GSC-queries -->
 <h1 class="font-heading text-3xl sm:text-4xl lg:text-[3.25rem] font-bold leading-[1.05] mb-4 tracking-[-0.02em]">
 Barnvagn, bilbarnstol och blöjor <span class="relative inline-block">
 <span class="relative z-10 italic" style="font-family: Georgia, 'Times New Roman', serif; font-weight: 500;">bäst i test</span>
 <svg class="absolute -bottom-3 left-0 w-full z-0 text-accent" aria-hidden="true" viewBox="0 0 300 12" preserveAspectRatio="none">
 <path d="M2 8 Q 75 2, 150 6 T 298 5" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" fill="none"/>
 </svg>
 </span> <span class="text-white/55 font-normal">2026</span>
 </h1>

 <!-- Brodtext: SEO-fokus -->
 <p class="text-base sm:text-lg text-white/85 leading-relaxed mb-8 max-w-xl">
 Oberoende test av bästa barnvagnen, bilbarnstolen, blöjorna, bedside crib och bröstpumpen 2026. Vi läser krocktester från Folksam och ADAC, följer i-Size R129 och testar varje produkt i svenska hem <span class="italic text-white/70" style="font-family: Georgia, 'Times New Roman', serif;">så du slipper lägga kvällarna i forumtrådar.</span>
 </p>

 <!-- CTA-knappar -->
 <div class="flex flex-wrap gap-3">
 <a href="/bilbarnstolar/" class="group inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-semibold px-6 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30 hover:shadow-xl hover:shadow-accent/40 hover:-translate-y-0.5">
 Se bästa bilbarnstolarna
 <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
 </a>
 <a href="/barnvagnar/" class="inline-flex items-center gap-2 bg-white/[0.08] hover:bg-white/[0.15] backdrop-blur-sm border border-white/20 text-white font-semibold px-6 py-3.5 rounded-xl transition-all">
 Bästa barnvagnarna
 </a>
 </div>

 </div>

 </div>
 </div>
 </div>

 <!-- Scroll-indikator & källor-ribbon -->
 <div class="relative border-t border-white/10 bg-black/20 backdrop-blur-sm">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between text-[11px] font-semibold uppercase tracking-[0.22em] text-white/60">
 <span class="inline-flex items-center gap-2.5">
 <svg class="w-3.5 h-3.5 animate-bounce text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
 <span class="hidden sm:inline">Scrolla för att läsa</span>
 </span>
 <span class="flex items-center gap-2.5 sm:gap-4">
 <span class="italic normal-case tracking-normal text-white/50 text-xs hidden md:inline" style="font-family: Georgia, serif;">Vi bygger på:</span>
 <span class="text-white/70">Folksam</span>
 <span class="text-accent/60">·</span>
 <span class="text-white/70">ADAC</span>
 <span class="text-accent/60 hidden sm:inline">·</span>
 <span class="text-white/70 hidden sm:inline">Stiftung Warentest</span>
 <span class="text-accent/60 hidden md:inline">·</span>
 <span class="text-white/70 hidden md:inline">i-Size R129</span>
 </span>
 </div>
 </div>
 </section>

 <!-- Granskningsområden -->
 <section class="py-8 sm:py-10 bg-white border-b border-border">
 <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
 <div class="mb-6">
 <div class="text-xs font-semibold text-accent uppercase tracking-[0.2em] mb-1.5">Våra granskningsområden</div>
 <h2 class="font-heading text-2xl sm:text-3xl font-bold text-primary leading-tight">Sexton kategorier, testade av barnmorska och barnsjuksköterska</h2>
 </div>
 <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
 {granskningsomraden.map((omr) => (
 <article class="flex flex-col rounded-2xl border border-border hover:border-accent hover:shadow-lg transition-all bg-white overflow-hidden">
 <a href={omr.href} tabindex="-1" aria-hidden="true" class="block relative aspect-[16/9] overflow-hidden bg-bg">
 <img
 src={omr.img}
 alt={`Testkategori: ${omr.name}`}
 class="absolute inset-0 w-full h-full object-cover hover:scale-105 transition-transform duration-500"
 loading="lazy"
 />
 <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
