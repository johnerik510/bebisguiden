 ctaLabel: 'matstolarna',
 img: '/images/cat-matstol.webp',
 lede: 'Växer stolen med barnet? Står den stadigt? Vi jämför Tripp Trapp, Antilop, BabyBjörn och fler, både på komfort och långsiktigt värde.',
 meta: 'Stabilitet, anpassning, livslängd',
 },
 {
 href: '/spjalsangar/',
