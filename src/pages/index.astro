 },
 {
 href: '/badkar/',
 name: 'Babybadkar',
 ctaLabel: 'babybadkaren',
 img: '/images/cat-badkar.webp',
 lede: 'Hopfällbara och stativsatta badkar jämförda. Stokke Flexi Bath, IKEA LATTSAM, Karibu och Fisher-Price testas på stabilitet, termosfunktion och hantering.',
 meta: 'Stabilitet · badstöd · hopfällbart',
 },
 {
 href: '/leksaker/',
 name: 'Leksaker',
