      ctaText="Se pris hos Babysam"
      ctaHref="https://to.babyworld.se/t/t?a=1945556823&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babysam.se%2Fsakerhet"
    />

    <ProductCard
      name="BabyDan Premier Spänngrind, Vit"
      badge="Bäst tryckmonterad"
      price="599 kr"
      rating={4.6}
      image="/images/products/babydan-premier-spanngrind.webp"
      pros={['Inga hål i väggen', 'Enkel att montera och flytta', 'Passar korridorer och dörröppningar', 'Kompletterbar med förlängningar']}
      cons={['Inte godkänd för trapptoppen', 'Kan klivas över av äldre barn', 'Kräver jämna väggar för bäst grepp']}
      ctaText="Se pris hos Babyland"
      ctaHref="https://pin.babyland.se/t/t?a=1066444612&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babyland.se%2F"
    />

    <ProductCard
      name="BabyDan Danamic Spänngrind, Vit"
      badge="Prisvärt val"
      price="589 kr"
      rating={4.5}
      image="/images/products/babydan-danamic-spanngrind.webp"
