      reviewCount: 1,
      offers: [{ price: 589, url: 'https://to.babyworld.se/t/t?a=1945556823&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babysam.se%2Fsakerhet', seller: 'Babysam' }],
