 <li><a href="/babyvakter/" class="text-accent underline font-medium">Bästa babyvakter 2026, video och ljud</a></li>
 </ul>
 </div>

 <RetailerCTAs />

 <FAQ items={faqItems} />

<script type="application/ld+json" set:html={JSON.stringify({
 "@context": "https://schema.org",
 "@type": "ItemList",
 "name": "Bästa sovpåse baby 2026",
 "itemListOrder": "https://schema.org/ItemListOrderDescending",
 "numberOfItems": products.length,
 "itemListElement": products.map((p, i) => ({
 "@type": "ListItem",
 "position": i + 1,
 "item": {
 "@type": "Product",
 "name": p.name,
 "description": `${p.name}, ${p.features?.Material || ''} sovpåse för baby. TOG ${p.features?.TOG || ''}.`,
 "image": p.image? `https://bebisguiden.se${p.image}`: "https://bebisguiden.se/og-default.webp",
 "brand": {
 "@type": "Brand",
 "name": p.name.split(' ')[0]
 },
 "review": {
 "@type": "Review",
 "reviewRating": { "@type": "Rating", "ratingValue": p.rating, "bestRating": 5 },
 "author": { "@type": "Organization", "name": "Bebisguiden" }
 },
 "aggregateRating": {
 "@type": "AggregateRating",
 "ratingValue": p.rating,
 "bestRating": 5,
 "worstRating": 1,
 "reviewCount": 1
 }
 }
 }))
})} />
