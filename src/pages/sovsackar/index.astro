<ProductSchema products={[
 { name: 'Voksi Nordic N1 Wool', description: 'Sovpåse i ull för bebis. Naturliga temperaturregulerande egenskaper, OEKO-TEX-certifierad.', image: 'https://bebisguiden.se/images/products/voksi-nordic-n1-wool.webp', brand: 'Voksi', ratingValue: 4.8, reviewCount: 1 },
 { name: 'HALO SleepSack Micro-Fleece', description: 'Populär sovpåse i mjuk fleece med omslutande design. Ersätter filt på ett säkert sätt.', image: 'https://bebisguiden.se/images/products/halo-sleepsack.webp', brand: 'HALO', ratingValue: 4.6, reviewCount: 1 },
 ]} />
</ArticleLayout>
