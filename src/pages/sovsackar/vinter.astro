---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Sovsackar', href: '/sovsackar/' },
  { label: 'Vintersovsack bebis' },
];

const products = [
  {
    name: 'Ergobaby On The Move Sovpåse 6-18M TOG 2.5, Sheep',
    badge: 'Bäst i test',
    price: '549 kr',
    rating: 4.8,
    image: '/images/products/ergobaby-sovpase-tog25.webp',
    ctaHref: 'https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fkollektioner%2Fsovsackar',
    features: {
      'TOG': '2.5',
      'Ålder': '6–18 månader',
      'Material': 'Polyester',
      'Öppning': 'Tvåvägsdragkedja',
      'Tvätt': '40°C maskin',
    },
  },
  {
    name: 'Little Dutch Sage Vinter Sovpåse 70 cm, Grön',
    badge: 'Bäst för nyfödda',
    price: '749 kr',
    rating: 4.7,
    image: '/images/products/little-dutch-vinter-sovpase.webp',
    ctaHref: 'https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fkollektioner%2Fsovsackar',
    features: {
      'TOG': '2.5',
      'Ålder': '0–12 månader',
      'Material': 'Bomull',
      'Öppning': 'Tvåvägsdragkedja',
      'Tvätt': '40°C maskin',
    },
  },
  {
    name: 'Ergobaby On The Move Sovpåse Vinter TOG 3.5',
    badge: 'För kalla sovrum',
    price: '599 kr',
    rating: 4.6,
    image: '/images/products/ergobaby-sovpase-tog25.webp',
    ctaHref: 'https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fkollektioner%2Fsovsackar',
    features: {
      'TOG': '3.5',
      'Ålder': '6–18 månader',
      'Material': 'Polyester',
      'Öppning': 'Tvåvägsdragkedja',
      'Tvätt': '40°C maskin',
    },
  },
];

const featureLabels = ['TOG', 'Ålder', 'Material', 'Öppning', 'Tvätt'];

const faqItems = [
  {
    question: 'Vilket TOG-värde ska man ha på vintern?',
    answer: 'TOG 2.5 rekommenderas vid rumstemperaturer 16–20°C och är det vanligaste valet för svenska vintrar med normalt uppvärmda sovrum. TOG 3.5 används vid rumstemperaturer under 16°C eller om barnet tenderar att frysa lätt. Lägg till eller ta bort kläder under sovsäcken vid behov istället för att byta sovsäck.',
  },
  {
    question: 'Vad ska bebisen ha på sig under vintersovsäcken?',
    answer: 'Vid 18–20°C och TOG 2.5: pyjamas eller långärmad body. Vid 16–18°C och TOG 2.5: pyjamas med fötter (sparkdräkt). Vid TOG 3.5: tunnare pyjamas räcker eftersom sovsäcken ger extra värme. Känn alltid på nacken och bröstet — bebisen ska kännas behagligt varm, aldrig svettiga. Svettiga nackar är ett tecken på överhettning — ta av ett plagg.',
  },
  {
    question: 'Kan man ha sovsäck på nyfödda på vintern?',
    answer: 'Ja — sovsäckar är säkra för nyfödda och rekommenderas framför lösa filtar i vagga och spjälsäng. Välj en sovsäck i rätt storlek för nyfödda (storlek 50–70 cm eller 0–6 månader). Kontrollera att halsöppningen inte är för stor — bebisens huvud ska inte kunna glida in i sovsäcken. Little Dutch erbjuder vintersovsäckar från 0 månaders ålder.',
  },
  {
    question: 'Varför är sovsäck säkrare än filt?',
    answer: 'En löst liggande filt kan täcka bebisens ansikte och orsaka kvävning, eller arbetas bort under natten och ge kyla. En sovsäck sitter kvar och täcker bebisens kropp utan att kunna täcka ansiktet. Socialstyrelsen och barnläkarföreningar rekommenderar sovsäck framför lösa filtar för bebisar under 12 månaders ålder.',
  },
  {
    question: 'Hur ofta ska man tvätta sovsäcken?',
    answer: 'En sovsäck bör tvättas var 1–2 vecka om bebisen är i den varje natt. Vid sjukdom eller läckage: tvätta direkt. De flesta sovsäckar tvättas i 40°C i maskin. Låt sovsäcken lufttorka — tumlaren kan skada stoppningen och dragkedja. Ha alltid minst två sovsäckar i rotation.',
  },
];
---

<ArticleLayout
  title="Sovsäck bebis vinter 2026 — varm och säker nattsömn"
  description="Vintersovsäck med TOG 2.5–3.5 håller bebis varm och säker. Test av bästa vintermodellerna 2026 — Ergobaby, Little Dutch och fler."
  breadcrumbs={breadcrumbs}
  canonical="https://bebisguiden.se/sovsackar/vinter/"
  updatedDate="2026-04-14"
>
  <p class="text-base text-text-light mb-3 max-w-2xl">
    En vintersovsäck med rätt TOG-värde håller bebisen trygg och lagom varm under kalla nätter. Vi guidar dig till rätt val och förklarar hur du klär bebisen under sovsäcken.
  </p>

  <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
    <p class="text-sm font-semibold text-blue-900 mb-1">Temperaturguide — vintersovsäck</p>
    <div class="text-sm text-blue-800 space-y-1">
      <p><strong>20–22°C i rummet:</strong> TOG 1.0–2.5 + långärmad body</p>
      <p><strong>18–20°C:</strong> TOG 2.5 + pyjamas eller sparkdräkt</p>
      <p><strong>16–18°C:</strong> TOG 2.5 + varm sparkdräkt</p>
      <p><strong>Under 16°C:</strong> TOG 3.5 + tunn pyjamas</p>
    </div>
  </div>

  <h2 class="font-heading text-xl font-bold mt-4 mb-3">Jämförelsetabell — vintersovsäckar bebis 2026</h2>
  <ComparisonTable products={products} featureLabels={featureLabels} />

  <div class="bg-accent/10 border border-accent/30 rounded-xl p-4 mt-4 mb-4">
    <p class="text-sm font-semibold text-accent-dark mb-1">Redaktionens val 2026</p>
    <p class="text-sm text-text-light"><strong><a href="/marken/ergobaby/" class="text-accent hover:underline">Ergobaby</a> On The Move TOG 2.5</strong> är bäst för bebisar 6–18 månader i normalt uppvärmda sovrum. <strong>Little Dutch Vinter TOG 2.5</strong> är bäst för nyfödda och de som föredrar bomull nära huden.</p>
  </div>

  <h2 class="font-heading text-xl font-bold mt-8 mb-4">Våra toppval — vintersovsäckar 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Ergobaby On The Move Sovpåse 6-18M TOG 2.5, Sheep"
  image="/images/products/ergobaby-sovpase-tog25.webp"
      badge="Bäst i test"
      price="549 kr"
      rating={4.8}
      image="/images/products/ergobaby-sovpase-tog25.webp"
      pros={['TOG 2.5 — perfekt för svenska vintrar', 'Tvåvägsdragkedja — enkel blöjbyte', 'Mjukt och hudvänligt material', 'Stor rörelsefrihet för benen']}
      cons={['Passar bara från 6 månader', 'Polyestermaterial — inte ekologiskt', 'Bara en storlek per modell']}
      ctaText="Se pris hos Polarn O. Pyret"
      ctaHref="https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fkollektioner%2Fsovsackar"
    />

    <ProductCard
      name="Little Dutch Sage Vinter Sovpåse 70 cm, Grön"
      badge="Bäst för nyfödda"
      price="749 kr"
      rating={4.7}
      image="/images/products/little-dutch-vinter-sovpase.webp"
      pros={['Mjuk bomull nära huden', 'Passar nyfödda från 0 månader', 'Stilren design från känt märke', 'TOG 2.5 för nordisk vinter']}
      cons={['Högre pris', 'Bomull kan krympa i tvätten', 'Bara storlek 70 cm i denna färg']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fsovsackar-soveplagg%2Flittle-dutch-sage-vinter-sovpase-70-cm-gron"
    />

    <ProductCard
      name="Ergobaby On The Move Sovpåse Vinter TOG 3.5"
      badge="För kalla sovrum"
      price="599 kr"
      rating={4.6}
      image="/images/products/ergobaby-sovpase-tog25.webp"
      pros={['Extra varmt TOG 3.5', 'Bra för kyliga sovrum under 16°C', 'Tvåvägsdragkedja', 'Samma kvalitet som övriga Ergobaby']}
      cons={['Kan bli för varmt i normalt uppvärmda rum', 'Begränsad säsong', 'Kräver kyligare sovrum för att fungera optimalt']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fsovsackar-soveplagg%2Fergobaby-on-the-move-sovpase-6-18m-tog-2-5-sheep"
    />
  </div>

  <h2 class="font-heading text-xl font-bold mt-10 mb-4">Säkerhet om natten — vad du ska tänka på</h2>

  <div class="prose prose-sm text-text-light max-w-none">
    <h3>Överhettning är den vanligaste faran</h3>
    <p>Överhettning är mer riskabelt än nedkylning för bebisar. Känn alltid på bebisens nacke och bröst när de sover — de ska kännas behagligt varma, aldrig svettiga eller heta. Om bebisen svettas: ta av ett plagg eller välj ett lägre TOG nästa natt.</p>

    <h3>Rätt storlek är avgörande</h3>
    <p>En sovsäck som är för stor kan glida upp och täcka bebisens ansikte. Välj alltid sovsäck i rätt storlek för bebisens aktuella längd och vikt. Sovsäckar finns vanligen i storlekarna 50–70 cm (0–6 mån), 70–90 cm (6–18 mån) och 90–110 cm (18–36 mån).</p>

    <h3>Tvättas regelbundet</h3>
    <p>Tvätta sovsäcken var 1–2 vecka i 40°C. Ha minst två sovsäckar i rotation. Låt lufttorka — tumlaren kan skada stoppning och dragkedjor.</p>
  </div>

  <div class="mt-8 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold mb-3">Relaterade sovprodukter</h2>
    <ul class="space-y-2 text-sm">
      <li><a href="/sovsackar/" class="text-accent hover:underline">Alla sovsäckar för bebis 2026</a></li>
      <li><a href="/sovsackar/sommar/" class="text-accent hover:underline">Sommarsovsäck bebis 2026 — TOG 0.5 och 1.0</a></li>
    </ul>
  </div>

  <FAQ items={faqItems} />

  <ProductSchema products={[
    {
      name: 'Ergobaby On The Move Sovpåse 6-18M TOG 2.5, Sheep',
      description: 'Vintersovsäck för bebis 6–18 månader med TOG 2.5. Tvåvägsdragkedja för enkel blöjbyte. Mjukt polyestermaterial.',
      image: 'https://bebisguiden.se/images/products/ergobaby-sovpase-tog25.webp',
      brand: 'Ergobaby',
      ratingValue: 4.8,
      reviewCount: 1,
      offers: [{ price: 549, url: 'https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fkollektioner%2Fsovsackar', seller: 'Polarn O. Pyret' }],
    },
    {
      name: 'Little Dutch Sage Vinter Sovpåse 70 cm, Grön',
      description: 'Vintersovsäck för bebis 0–12 månader med TOG 2.5 i ekologisk bomull. Tvåvägsdragkedja.',
      image: 'https://bebisguiden.se/images/products/little-dutch-vinter-sovpase.webp',
      brand: 'Little Dutch',
      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 749, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbabyprodukter%2Fsovsackar-soveplagg%2Flittle-dutch-sage-vinter-sovpase-70-cm-gron', seller: 'Jollyroom' }],
    },
  ]} />
</ArticleLayout>

<StickyCTA
  href="https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fkollektioner%2Fsovsackar"
  text="Se pris hos Polarn O. Pyret — vintersovsäckar"
  productName="Bäst vintersovsäck 2026"
/>
