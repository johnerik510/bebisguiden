---
import ArticleLayout from '../layouts/ArticleLayout.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Kontakt' },
];
---

<ArticleLayout
  title="Kontakta Bebisguiden.se"
  description="Kontakta Bebisguiden.se med frågor, samarbetsförfrågningar eller feedback. Vi svarar så snart vi kan via e-post."
  breadcrumbs={breadcrumbs}
  showDisclaimer={false}
>
  <div class="prose prose-sm text-text-light max-w-none">
    <p>Har du fragor om våra tester, vill rapportera felaktig information eller är intresserad av samarbete? Kontakta oss via e-post.</p>

    <h2>Kontaktuppgifter</h2>
    <p>Grundår: John Erik Johansson<br />
    E-post: <a href="mailto:vpniskguiden@proton.me">vpniskguiden@proton.me</a></p>

    <p>Vi svarår normalt inom 1-3 årbetsdagar.</p>
  </div>
</ArticleLayout>
