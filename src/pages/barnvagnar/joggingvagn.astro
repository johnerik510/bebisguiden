{/* Auto-TOC "Detaljerad genomgång", money page-mallen. Scopat till .mp-prose på denna sida. */}
<script>
  (function () {
    function slugify(text) {
      return text.toLowerCase().replace(/å/g, 'a').replace(/ä/g, 'a').replace(/ö/g, 'o').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
    function buildToc() {
      const root = document.querySelector('.mp-prose');
      if (!root) return;

      const words = (root.innerText || root.textContent || '').trim().split(/\s+/).filter(Boolean).length;
      const minutes = Math.max(1, Math.round(words / 200));
      const rtEl = document.getElementById('article-reading-time');
      if (rtEl) { rtEl.textContent = minutes + ' min läsning'; rtEl.classList.remove('sr-only'); }

      const h2s = Array.from(root.querySelectorAll('h2'));
      if (h2s.length < 2) return;
      h2s.forEach((h) => { if (!h.id) h.id = slugify(h.textContent || ''); });

      const nav = document.createElement('nav');
      nav.setAttribute('aria-label', 'Innehållsförteckning');
      nav.className = 'not-prose';
      nav.style.cssText = ['margin:0 0 1.5rem', 'padding:1rem 1.35rem', 'background:var(--color-bg-alt)', 'border:1px solid var(--color-border)', 'border-radius:0.85rem'].join(';');

      const heading = document.createElement('div');
      heading.style.cssText = ['display:flex', 'align-items:center', 'gap:0.5rem', 'font-size:0.7rem', 'font-weight:700', 'text-transform:uppercase', 'letter-spacing:0.12em', 'color:var(--color-primary)', 'margin:0 0 0.8rem', 'padding-bottom:0.7rem', 'border-bottom:1px solid var(--color-border)'].join(';');
      heading.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg><span>Innehåll</span>';
      nav.appendChild(heading);

      const ol = document.createElement('ol');
      ol.style.cssText = 'margin:0;padding:0;list-style:none;display:flex;flex-direction:column;';
      h2s.forEach((h, i) => {
        const raw = (h.textContent || '').trim();
        const isRanked = /^\s*\d+[.)]/.test(raw);
        const label = raw.replace(/^\s*\d+[.)]\s*/, '').replace(/\s*\([^)]*\)\s*$/, '').trim();
        const li = document.createElement('li');
        li.style.cssText = 'display:flex;gap:0.55rem;align-items:baseline;padding:0.2rem 0;';
        const num = document.createElement('span');
        num.textContent = String(i + 1);
        num.style.cssText = 'flex:0 0 1.2rem;text-align:right;font-size:0.78rem;font-weight:700;color:var(--color-accent);font-variant-numeric:tabular-nums;line-height:1.3;';
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.style.cssText = ['display:-webkit-box', '-webkit-box-orient:vertical', '-webkit-line-clamp:2', 'flex:1 1 0', 'min-width:0', 'overflow:hidden', 'color:var(--color-text)', 'font-size:0.9rem', 'line-height:1.3', 'text-decoration:none'].join(';');
        const commaIdx = label.indexOf(', ');
        if (isRanked && commaIdx > -1) {
          const nameSpan = document.createElement('span');
          nameSpan.textContent = label.slice(0, commaIdx);
          nameSpan.style.cssText = 'font-weight:600;';
          const descSpan = document.createElement('span');
          descSpan.textContent = label.slice(commaIdx);
          descSpan.style.cssText = 'color:var(--color-text-light);font-weight:400;';
          a.appendChild(nameSpan);
          a.appendChild(descSpan);
        } else {
          a.textContent = label;
          a.style.fontWeight = '500';
        }
        a.addEventListener('mouseenter', () => { a.style.textDecoration = 'underline'; a.style.textUnderlineOffset = '3px'; });
        a.addEventListener('mouseleave', () => { a.style.textDecoration = 'none'; });
        li.appendChild(num);
        li.appendChild(a);
        ol.appendChild(li);
      });
      nav.appendChild(ol);

      const firstH2 = h2s[0];
      const sectionTitle = document.createElement('p');
      sectionTitle.textContent = 'Detaljerad genomgång';
      sectionTitle.className = 'not-prose';
      sectionTitle.style.cssText = ['font-family:var(--font-heading,inherit)', 'font-weight:700', 'font-size:1.5rem', 'line-height:1.25', 'color:var(--color-primary)', 'margin:2rem 0 0.75rem'].join(';');
      firstH2.parentNode.insertBefore(sectionTitle, firstH2);
      firstH2.parentNode.insertBefore(nav, firstH2);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', buildToc);
    else buildToc();
  })();
</script>
