    price: '2 999 kr',
    rating: 4.7,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbarnvagnar',
    features: {
      'Vikt (kg)': '6,0 kg',
      'Hopfällt mått': '53 x 45 x 25 cm',
      'Sits-riktning': 'Framåt',
      'Lämplig ålder': '6 mån–4 år',
      'Pris': '2 999 kr',
    },
  },
  {
    name: 'Cybex Eezy S Twist+2',
    badge: 'Roterande sits',
    price: '4 999 kr',
    rating: 4.6,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbarnvagnar',
    features: {
      'Vikt (kg)': '7,5 kg',
      'Hopfällt mått': '55 x 46 x 22 cm',
      'Sits-riktning': 'Fram- och bakåt',
      'Lämplig ålder': '6 mån–4 år',
      'Pris': '4 999 kr',
    },
  },
  {
    name: 'Babyzen YOYO2',
    badge: 'Flyg-godkänd',
    price: '7 499 kr',
    rating: 4.8,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbarnvagnar',
    features: {
      'Vikt (kg)': '5,8 kg',
      'Hopfällt mått': '52 x 44 x 18 cm',
      'Sits-riktning': 'Framåt',
      'Lämplig ålder': '0–4 år (med tillbehör)',
      'Pris': '7 499 kr',
    },
  },
  {
    name: 'UPPAbaby Minu V2',
    badge: 'Premium kompakt',
    price: '5 999 kr',
    rating: 4.6,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2Fcollections%2Fbarnvagnar',
    features: {
      'Vikt (kg)': '6,4 kg',
      'Hopfällt mått': '56 x 43 x 24 cm',
