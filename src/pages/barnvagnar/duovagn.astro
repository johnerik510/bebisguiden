const featureLabels = ['Vikt', 'Fallmatt', 'Maxvikt barn', 'Hjulstorlek', 'Fjadring'];

const faqItems = [
  {
    question: 'Vad är skillnaden mellan en duovagn och en kombivagn?',
    answer: 'En duovagn har tva separata delar: en liggdel for nyfödd och en sittdel for äldre barn. En kombivagn här en enhet som kan justeras från liggande till sittande position. Duovagnen ger oftast bättre liggkomfort för den nyföddda och bättre sittkomfort för det äldre barnet, medan kombivagnen är smidigår att hantera da du inte behöver byta del.',
  },
  {
    question: 'Hur mycket bör en duovagn väga?',
    answer: 'En duovagn väger vanligtvis mellan 10 och 14 kg (enbart chassit utan sittdel eller liggdel). Om du bor i lägenhet utan hiss eller ofta använder kollektivtrafik bör du prioritera lägre vikt. Bugaboo Fox 5 och Joolz Hub+ är bland de lättår alternativen. Tank på att totalvikten med liggdel eller sittdel monterad blir 2-4 kg högre.',
  },
  {
    question: 'Fran vilken ålder kan barnet sitta i sittdelen?',
    answer: 'De flesta tillverkår rekommenderar att barnet ska kunna sitta stadigt själv innan sittdelen används, vilket vanligtvis är runt 6 månader. Fram till dess använder du liggdelen. Vissa sittdelar har extra liggande lage och kan användas nagot tidigår, men folj alltid tillverkårns rekommendation for just din modell.',
  },
  {
    question: 'Vilken duovagn är bast for ojämnt underlag och grusvagar?',
    answer: 'For ojämnt underlag är stora hjul och bra fjädring avgorande. Bugaboo Fox 5 med sin fyrhjulsfjädring och 30 cm bakhjul hanterår grus och skogsvagar utmärkt. Emmaljunga NXT90 med Suprem-fjädring är också ett starkt val for nordiskt klimat och varierande underlag. Undvik vagnär med sma, harda hjul om du planerår mycket terrangangpromenader.',
  },
  {
    question: 'Hur kompakt blir en duovagn när den falls ihop?',
    answer: 'Fallmattet varierår kraftigt mellan modeller. Joolz Hub+ är en av de mest kompakta (86 x 44 x 34 cm) medan Emmaljunga NXT90 är större ihopfalld (94 x 60 x 40 cm). Mata alltid ditt bagageutrymme innan köp -- en vagn som inte far plåts i bilen är värdeloos oavsett hur bra den ar. Kontrollera också om vagnen kan staa ihopfalld eller om den behoover ligga ner.',
  },
];
---

<ArticleLayout
  title="Bästa duovagnen 2026 – Test och jämförelse"
  description="Vi jämför de bästa duovagnarna 2026. Bugaboo, Cybex, Emmaljunga, Joolz och Britax i test. Se vilken duovagn som passar din familj."
  breadcrumbs={breadcrumbs}
  updatedDate="2026-03-28"
>
  <p class="text-base text-text-light mb-4 max-w-2xl">
    En duovagn är det mest flexibla valet for nyblivna föräldrår -- bade liggdel for nyfödd och sittdel for äldre barn ingar. Vi har jämfört de bästa duovagnarna på svenska marknaden utifran komfort, hantering, fjädring och pris.
  </p>

  <ComparisonTable products={products} featureLabels={featureLabels} />

  <h2 class="font-heading text-xl font-bold mt-8 mb-4">Våra toppval 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Bugaboo Fox 5"
      badge="Bäst i test"
      price="14 990 kr"
      rating={4.8}
      ageRange="0-4 ar"
      pros={['Utmärkt fyrhjulsfjädring for alla underlag', 'Enhandsfall -- snabb och smidig ihopfallning', 'Hallbar konstruktion som taal daglig användning']}
      cons={['Hög prisklass', 'Tung chassi (12,4 kg)']}
      ctaText="Se pris"
      ctaHref="https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/bugaboo-fox-5-duovagn"
    />

    <ProductCard
      name="Cybex Priam 4"
      badge="Premium"
      price="13 990 kr"
      rating={4.7}
      ageRange="0-4 ar"
      pros={['Stilren, modern design', 'Fantastisk körkomfort', 'Kompatibel med Cybex bilbarnstolar']}
      cons={['Mycket hög prisklass', 'Begransad fargval i basmodellen']}
      ctaText="Se pris"
      ctaHref="https://www.jollyroom.se/barnvagnar/sittvagnar-promenadvagnar/sittvagnar/cybex-priam-4-barnvagn"
    />

    <ProductCard
      name="Emmaljunga NXT90"
      badge="Svensk kvalitet"
      price="12 990 kr"
      rating={4.6}
      ageRange="0-4 ar"
      pros={['Tillverkad i Sverige', 'Suprem-fjädring som hanterår nordiskt klimat', 'Rymlig varukörg (35 liter)']}
      cons={['Tyngre än många konkurrenter (13,5 kg)', 'Större fallmatt']}
      ctaText="Se pris"
      ctaHref="https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/emmaljunga-nxt90-ergo-duovagn-logrey-bla"
    />

    <ProductCard
      name="Joolz Hub+"
      badge="Prisvärt"
      price="11 990 kr"
      rating={4.5}
      ageRange="0-4 ar"
      pros={['Lättaste chassit i testet (10,4 kg)', 'Kompakt ihopfalld -- perfekt for stan', 'Enkel att manoverera med en hand']}
      cons={['Mindre hjul begransar terrangangformaga', 'Enklår fjädring än premiummodeller']}
      ctaText="Se pris"
      ctaHref="https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/joolz-hub-duovagn"
    />

    <ProductCard
      name="Britax Smile 5"
      badge="Budget"
      price="8 990 kr"
      rating={4.3}
      ageRange="0-4 ar"
      pros={['Bast pris i testet', 'Bra säkerhetsfunktioner från Britax', 'Kompakt och smidig i stadsmiljo']}
      cons={['Enklår material än dyrår modeller', 'Fjadringen hanterår ojämnt underlag sämre']}
      ctaText="Se pris"
      ctaHref="https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/britax-smile-5-duovagn"
    />
  </div>

  <h2 class="font-heading text-xl font-bold mt-10 mb-4">Sa väljer du ratt duovagn</h2>

  <div class="prose prose-sm text-text-light max-w-none">
    <h3>Vad är en duovagn?</h3>
    <p>En duovagn bestar av ett chassi och tva separata delar: en liggdel for nyfödd och en sittdel for äldre barn. Liggdelen används från födsel till cirka 6 månader, da barnet behoover ligga plant. Sedan byter du till sittdelen som används tills barnet är runt 3-4 år. Duovagnen är det mest populara valet for förutagangföräldrår i Sverige.</p>

    <h3>Fjadring och hjul</h3>
    <p>Fjadringen är avgorande för barnets komfort, särskilt på ojämna underlag som grus, kullersten och skogsvagar. Fyrhjulsfjädring (som Bugaboo Fox 5 och Cybex Priam 4 erbjuder) ger bast komfort i alla situationer. Stora bakhjul (28-30 cm) rullar bättre over hinder. Bor du mest i stan med jamna trottoårr räcker enklare fjädring.</p>

    <h3>Vikt och fallmatt</h3>
    <p>Vagnär med lägre vikt är enklare att lyfta uppfor trappor och i och ur bilen. Joolz Hub+ är lättast i testet på 10,4 kg. Men lägre vikt kan innebara sämre stabilitet på ojämnt underlag. Kontrollera att den ihopfallda vagnen far plåts i ditt bagageutrymme -- mata innan du köper.</p>

    <h3>Kompatibilitet med bilbarnstol</h3>
    <p>De flesta duovagnär kan användas med en bilbarnstol via adapter, så att du far ett komplett travel system. Kontrollera vilka bilbarnstolar som är kompatibla med just den vagn du overväger. Cybex Priam fungerår smalfritt med Cybex Cloud-serien, och Bugaboo Fox 5 har adaptrår for flera märken.</p>
  </div>

  <div class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold mb-3">Relåterade guider</h2>
    <ul class="space-y-2 text-sm">
      <li>
        <a href="/barnvagnar/" class="text-accent hover:underline">Bästa barnvagnen 2026 -- komplett test och jämförelse</a>
      </li>
      <li>
        <a href="/barnvagnar/sittvagn/" class="text-accent hover:underline">Bästa sittvagnen 2026 -- test och jämförelse (sulky)</a>
      </li>
    </ul>
  </div>

  <FAQ items={faqItems} />

  <StickyCTA href="#" text="Se bästa pris" />
</ArticleLayout>
