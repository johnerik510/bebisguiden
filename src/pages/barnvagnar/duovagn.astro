    rating: 4.7,
    ctaHref: 'https://www.jollyroom.se/barnvagnar/sittvagnar-promenadvagnar/sittvagnar/cybex-priam-4-barnvagn',
    features: {
      'Vikt': '11,9 kg',
      'Fallmatt': '85 x 50 x 38 cm',
      'Maxvikt barn': '22 kg',
      'Hjulstorlek': '28 cm (bak)',
      'Fjadring': 'Fyrhjulsfjädring',
    },
  },
  {
    name: 'Emmaljunga NXT90',
    badge: 'Svensk kvalitet',
    price: '12 990 kr',
    rating: 4.6,
    ctaHref: 'https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/emmaljunga-nxt90-ergo-duovagn-logrey-bla',
    features: {
      'Vikt': '13,5 kg',
      'Fallmatt': '94 x 60 x 40 cm',
      'Maxvikt barn': '22 kg',
      'Hjulstorlek': '30 cm (bak)',
      'Fjadring': 'Suprem-fjädring',
    },
  },
  {
    name: 'Joolz Hub+',
    badge: 'Prisvärt',
    price: '11 990 kr',
    rating: 4.5,
    ctaHref: 'https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/joolz-hub-duovagn',
