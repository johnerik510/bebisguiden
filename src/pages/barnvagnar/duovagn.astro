    rating: 4.8,
    ctaHref: 'https://www.jollyroom.se/barnvagnar/duovagnar-kombivagnar/duovagnar/bugaboo-fox-5-duovagn',
    features: {
      'Vikt': '12,4 kg',
      'Fallmatt': '90 x 46 x 36 cm',
      'Maxvikt barn': '22 kg',
      'Hjulstorlek': '30 cm (bak)',
      'Fjadring': 'Fyrhjulsfjädring',
    },
  },
  {
    name: 'Cybex Priam 4',
    badge: 'Premium',
