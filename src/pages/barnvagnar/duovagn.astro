      'Vikt': '11,2 kg',
      'Fallmatt': '88 x 48 x 35 cm',
      'Maxvikt barn': '22 kg',
      'Hjulstorlek': '28 cm (bak)',
      'Fjadring': 'Bakhjulsfjädring',
    },
