    ctaHref: 'https://addrevenue.io/t?a=987081&c=3467325',
    features: {
      'Typ': 'Duovagn',
      'Vikt chassi': '13,2 kg',
      'Tillverkning': 'Tyskland',
      'Fjädring': 'Fullfjädrad',
