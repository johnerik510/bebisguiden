const featureLabels = ['Typ', 'Vikt', 'Hopfälld', 'Hjul', 'Liggläge'];

const faqItems = [
 {
 question: 'Vad ska jag tänka på när jag köper en billig barnvagn?',
 answer: 'Tre faktorer avgör om budgetvagnen håller: säkerhetsgodkännande (EN 1888 är kravet, kontrollera att CE-märke finns), barnets ålder (under sex månader krävs liggläge, annars räcker sittvagn), och din vardag (city med kollektivtrafik = vikt under 8 kg, grus och natur = stötdämpande hjul). Joie Honour är bäst om du vill ha en komplett sittvagn med liggläge och vändbar sittdel. Silver Cross Clic på 6,5 kg är bäst om resor och kollektivtrafik är vanligt. Hauck Rapid 3R är billigast om budgeten är avgörande.',
 },
 {
 question: 'Kan ett nyfött barn åka i en budget-sittvagn?',
