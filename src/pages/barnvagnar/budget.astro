const featureLabels = ['Typ', 'Vikt', 'Hopfälld', 'Hjul', 'Liggläge'];

const faqItems = [
 {
 question: 'Vad ska jag tänka på när jag köper en billig barnvagn?',
 answer: 'Tre faktorer avgör om budgetvagnen håller: säkerhetsgodkännande (EN 1888 är kravet, kontrollera att CE-märke finns), barnets ålder (under sex månader krävs liggläge, annars räcker sittvagn), och din vardag (city med kollektivtrafik = vikt under 8 kg, grus och natur = lufthjul). Joie Litetrax 4 Air är bäst om du behöver lufthjul och liggläge. Silver Cross Zest på 6 kg är bäst om du reser mycket med kollektivtrafik. Chicco Miinimo 4 är kompaktest ihopfälld om bagageutrymmet i bilen är litet.',
