  <ProductSchema products={[
    { name: 'Bugaboo Donkey 5 Duo', description: 'Bredaste syskonvagnen med plats för två i full bredd sida vid sida.', brand: 'Bugaboo', ratingValue: 4.8, reviewCount: 1, offers: [{ price: 24999, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnvagnar', seller: 'Jollyroom' }] },
    { name: 'UPPAbaby Vista V3', description: 'Expanderbar kombivagn som enkelt byggs ut till syskonvagn med rumble seat.', brand: 'UPPAbaby', ratingValue: 4.8, reviewCount: 1, offers: [{ price: 15999, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnvagnar%2Fduovagnar-kombivagnar%2Fduovagnar%2Fuppababy-vista-v3-duovagn-jake', seller: 'Jollyroom' }] },
    { name: 'Baby Jogger City Select 2', description: 'Modulär syskonvagn med många konfigurationsmöjligheter och god körbarhet.', brand: 'Baby Jogger', ratingValue: 4.6, reviewCount: 1, offers: [{ price: 9999, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnvagnar%2Fsyskonvagnar%2Fbaby-jogger-city-select-2-tencel-sys-bla', seller: 'Jollyroom' }] },
