import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';
import CTABox from '../../components/CTABox.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Barnvagnar', href: '/barnvagnar/' },
  { label: 'Syskonvagn' },
