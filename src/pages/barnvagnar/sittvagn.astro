    { name: 'Bugaboo Butterfly', description: 'Premiumsittvagn med Bugaboos kvalitet och smidiga enhandsvikning.', brand: 'Bugaboo', ratingValue: 4.8, reviewCount: 1, offers: [{ price: 5990, url: 'https://to.kopbarnvagn.se/t/t?a=2056646903&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.kopbarnvagn.se%2Fsv%2Fartiklar%2Fbugaboo-butterfly%2Findex.html', seller: 'Köpbarnvagn' }] },
