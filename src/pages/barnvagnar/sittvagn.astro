    { name: 'Babyzen Yoyo2', description: 'Ikonisk kabinvagn med premium material och enkel 1-stegsvikning.', brand: 'Babyzen', ratingValue: 4.8, reviewCount: 1, offers: [{ price: 5290, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnvagnar%2Fsulkys%2Fsulkys%2Fstokke-yoyo-3-sittvagn-6-black-black', seller: 'Jollyroom' }] },
