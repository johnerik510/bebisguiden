// Spec-tabellens features = de fem grundspeccen.
const specProducts = products.map((p) => ({ name: p.name, imageUrl: p.imageUrl, features: p.features }));
const specLabels = ['Bredd', 'Vikt', 'Hopfällt', 'Passage', 'Fällning'];

const faqItems = [
  {
    question: 'Hur bred ska en kompakt barnvagn vara för att passa i smala dörröppningar?',
