    { name: 'Emmaljunga NXT90', description: 'Klassisk svensk kombivagn med djup liggdel och bra väggrepp. Tillverkad i Sverige.', brand: 'Emmaljunga', ratingValue: 4.8, reviewCount: 1, offers: [{ price: 9999, url: 'https://addrevenue.io/t?a=986001&c=3467325&url=https%3A%2F%2Fwww.emmaljunga.com%2Fsv%2F', seller: 'Emmaljunga' }] },
    { name: 'iCandy Peach 7', description: 'Brittisk kombivagn med bred platt liggdel och smidig körning. Premiumkvalitet.', brand: 'iCandy', ratingValue: 4.7, reviewCount: 1, offers: [{ price: 12999, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnvagnar', seller: 'Jollyroom' }] },
    { name: 'Bugaboo Fox 5', description: 'Toppmärkets kombivagn med djup liggdel och unikt fjädringssystem. Bäst i test.', brand: 'Bugaboo', ratingValue: 4.9, reviewCount: 1, offers: [{ price: 15999, url: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbarnvagnar', seller: 'Jollyroom' }] },
  ]} />
</ArticleLayout>
