<script is:inline>
(function () {
 var imgs = document.querySelectorAll('img[src*="/images/infografik-"]');
 if (!imgs.length) return;
 var overlay = null;
 function onKey(e) { if (e.key === 'Escape') closeLb(); }
 function closeLb() {
  if (!overlay) return;
  document.removeEventListener('keydown', onKey);
  document.body.style.overflow = '';
  overlay.remove();
  overlay = null;
 }
 function openLb(src, alt) {
  overlay = document.createElement('div');
  overlay.setAttribute('role', 'dialog');
  overlay.setAttribute('aria-modal', 'true');
  overlay.setAttribute('aria-label', alt || 'Förstorad infografik');
  overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(15,23,42,.92);display:flex;align-items:center;justify-content:center;padding:20px;cursor:zoom-out;';
  var img = document.createElement('img');
  img.src = src;
  img.alt = alt || '';
  img.style.cssText = 'max-width:100%;max-height:100%;border-radius:12px;box-shadow:0 10px 40px rgba(0,0,0,.5);';
  var close = document.createElement('button');
  close.type = 'button';
  close.setAttribute('aria-label', 'Stäng');
  close.innerHTML = '&times;';
  close.style.cssText = 'position:absolute;top:14px;right:20px;background:none;border:none;color:#fff;font-size:42px;line-height:1;cursor:pointer;';
  overlay.appendChild(img);
  overlay.appendChild(close);
  document.body.appendChild(overlay);
  document.body.style.overflow = 'hidden';
  close.focus();
  overlay.addEventListener('click', closeLb);
  document.addEventListener('keydown', onKey);
 }
 imgs.forEach(function (im) {
  im.style.cursor = 'zoom-in';
  im.setAttribute('role', 'button');
  im.setAttribute('tabindex', '0');
  im.setAttribute('aria-label', 'Förstora: ' + (im.alt || 'infografik'));
  im.addEventListener('click', function () { openLb(im.currentSrc || im.src, im.alt); });
  im.addEventListener('keydown', function (e) {
   if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(im.currentSrc || im.src, im.alt); }
  });
 });
})();
</script>

