      image: 'https://bebisguiden.se/images/products/ratt-start-badleksaker-korall.webp',
      brand: 'Rätt Start',
      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 99, url: 'https://www.jollyroom.se/sok?text=rätt+start+badleksaker', seller: 'Jollyroom' }],
