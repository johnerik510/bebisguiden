    },
  ]} />

  <CTABox productName="Badleksaker bebis" store="Jollyroom" affiliateUrl="https://www.jollyroom.se/sok?text=badleksaker+bebis" description="Stort sortiment badleksaker och badprodukter för bebis." />
<CTABox productName="Badleksaker bebis" store="Toyspace" affiliateUrl="https://id.toyspace.se/t/t?a=1984734030&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.toyspace.se%2Fleksaker%2Fvattenleksaker" description="Skandinaviens största leksaksbutik — vattenleksaker och badleksaker." />
