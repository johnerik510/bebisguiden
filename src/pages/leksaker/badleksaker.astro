      ctaText="Se pris hos Jollyroom"
      ctaHref="https://www.jollyroom.se/leksaker/babyleksaker/bitringar/playgro-loopy-links-babyleksak-lankkedja-flerfargad"
    />

    <ProductCard
      name="Oball Classic Bold Boll"
      badge="Bäst i badet"
      price="129 kr"
      rating={4.8}
      image="/images/products/oball-classic-boll.webp"
      ageRange="0–12 månader"
      pros={['Inga hål — samlar inte vatten och mögel', 'Flyter i vadet', 'Enkel att greppa med liten hand', 'Torkar snabbt']}
