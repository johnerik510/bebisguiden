    ctaHref: 'https://www.jollyroom.se/sok?text=rätt+start+badleksaker+sjodjur',
    features: {
      'Lämplig ålder': '6 mån+',
      'Material': 'Plast BPA-fri',
      'Stimulerar': 'Finmotorik + syn',
