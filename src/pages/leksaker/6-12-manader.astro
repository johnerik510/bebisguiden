    {
      name: 'Oball Classic Bold Boll',
      description: 'Lätt boll i BPA-fri plast med öppet mönster. Enkel att greppa för bebis. Stimulerar krypning. Lämplig 0–12 månader.',
      image: 'https://bebisguiden.se/images/products/oball-classic-boll.jpg',
      brand: 'Oball',
      ratingValue: 4.8,
      reviewCount: 1,
      offers: [{ price: 129, url: 'https://www.jollyroom.se/leksaker/babyleksaker/bitringar/oball-classic-bold-boll-rod-bla-gron-och-gul', seller: 'Jollyroom' }],
    },
  ]} />

  <CTABox productName="Leksaker 6–12 månader" store="Jollyroom" affiliateUrl="https://www.jollyroom.se/leksaker/babyleksaker/stapelbara-klossar" description="Stort sortiment stapelleksaker och aktivitetsleksaker för bebis." />
