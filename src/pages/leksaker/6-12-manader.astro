---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import ProductSchema from '../../components/ProductSchema.astro';
import CTABox from '../../components/CTABox.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Leksaker', href: '/leksaker/' },
  { label: 'Leksaker 6–12 månader' },
];

const products = [
  {
    name: 'Alice & Fox Stapeltorn Safari',
    badge: 'Bäst i test',
    price: '299 kr',
    rating: 4.8,
    image: '/images/products/alice-fox-stapeltorn-safari.jpg',
    ctaHref: 'https://www.jollyroom.se/leksaker/babyleksaker/stapelbara-klossar/alice-fox-stapeltorn-safari',
    features: {
      'Lämplig ålder': '6–36 mån',
      'Material': 'Trä',
      'Stimulerar': 'Finmotorik + kognition',
      'Säkerhetsgodkänd': 'Ja',
    },
  },
  {
    name: 'PolarB Stapelklossar Djur',
    badge: 'Bäst budget',
    price: '149 kr',
    rating: 4.6,
    image: '/images/products/polarb-stapelklossar-djur.jpg',
    ctaHref: 'https://www.jollyroom.se/leksaker/babyleksaker/stapelbara-klossar/polarb-stapelklossar-djur',
    features: {
      'Lämplig ålder': '6 mån+',
      'Material': 'Trä',
      'Stimulerar': 'Grepp + kognition',
      'Säkerhetsgodkänd': 'Ja',
    },
  },
  {
    name: 'Little Dutch Fairy Garden Stapelklossar',
    badge: 'Bäst design',
    price: '149 kr',
    rating: 4.7,
    image: '/images/products/little-dutch-fairy-garden-stapelklossar.jpg',
    ctaHref: 'https://www.jollyroom.se/leksaker/babyleksaker/stapelbara-klossar/little-dutch-fairy-garden-stapelklossar',
    features: {
      'Lämplig ålder': '6 mån+',
      'Material': 'Trä',
      'Stimulerar': 'Finmotorik + syn',
      'Säkerhetsgodkänd': 'Ja',
    },
  },
  {
    name: 'Oball Classic Bold Boll, Röd, Blå, Grön och Gul',
    badge: 'Bäst för krypning',
    price: '129 kr',
    rating: 4.8,
    image: '/images/products/oball-classic-boll.jpg',
    ctaHref: 'https://www.jollyroom.se/leksaker/babyleksaker/bitringar/oball-classic-bold-boll-rod-bla-gron-och-gul',
    features: {
      'Lämplig ålder': '0–12 mån',
      'Material': 'Plast BPA-fri',
      'Stimulerar': 'Grepp + krypning',
      'Säkerhetsgodkänd': 'Ja',
    },
  },
