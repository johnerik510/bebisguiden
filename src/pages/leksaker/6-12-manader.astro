      image: 'https://bebisguiden.se/images/products/little-dutch-fairy-garden-stapelklossar.jpg',
      brand: 'Little Dutch',
      ratingValue: 4.7,
      reviewCount: 1,
      offers: [{ price: 149, url: 'https://www.jollyroom.se/leksaker/babyleksaker/stapelbara-klossar/little-dutch-fairy-garden-stapelklossar', seller: 'Jollyroom' }],
