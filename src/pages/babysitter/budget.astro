    { name: 'Bright Starts Wild Vibes Babysitter', description: 'Babysitter med inbyggd vibration, musik och leksaksbåge. Max 9 kg.', brand: 'Bright Starts', ratingValue: 4.3, reviewCount: 1 },
  ]} />

