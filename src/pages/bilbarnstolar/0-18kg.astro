 { name: 'BeSafe iZi Modular RF X1 i-Size', description: 'Bakåtvänd bilbarnstol 0 till 18 kg med modulärt system och ISOFIX.', image: 'https://bebisguiden.se/images/products/besafe-izi-modular-rf-x1.webp', brand: 'BeSafe', ratingValue: 4.8, reviewCount: 1 },
 ]} />
</ArticleLayout>
