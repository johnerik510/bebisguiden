---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Bilbarnstolar' },
];

const products = [
  {
    name: 'Britax Romer Dualfix 5Z i-Size',
    badge: 'Bäst i test',
    price: '2 995 kr',
    rating: 4.8,
    image: '/images/products/britax-dualfix-5z.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbilstolar%2Fbilbarnstolar%2Fbakatvanda%2F1792555_britax-romer-dualfix-5z-bilbarnstol-night-blue',
    features: {
      'Montering': 'ISOFIX + stödben',
      'Riktning': 'Bakåtvänd/framåtvänd',
      'Vikt': '14,8 kg',
      'Ålder': '0–4 år (40–105 cm)',
      'Krocktest': 'Bra (ADAC 2024)',
    },
  },
  {
    name: 'Cybex Sirona T i-Size',
    badge: 'Premiumval',
    price: '3 995 kr',
    rating: 4.7,
    image: '/images/products/cybex-sirona-t.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbilstolar%2Fbilbarnstolar%2Fbakatvanda%2Fcybex-sirona-t-i-size-bilbarnstol-sepia-black',
    features: {
      'Montering': 'ISOFIX + stödben',
      'Riktning': 'Bakåtvänd/framåtvänd',
      'Vikt': '15,2 kg',
      'Ålder': '0–4 år (45–105 cm)',
      'Krocktest': 'Bra (ADAC 2024)',
    },
  },
  {
    name: 'BeSafe iZi Modular RF X1 i-Size',
    badge: 'Lång användningstid',
    price: '2 999 kr',
    rating: 4.6,
    image: '/images/products/besafe-izi-modular-rf-x1.webp',
    ctaHref: 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2Fbilstolar%2Fbilbarnstolar%2Fbakatvanda%2Fbesafe-izi-modular-rf-x1-i-size-bilbarnstol-fresh-black-cab',
    features: {
      'Montering': 'ISOFIX + stödben',
      'Riktning': 'Bakåtvänd/framåtvänd',
      'Vikt': '12,5 kg',
      'Ålder': '0–4 år',
      'Krocktest': 'Bra',
    },
  },
];

const featureLabels = ['Montering', 'Riktning', 'Vikt', 'Ålder', 'Krocktest'];

const kriterier = [
  { nr: '01', namn: 'Krocktest', vikt: 35, beskrivning: 'ADAC, Folksam och Stiftung Warentest — minst två oberoende källor krävs.' },
  { nr: '02', namn: 'Installation', vikt: 20, beskrivning: 'Vi monterar stolen i tre olika bilar och mäter tid och felrisk.' },
  { nr: '03', namn: 'Bakåtvänd kapacitet', vikt: 20, beskrivning: 'Hur länge barnet får åka bakåtvänt — upp till 105 cm är kravet.' },
  { nr: '04', namn: 'Komfort & ergonomi', vikt: 15, beskrivning: 'Passform, värme, polster och hur barnet faktiskt sitter över tid.' },
  { nr: '05', namn: 'Pris & värde', vikt: 10, beskrivning: 'Kronor per månads användning snarare än prislappen i butik.' },
];

const faqItems = [
  {
    question: 'Hur länge ska barn åka bakåtvänt?',
    answer: 'Barn ska åka bakåtvänt så länge som möjligt, helst till 4 års ålder eller längre. Bakåtvänt är upp till fem gånger säkrare än framåtvänt vid en frontalkrocka. Transportstyrelsen rekommenderar bakåtvänt till minst 4 år.',
  },
  {
    question: 'Vad är ISOFIX och behövs det?',
    answer: 'ISOFIX är ett standardiserat fastsystem där bilbarnstolen klickas fast i bilens chassi via två metallpunkter. Det ger en säkrare och enklare montering jämfört med bilbälte. De flesta moderna bilar från 2012 och framåt har ISOFIX som standard.',
  },
  {
    question: 'Vad betyder i-Size (R129)?',
    answer: 'i-Size (R129) är den senaste europeiska säkerhetsstandarden för bilbarnstolar. Den kräver sidokrocktestning, längre bakåtvänt åkande (minst 15 månader), och använder barnets längd istället för vikt för att avgöra vilken stol som passar.',
  },
  {
    question: 'Vad kostar en bra bilbarnstol?',
    answer: 'En bra bilbarnstol kostar vanligtvis mellan 3 000 och 7 000 SEK. Det finns prisvärda alternativ som klarar krocktester bra, men dyrare stolar har ofta bättre komfort, längre användningstid och smidigare funktioner som 360-graders rotation.',
  },
  {
    question: 'Kan jag köpa en begagnad bilbarnstol?',
    answer: 'Nej — undvik alltid begagnade bilbarnstolar. Du vet inte om stolen varit med i en krock (osynliga skador), om den har rätt delar, och certifieringen kan ha löpt ut. Säkerhet är inte ett område att spara pengar på.',
  },
];
---

<BaseLayout
  title="Bilbarnstol bäst i test 2026 — krocktestade i-Size"
  description="Redaktionell ranking av bilbarnstolar 2026. Vi läser ADAC, Folksam och i-Size R129 — sedan testar vi stolarna i verkliga bilar."
  canonical="https://bebisguiden.se/bilbarnstolar/"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <link slot="head" rel="preload" as="image" href="/images/cat-bilbarnstol.webp" type="image/webp" />

  <!-- Editorial hero -->
  <section class="text-white relative overflow-hidden">
    <img
      src="/images/cat-bilbarnstol.webp"
      alt="Bilbarnstol monterad i bil — testad av redaktionen"
      class="absolute inset-0 w-full h-full object-cover -z-10"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-[#3d0a1f] via-primary/90 to-primary/50 -z-10" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/25 -z-10" aria-hidden="true"></div>
    <div class="absolute -top-20 -right-20 w-[480px] h-[480px] rounded-full bg-accent/20 blur-[140px] -z-10" aria-hidden="true"></div>
    <div class="absolute inset-0 opacity-[0.10] mix-blend-overlay -z-10" aria-hidden="true" style="background-image: radial-gradient(circle at 1px 1px, white 0.8px, transparent 0); background-size: 3px 3px;"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-1 relative">
      <nav aria-label="Brödsmulor" class="mb-4 text-[13px] text-white/70">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="hover:text-white hover:underline">Hem</a></li>
          <li aria-hidden="true" class="text-white/40">/</li>
          <li aria-current="page" class="text-white/90 font-semibold">Bilbarnstolar</li>
        </ol>
      </nav>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 sm:pb-12 relative">
      <div>
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-px bg-rose-300"></span>
            <span class="text-[11px] font-bold uppercase tracking-[0.28em] text-rose-200">Granskningsområde 01 / 08</span>
          </div>

          <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.02] mb-6 tracking-[-0.02em]">
            Bilbarnstolar
            <span class="text-white/55 font-normal"> — </span>
            <span class="italic font-medium" style="font-family: Georgia, serif;">säkrast först</span>,
            <br class="hidden sm:inline">
            <span class="relative inline-block">
              <span class="relative z-10">sedan pris.</span>
              <svg class="absolute -bottom-3 left-0 w-full z-0 text-accent" aria-hidden="true" viewBox="0 0 300 12" preserveAspectRatio="none">
                <path d="M2 8 Q 75 2, 150 6 T 298 5" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" fill="none"/>
              </svg>
            </span>
          </h1>

          <div class="flex flex-wrap gap-3 mb-10 mt-2">
            <a href="#kategorier" class="group inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-semibold px-6 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30 hover:-translate-y-0.5">
              Välj kategori
              <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </a>
            <a href="#metodik" class="inline-flex items-center gap-2 bg-white/[0.08] hover:bg-white/[0.15] backdrop-blur-sm border border-white/20 text-white font-semibold px-6 py-3.5 rounded-xl transition-all">
              Så testar vi
            </a>
          </div>

        </div>

      </div>
    </div>

    <!-- Källor-ribbon -->
    <div class="relative border-t border-white/10 bg-black/20 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between text-[11px] font-semibold uppercase tracking-[0.22em] text-white/60">
        <span class="italic normal-case tracking-normal text-white/50 text-xs hidden sm:inline" style="font-family: Georgia, serif;">Vi bygger på:</span>
        <span class="flex items-center gap-2.5 sm:gap-4 ml-auto">
          <span class="text-white/75">Folksam</span>
          <span class="text-accent/60">·</span>
          <span class="text-white/75">ADAC</span>
          <span class="text-accent/60 hidden sm:inline">·</span>
          <span class="text-white/75 hidden sm:inline">Stiftung Warentest</span>
          <span class="text-accent/60 hidden md:inline">·</span>
          <span class="text-white/75 hidden md:inline">i-Size R129</span>
          <span class="text-accent/60 hidden md:inline">·</span>
          <span class="text-white/75 hidden md:inline">Transportstyrelsen</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Metodik-stripe -->
  <section id="metodik" class="py-16 sm:py-20 bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 mb-12 items-end">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 mb-4">
            <span class="w-10 h-px bg-accent"></span>
            <span class="text-xs font-semibold text-accent uppercase tracking-[0.25em]">Så testar vi bilbarnstolar</span>
          </div>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-primary leading-[1.05] tracking-tight">
            Fem kriterier, <span class="relative inline-block">
              <span class="relative z-10">samma måttstock</span>
              <span class="absolute left-0 bottom-1 w-full h-3 bg-accent/30 -z-0" aria-hidden="true"></span>
            </span> på varje stol.
          </h2>
        </div>
        <div class="lg:col-span-5">
          <p class="text-text-light leading-relaxed text-base border-l-2 border-accent pl-5">
            Vi rankar aldrig efter en enskild testkälla. Varje stol poängsätts mot fem vägda kriterier — och läggs in i tabellen nedan först när vi testat den själva. <a href="/sa-testar-vi/" class="text-accent font-semibold hover:underline">Läs hela metodiken</a>.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-5 gap-4 lg:gap-5">
        {kriterier.map((k) => (
          <article class="group relative bg-white rounded-2xl p-5 border border-border hover:border-accent hover:shadow-lg transition-all">
            <div class="flex items-baseline justify-between mb-3">
              <span class="font-heading text-sm font-bold text-accent tracking-wider">{k.nr}</span>
              <span class="text-[10px] font-bold uppercase tracking-wider text-text-light">Vikt {k.vikt}%</span>
            </div>
            <h3 class="font-heading text-lg font-bold text-primary mb-2 leading-tight">{k.namn}</h3>
            <p class="text-[13px] text-text-light leading-snug mb-4">{k.beskrivning}</p>
            <div class="h-1 rounded-full bg-bg overflow-hidden">
              <div class="h-full bg-gradient-to-r from-accent to-accent-dark" style={`width: ${k.vikt * 2.5}%`}></div>
            </div>
          </article>
        ))}
      </div>

      <!-- Redaktionsansvarig -->
      <div class="mt-14 pt-10 border-t border-border grid md:grid-cols-[auto_1fr_auto] gap-6 items-center">
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-full overflow-hidden ring-2 ring-border">
            <img src="/images/john-erik-johansson.webp" alt="John Erik Johansson" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-wider text-accent mb-0.5">Testansvarig bilbarnstolar</div>
            <div class="font-heading font-bold text-primary leading-tight">John Erik Johansson</div>
            <div class="text-xs text-text-light">Grundare · 100+ produkter testade</div>
          </div>
        </div>
        <p class="text-sm text-text-light leading-relaxed italic" style="font-family: Georgia, serif;">
          "Jag monterar varje stol jag rankar i minst tre olika bilar — Volvo, Kia och Volkswagen. En stol som sitter perfekt i en bil kan hamna snett i nästa, och det är där de verkliga felen uppstår."
        </p>
        <a href="/om-redaktionen/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:underline whitespace-nowrap">
          Möt redaktionen
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>


  <!-- Köpguide -->
  <!-- Kategorier vi testar -->
  <section id="kategorier" class="py-14 sm:py-16 bg-bg border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-10">
        <div class="inline-flex items-center gap-2 text-xs font-semibold text-accent uppercase tracking-[0.25em] mb-3">
          <span class="w-8 h-px bg-accent"></span>
          Kategorier vi testar
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary leading-tight mb-3">Välj kategori av bilbarnstol</h2>
        <p class="text-text-light leading-relaxed">Vi granskar bilbarnstolar i nio kategorier — efter åldersgrupp, riktning, standard och användningsområde. Varje kategori har sin egen ranking och köpguide.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            href: '/bilbarnstolar/bakatvand/',
            name: 'Bakåtvända bilbarnstolar',
            desc: 'Upp till fem gånger säkrare vid frontalkrock. Vi rankar stolarna som klarar bakåtvänt till minst 105 cm.',
            meta: '0–4 år · R129',
            anchor: 'Se bästa bakåtvända bilbarnstolen 2026',
            icon: 'M10 19l-7-7m0 0l7-7m-7 7h18',
          },
          {
            href: '/bilbarnstolar/framatvand/',
            name: 'Framåtvända bilbarnstolar',
            desc: 'När barnet vuxit ur bakåtvänt. Vi testar Cybex Anoris T, Britax Kidfix och andra framåtvända toppval.',
            meta: '4 år+ · ISOFIX + bälte',
            anchor: 'Se bästa framåtvända bilbarnstolen',
            icon: 'M14 5l7 7m0 0l-7 7m7-7H3',
          },
          {
            href: '/bilbarnstolar/i-size/',
            name: 'i-Size (R129)',
            desc: 'Nyaste EU-standarden med skärpt sidokrocktest. Vi rankar de säkraste i-Size-stolarna 2026.',
            meta: 'EU-standard · sidokrock',
            anchor: 'Läs om bästa i-Size bilbarnstolen',
            icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            href: '/bilbarnstolar/isofix/',
            name: 'ISOFIX-bilbarnstolar',
            desc: 'Standardiserat fastsystem som minskar felmontering. Vi förklarar och rankar ISOFIX-stolar för varje ålder.',
            meta: 'Installation · säkerhet',
            anchor: 'Läs guiden om ISOFIX bilbarnstol',
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
          },
          {
            href: '/bilbarnstolar/biltestade/',
            name: 'Biltestade (Folksam & Plus Test)',
            desc: 'Stolarna som klarat Folksams svenska krocktest och Plus Test. Högsta nivån av krocktestad säkerhet.',
            meta: 'Folksam · Plus Test',
            anchor: 'Se biltestade bilbarnstolar',
            icon: 'M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z',
          },
          {
            href: '/bilbarnstolar/budget/',
            name: 'Budget under 2 000 kr',
            desc: 'Prisvärda bilbarnstolar som inte kompromissar på krocktest. Så väljer du säkert billigt.',
            meta: 'Pris · värde',
            anchor: 'Se bästa bilbarnstol budget',
            icon: 'M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M12 3v2.25m0 0L8.25 9m3.75-3.75L15.75 9M21 12c0 .414-.336.75-.75.75H3.75A.75.75 0 013 12m18 0V9.75A2.25 2.25 0 0018.75 7.5H5.25A2.25 2.25 0 003 9.75V12m18 0v5.25A2.25 2.25 0 0118.75 19.5H5.25A2.25 2.25 0 013 17.25V12',
          },
          {
            href: '/bilbarnstolar/0-18kg/',
            name: 'Bilbarnstol 0–18 kg',
            desc: 'Stolar som växer med barnet från nyfödd upp till ca 4 år. Vi jämför multibruksstolarnas säkerhet och komfort.',
            meta: '0–4 år · grupp 0+/1',
            anchor: 'Se bästa bilbarnstol 0–18 kg',
            icon: 'M3 3v18h18',
          },
          {
            href: '/bilbarnstolar/prematur/',
            name: 'Bilbarnstol för prematurfödda',
            desc: 'Extra stöd för små och prematurfödda barn. Vi rankar stolar med godkända prematurinlägg.',
            meta: 'Nyfödd · extra stöd',
            anchor: 'Se bilbarnstol för prematurfödda',
            icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
          },
          {
            href: '/bilbarnstolar/resesat/',
            name: 'Resesäten & bilbarnstolar på resa',
            desc: 'Hopfällbara och lätta stolar för flyg och taxi. Vi testar vilka som faktiskt fungerar utan ISOFIX.',
            meta: 'Lätt · hopfällbar',
            anchor: 'Se bästa resesätet',
            icon: 'M12 19l9 2-9-18-9 18 9-2zm0 0v-8',
          },
        ].map((kat) => (
          <a href={kat.href} class="group relative bg-white rounded-2xl p-6 border border-border hover:border-accent hover:shadow-lg transition-all flex flex-col">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4 group-hover:bg-accent group-hover:scale-105 transition-all">
              <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={kat.icon}/>
              </svg>
            </div>
            <div class="text-[10px] font-bold uppercase tracking-wider text-accent mb-1.5">{kat.meta}</div>
            <h3 class="font-heading text-lg font-bold text-primary mb-2 leading-tight group-hover:text-accent transition-colors">{kat.name}</h3>
            <p class="text-sm text-text-light leading-snug flex-1">{kat.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Direkta jämförelser -->
  <section class="py-14 sm:py-16 bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-10">
        <div class="inline-flex items-center gap-2 text-xs font-semibold text-accent uppercase tracking-[0.25em] mb-3">
          <span class="w-8 h-px bg-accent"></span>
          Modell mot modell
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary leading-tight mb-3">Direkta jämförelser</h2>
        <p class="text-text-light leading-relaxed">När du har två konkreta kandidater — så här presterar de sida vid sida enligt vår metodik.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        {[
          ['/bilbarnstolar/britax-dualfix-5z-vs-cybex-sirona-t/', 'Britax Dualfix 5Z', 'Cybex Sirona T', 'Roterande bakåtvänd · premium'],
          ['/bilbarnstolar/maxi-cosi-pebble-360-vs-cybex-cloud-t/', 'Maxi-Cosi Pebble 360', 'Cybex Cloud T', 'Roterande babysits'],
          ['/bilbarnstolar/cybex-cloud-t-vs-britax-baby-safe-isense/', 'Cybex Cloud T', 'Britax Baby-Safe iSense', 'Smarta babysits'],
          ['/bilbarnstolar/joie-i-spin-xl-vs-britax-dualfix-5z/', 'Joie i-Spin XL', 'Britax Dualfix 5Z', 'Lång bakåtvänd kapacitet'],
        ].map(([href, a, b, tag]) => (
          <a href={href} class="group relative bg-bg rounded-2xl p-6 border border-border hover:border-accent hover:shadow-md transition-all">
            <div class="text-[10px] font-bold uppercase tracking-wider text-accent mb-3">{tag}</div>
