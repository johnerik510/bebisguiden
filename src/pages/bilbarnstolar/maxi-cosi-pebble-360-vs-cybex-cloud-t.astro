 <td class="p-3 text-green-700 font-semibold">Ja (75 till 105 cm, ca 3,5 år)</td>
 </tr>
 <tr class="bg-bg-alt/50 border-b border-border">
 <td class="p-3 font-medium text-text">Liggläge (nyfödda)</td>
 <td class="p-3 text-text-light">163°</td>
 <td class="p-3 text-green-700 font-semibold">170° (nästan plant)</td>
 </tr>
 <tr class="border-b border-border">
 <td class="p-3 font-medium text-text">Bugaboo-kompatibel</td>
 <td class="p-3 text-green-700 font-semibold">Ja (med adapter)</td>
 <td class="p-3 text-red-600 font-semibold">Nej</td>
 </tr>
