      <tr class="bg-gray-50"><td class="px-4 py-3 font-medium">Övre centrala framtänder</td><td class="px-4 py-3 text-text-light">8–10 mån</td><td class="px-4 py-3 text-text-light">6–12 mån</td></tr>
      <tr><td class="px-4 py-3 font-medium">Laterala framtänder (övre + nedre)</td><td class="px-4 py-3 text-text-light">9–13 mån</td><td class="px-4 py-3 text-text-light">7–16 mån</td></tr>
