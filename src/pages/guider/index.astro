---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Guider' },
];

const guides = [
  { title: 'Bilbarnstolar – komplett köpguide', href: '/bilbarnstolar/', description: 'Allt du behöver veta om bilbarnstolar: säkerhet, ISOFIX, i-Size och hur du väljer rätt.' },
  { title: 'Bakåtvända bilbarnstolar – test och jämförelse', href: '/bilbarnstolar/bakatvand/', description: 'Vi jämför de bästa bakåtvända bilbarnstolarna 2026. Se vilken som är säkrast för ditt barn.' },
  { title: 'ISOFIX bilbarnstol – komplett guide', href: '/bilbarnstolar/isofix/', description: 'Hur ISOFIX fungerar, vilka bilar som har det och de bästa ISOFIX-stolarna 2026.' },
  { title: 'Barnvagnar – komplett köpguide', href: '/barnvagnar/', description: 'Duovagn, sittvagn eller syskonvagn? Vi hjälper dig välja rätt barnvagn för din familj.' },
  { title: 'Barnvagn till nyfödd – bästa duovagnarna 2026', href: '/barnvagnar/nyfodda/', description: 'Bästa barnvagnar till nyfödd 2026. Vad kräver liggdelen? Emmaljunga, Bugaboo och Joolz jämförda.' },
  { title: 'Duovagn – test och jämförelse 2026', href: '/barnvagnar/duovagn/', description: 'Vi jämför de bästa duovagnarna 2026. Bugaboo, Cybex, Emmaljunga, Joolz och Britax i test.' },
  { title: 'Sittvagn (sulky) – test och jämförelse 2026', href: '/barnvagnar/sittvagn/', description: 'Bästa sittvagnarna och sulkyarna 2026. Lätta, kompakta vagnar för stad och resa.' },
  { title: 'Babyvakter – komplett köpguide', href: '/babyvakter/', description: 'Ljud, video eller WiFi? Jämför funktioner och hitta babyvakten som passar dig.' },
  { title: 'Videobabyvakt – test och jämförelse 2026', href: '/babyvakter/video/', description: 'Vi jämför de bästa videobabyvakterna 2026. Luvion, Motorola och Philips i test.' },
  { title: 'WiFi-babyvakt – test och jämförelse 2026', href: '/babyvakter/wifi/', description: 'Bästa WiFi-babyvakterna 2026. Owlet, Nanit och eufy — övervakning via app.' },
  { title: 'Bärselen – komplett köpguide', href: '/barselen/', description: 'Från nyfödd till större barn. Hitta bärselen med rätt ergonomi och komfort.' },
];
---

<BaseLayout
  title="Guider – Bebisguiden.se"
  description="Kompletta köpguider för barnprodukter. Bilbarnstolar, barnvagnar, babyvakter och mer."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="font-heading text-2xl sm:text-3xl font-bold text-text mt-3 mb-6">Guider</h1>
    <div class="space-y-4">
      {guides.map(guide => (
        <a href={guide.href} class="block bg-white border border-border rounded-xl p-5 hover:shadow-md hover:border-accent transition-all group">
          <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">{guide.title}</h2>
          <p class="text-sm text-text-light mt-1">{guide.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
