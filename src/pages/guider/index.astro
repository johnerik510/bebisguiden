---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Guider' },
];

const guides = [
  { title: 'Regler för bilbarnstol i Sverige April 2026 — lag och krav', href: '/guider/bilbarnstol-regler/', description: 'Komplett guide om regler för bilbarnstol i Sverige 2026. Vad säger lagen? Hur länge bakåtvänt? Vi reder ut alla frågor.' },
  { title: 'Hur länge ska barn åka bakåtvänt? — guide 2026', href: '/guider/bakatvand-hur-lange/', description: 'Hur länge ska ditt barn åka bakåtvänt? Vi förklarar forskningen bakom bakåtvänd körning och ger konkreta råd för varje ålder.' },
  { title: 'Så väljer du rätt bilbarnstol – köpguide 2026', href: '/guider/valja-bilbarnstol/', description: 'ISOFIX eller bältat? i-Size-standard, bakåtvänd körning och vad krocktesterna från Folksam och Plus Test säger.' },
  { title: 'Så väljer du rätt barnvagn – köpguide 2026', href: '/guider/valja-barnvagn/', description: 'Duovagn, sittvagn, terrängvagn eller syskonvagn? Vi hjälper dig sortera igenom alternativen och hitta rätt.' },
  { title: 'Så väljer du rätt babyvakt – köpguide 2026', href: '/guider/valja-babyvakt/', description: 'DECT, video eller WiFi? Vi jämför typerna och hjälper dig hitta rätt babyvakt för ditt hem.' },
  { title: 'Så väljer du rätt bärsele – köpguide 2026', href: '/guider/valja-barsele/', description: 'Mjukbärare, bärsjal eller strukturbärare? Vi förklarar M-positionen och vad som gäller från nyfödd.' },
  { title: 'Så väljer du rätt matstol – köpguide 2026', href: '/guider/valja-matstol/', description: 'Hög matstol, klaffstol eller tillväxtstol? Vi går igenom ergonomi, fotstöd, städvänlighet och säkerhetssele.' },
  { title: 'Bilbarnstolar – komplett köpguide', href: '/bilbarnstolar/', description: 'Allt du behöver veta om bilbarnstolar: säkerhet, ISOFIX, i-Size och hur du väljer rätt.' },
  { title: 'Bakåtvända bilbarnstolar – test och jämförelse', href: '/bilbarnstolar/bakatvand/', description: 'Vi jämför de bästa bakåtvända bilbarnstolarna 2026. Se vilken som är säkrast för ditt barn.' },
  { title: 'ISOFIX bilbarnstol – komplett guide', href: '/bilbarnstolar/isofix/', description: 'Hur ISOFIX fungerar, vilka bilar som har det och de bästa ISOFIX-stolarna 2026.' },
  { title: 'Barnvagnar – komplett köpguide', href: '/barnvagnar/', description: 'Duovagn, sittvagn eller syskonvagn? Vi hjälper dig välja rätt barnvagn för din familj.' },
  { title: 'Barnvagn till nyfödd – bästa duovagnarna 2026', href: '/barnvagnar/nyfodda/', description: 'Bästa barnvagnar till nyfödd 2026. Vad kräver liggdelen? Emmaljunga, Bugaboo och Joolz jämförda.' },
  { title: 'Duovagn – test och jämförelse 2026', href: '/barnvagnar/duovagn/', description: 'Vi jämför de bästa duovagnarna 2026. Bugaboo, Cybex, Emmaljunga, Joolz och Britax i test.' },
  { title: 'Sittvagn (sulky) – test och jämförelse 2026', href: '/barnvagnar/sittvagn/', description: 'Bästa sittvagnarna och sulkyarna 2026. Lätta, kompakta vagnar för stad och resa.' },
  { title: 'Babyvakter – komplett köpguide', href: '/babyvakter/', description: 'Ljud, video eller WiFi? Jämför funktioner och hitta babyvakten som passar dig.' },
  { title: 'Videobabyvakt – test och jämförelse 2026', href: '/babyvakter/video/', description: 'Vi jämför de bästa videobabyvakterna 2026. Luvion, Motorola och Philips i test.' },
  { title: 'WiFi-babyvakt – test och jämförelse 2026', href: '/babyvakter/wifi/', description: 'Bästa WiFi-babyvakterna 2026. Owlet, Nanit och eufy — övervakning via app.' },
  { title: 'Bärselen – komplett köpguide', href: '/barselen/', description: 'Från nyfödd till större barn. Hitta bärselen med rätt ergonomi och komfort.' },
  { title: 'Checklista inför bebis April 2026 – allt du behöver köpa', href: '/guider/bebis-checklista/', description: 'Komplett köplista inför bebisens ankomst. Maste-ha, bra-att-ha och vad du kan vänta med.' },
  { title: 'Säker sovmiljö för bebis – komplett guide 2026', href: '/guider/saker-sovmiljo/', description: 'Vad säger forskningen om SIDS-prevention? Ryggläge, rätt temperatur, rökfri miljö och mer.' },
  { title: 'Bebis sover dåligt – orsaker och lösningar 2026', href: '/guider/bebis-sover-daligt/', description: 'Normala sömnmönster, sömnregressioner (4 månader, 8 månader), sömnträning och konkreta tips för varje ålder.' },
  { title: 'När börjar bebis äta fast föda? – guide 2026', href: '/guider/nar-borjar-bebis-ata/', description: 'Rätt ålder för smakportioner, vilka livsmedel man börjar med, hur man introducerar allergener och vad man ska undvika.' },
  { title: 'Bebis feber – temperatur och när du söker vård 2026', href: '/guider/bebis-feber/', description: 'Vilken temperatur är feber hos bebis? Hur mäter du rätt? När ska du ringa 1177 eller åka till akuten? Komplett guide.' },
  { title: 'Amningstips – guide för nybörjare och vanliga problem', href: '/guider/amning-tips/', description: 'Anläggning, mjölkproduktion, smärta, hur vet du att bebisen får nog — praktiska tips för alla faser av amningen.' },
  { title: 'Bebis kolik – orsaker och vad som hjälper 2026', href: '/guider/bebis-kolik/', description: 'Vad är kolik, hur länge varar det, probiotika (L. reuteri), bärande, och praktiska tips för utmattade föräldrar.' },
  { title: 'Bebis tandsprickning – symtom, timing och vad som hjälper 2026', href: '/guider/bebis-tandsprickning/', description: 'När kommer de första tänderna, vilka symtom som faktiskt beror på tänder (och vilka som inte gör det), och hur du sköter mjölktänderna.' },
  { title: 'Bebis förstoppning – orsaker och vad som hjälper 2026', href: '/guider/bebis-forstoppning/', description: 'Vad som är normalt, tecken på verklig förstoppning, säkra hemmetoder (magmassage, trampcykel) och när du kontaktar BVC.' },
  { title: 'Amma eller ge flaska – för- och nackdelar 2026', href: '/guider/amma-eller-flaska/', description: 'Vad forskningen säger om amning vs. formelmatning, och hur du gör det beslut som passar just din familj.' },
  { title: 'Barnvagn på flyget – regler och tips 2026', href: '/guider/barnvagn-flyg/', description: 'Får du ta med barnvagn gratis? Vilka regler gäller på SAS, Norwegian och Ryanair? Komplett guide.' },
  { title: 'Bebis gulsot – orsaker, symtom och behandling 2026', href: '/guider/bebis-gulsot/', description: 'Vad är fysiologisk och patologisk gulsot? Normala bilirubinnivåer, tecken på allvarlig gulsot, ljusbehandling och amningens roll.' },
  { title: 'Bebis magont – orsaker, symtom och vad som hjälper 2026', href: '/guider/bebis-magont/', description: 'Skillnad på gas, kolik, reflux och allvarligare problem. Säkra hemåtgärder och tydliga tecken på när du söker vård.' },
  { title: 'Öroninflammation hos bebis – symtom, behandling och förebyggande 2026', href: '/guider/bebis-otitis/', description: 'Hur du känner igen öroninflammation hos bebis, när antibiotika behövs, hur amning skyddar och hur du förebygger framtida infektioner.' },
  { title: 'Utslag hos bebis – vad de ser ut, orsaker och vad du ska göra 2026', href: '/guider/bebis-utslag/', description: 'Guide om vanliga och ovanliga utslag hos bebis: glastest för petekier, behandling av eksem och blöjeksem, och tydliga vårdsignaler.' },
];
---

<BaseLayout
  title="Guider – Bebisguiden.se"
  description="Kompletta köpguider för barnprodukter 2026. Bilbarnstolar, barnvagnar, babyvakter, bärselen och spjälsängar — hitta rätt för din bebis."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="font-heading text-2xl sm:text-3xl font-bold text-text mt-3 mb-6">Guider</h1>
    <div class="space-y-4">
      {guides.map(guide => (
        <a href={guide.href} class="block bg-white border border-border rounded-xl p-5 hover:shadow-md hover:border-accent transition-all group">
          <h2 class="font-heading text-lg font-bold text-text group-hover:text-accent transition-colors">{guide.title}</h2>
          <p class="text-sm text-text-light mt-1">{guide.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
