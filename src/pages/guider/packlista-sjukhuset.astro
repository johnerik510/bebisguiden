---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import FAQ from '../../components/FAQ.astro';
import CTABox from '../../components/CTABox.astro';
import RetailerCTAs from '../../components/RetailerCTAs.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Guider', href: '/guider/' },
  { label: 'Packlista sjukhuset' },
];

const faqItems = [
  {
    question: 'När ska jag packa väskan inför förlossningen?',
    answer: 'Packa väskan senast i vecka 36–37 av graviditeten. Prematurfödslar är ovanliga men inte omöjliga — ha väskan redo i god tid. Många väljer att packa redan i vecka 34–35 för att ha ett bekymmer av vägen. Ha väskan stående synlig i hallen eller i bilen, inte gömd i garderoben.',
  },
  {
    question: 'Vad händer om vattnet går hemma?',
    answer: 'Om fostervattnet går hemma, ring förlossningsavdelningen direkt. Det är inte alltid akut — det beror på om värkarbetet kommit igång, färgen på vattnet (klart är bra, grönfärgat kan tyda på att bebisen bajsat i fostervattnet och kräver snabbare åtgärd) och hur det känns i övrigt. Ha telefonnumret till förlossningsavdelningen inlagd i telefonen redan i v. 34.',
  },
  {
    question: 'Vad kostar att föda på sjukhus i Sverige?',
    answer: 'Förlossningsvård ingår i den offentliga sjukvården och finansieras via skatten. Du betalar ordinarie patientavgift (100–200 kr beroende på landsting) per dag. Förlossningsvård och BB-vistelse är avgiftsfritt för mamma. Du kan be om ett rum utan delning (enkelrum) mot eventuell kostnad — det varierar mellan sjukhus.',
  },
  {
    question: 'Behöver jag ta med mat till sjukhuset?',
    answer: 'Sjukhusen serverar mat under BB-vistelsen. Ta ändå med egna snacks, mellanmål och dryck till förlossningen — det är oförutsägbart hur länge det tar och när du hinner äta. Energibars, nötter, frukt och sportdryck är bra att ha. För natten och tidiga morgonen på BB kan egna mellanmål göra stor skillnad.',
  },
  {
    question: 'Måste bilbarnstolen vara installerad innan vi åker hem?',
    answer: 'Ja — det är lagstadgat att barn ska sitta i godkänd bilbarnstol i bil. Sjukhuset får inte skicka hem bebisen i bil utan bilbarnstol. Se till att rätt nyföddbilbarnstol (grupp 0+ eller babyskydd) är inköpt och korrekt installerad i bilen INNAN förlossningsdatumet. Testa installationen i lugn och ro i förväg — inte i sista minuten på parkeringen utanför BB.',
  },
];

export const articleMeta = {
  title: "Packlista sjukhuset förlossning 2026 — komplett checklista",
  description: "Vad ska du ta med till förlossningen? Komplett packlista för mamma, partner och bebis 2026.",
  publishDate: "2026-04-05",
  category: "Guider",
  image: "",
};
---
<ArticleLayout
  title="Packlista sjukhuset förlossning 2026 — komplett checklista"
  description="Vad ska du ta med till förlossningen? Komplett packlista för mamma, partner och bebis 2026."
  breadcrumbs={breadcrumbs}
  canonical="https://bebisguiden.se/guider/packlista-sjukhuset/"
  updatedDate="2026-04-19"
  showDisclaimer={false}
  relatedArticles={[
    { title: 'Bästa bilbarnstolen 2026', href: '/bilbarnstolar/' },
    { title: 'Amning — guide', href: '/amning/' },
    { title: 'Vad behöver en nyfödd?', href: '/guider/vad-behover-nyfodd/' },
    { title: 'Bebis checklista', href: '/guider/bebis-checklista/' },
  ]}
  faqItems={faqItems}
>

<p class="text-base text-text-light mb-6 max-w-2xl">
  Förlossningsväskan bör vara packad senast vecka 36–37. Här är den kompletta checklistan för mamma, partner och bebis — med tips om vad du INTE behöver ta med.
</p>

<div class="bg-accent/10 border border-accent/30 rounded-xl p-4 mb-8">
  <p class="text-sm font-semibold text-accent-dark mb-1">Det viktigaste att ordna i förväg</p>
  <p class="text-sm text-text-light"><strong>Bilbarnstol:</strong> Lagstadgat att ha när ni åker hem. Köp och installera den INNAN förlossningen — inte dagen efter.</p>
</div>

<h2 class="font-heading text-xl font-bold mt-8 mb-4">Checklista mamma</h2>

<h3 class="font-heading text-lg font-semibold mt-4 mb-2">Kläder och underkläder</h3>
<ul class="space-y-1 text-text-light text-sm mb-4">
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Öppen nattskjorta eller nattlinne (för amning) — 2–3 st</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Amnings-BH — 2 st (mjuk, inga spännen mot huden)</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Trosor med hög midja — 5–7 st (bekväma, gärna engångstrosor)</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Bekväma hemkläder/pyjamasbyxor — 2 par</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Morgonrock eller kofta</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Tofflor eller sandaler</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Hemkläder för hemfärd</li>
</ul>

<h3 class="font-heading text-lg font-semibold mt-4 mb-2">Hygien och toalettartiklar</h3>
<ul class="space-y-1 text-text-light text-sm mb-4">
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Tandborste, tandkräm, schampo, duschkräm</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Läppbalsam (torr luft på sjukhus)</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Hårsnodd och hårborste</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Bröstvårtsalva (Lanolin) för amningsstart</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Amningsinlägg — 1 förpackning</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Tjocka bindor (efter förlossning)</li>
</ul>

<h3 class="font-heading text-lg font-semibold mt-4 mb-2">Praktiskt och underhållning</h3>
<ul class="space-y-1 text-text-light text-sm mb-4">
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Telefon och laddare</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Hörlurar</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Snacks: nötter, energibars, frukt, choklad</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Vattenflaska</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Legitimation och <a href="https://www.1177.se/barn--gravid/forlossning/" rel="noopener noreferrer" target="_blank" class="text-accent hover:underline">1177</a>-kort</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Eventuellt födelseplanen (skriven i förväg)</li>
</ul>

<h2 class="font-heading text-xl font-bold mt-8 mb-4">Checklista bebis</h2>
<ul class="space-y-1 text-text-light text-sm mb-6">
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Body/sparkdräkt — 2–3 st (storlek 50–56, nyfödda kan bli 50)</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Sparkbyxor — 2 st</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Mössa (newborn)</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Sockor — 2 par</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Filt eller swaddlefilt</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Blöjor storlek 1 (newborn) — en förpackning</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Våtservetter (milt, utan parfym)</li>
  <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">!</span> <strong>Bilbarnstol — måste finnas i bilen för hemfärd</strong></li>
</ul>

<h2 class="font-heading text-xl font-bold mt-8 mb-4">Checklista partner</h2>
<ul class="space-y-1 text-text-light text-sm mb-6">
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Ombyte kläder för 1–2 nätter</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Toalettartiklar</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Telefon och laddare</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Snacks och energi för en lång natt</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Kamera eller telefon med bra kamera</li>
  <li class="flex items-start gap-2"><span class="text-accent font-bold mt-0.5">+</span> Kontantkortet till p-automaten om ni kör</li>
</ul>

<h2 class="font-heading text-xl font-bold mt-8 mb-3">Vad behöver du INTE ta med?</h2>
<div class="bg-gray-50 rounded-xl p-4 mb-6">
  <ul class="space-y-1 text-text-light text-sm">
    <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">-</span> Mycket smink — du kommer inte ha tid eller ork</li>
    <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">-</span> Flaskuppsättning om du planerar att amma — vänta och se</li>
    <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">-</span> Alla bebisens kläder — ta med ett urval, ni kan hämta mer</li>
    <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">-</span> Badkar och badtillbehör — det finns på BB</li>
    <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">-</span> Stora presenter att öppna på BB — det tar energi ni inte har</li>
  </ul>
</div>

<h2 class="font-heading text-xl font-bold mt-8 mb-3">Bilbarnstol — ordna i förväg</h2>
<div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-6">
  <p class="text-sm text-yellow-900">Det är lagstadgat att bebisen måste sitta i godkänd bilbarnstol för att åka hem från sjukhuset. Sjukhusets personal kontrollerar ibland att ni har en med er. Köp babyskyddet/nyföddbilbarnstolen, installera den korrekt och testa den — INNAN förlossningsdatumet. Läs vår guide om bästa bilbarnstolen för nyfödda.</p>
</div>

<div class="bg-cta/5 border border-cta/20 rounded-xl p-5 my-6 flex flex-col sm:flex-row items-center justify-between gap-4">
  <div>
    <p class="font-heading font-bold text-dark text-base">Bästa bilbarnstolen för nyfödd</p>
    <p class="text-sm text-text-light mt-1">Lagstadgat att ha bilbarnstol när ni åker hem. Se vår guide över bästa nyföddbilbarnstolarna.</p>
  </div>
  <a href="/bilbarnstolar/" class="inline-flex items-center gap-2 bg-cta hover:bg-cta-dark text-white font-bold py-3 px-6 rounded-lg transition-colors text-sm whitespace-nowrap">
    Läs guiden
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
  </a>
</div>

<div class="mt-8 bg-gray-50 rounded-xl p-5">
  <h3 class="font-heading font-semibold text-lg mb-3">Relaterade guider</h3>
  <ul class="space-y-2 text-sm">
    <li><a href="/bilbarnstolar/" class="text-accent hover:underline font-medium">Bästa bilbarnstolen 2026 — nyfödda och uppåt</a></li>
    <li><a href="/amning/" class="text-accent hover:underline font-medium">Amning — komplett guide för nyblivna föräldrar</a></li>
    <li><a href="/guider/vad-behover-nyfodd/" class="text-accent hover:underline font-medium">Vad behöver en nyfödd? — komplett lista</a></li>
    <li><a href="/guider/bebis-checklista/" class="text-accent hover:underline font-medium">Bebis checklista — allt du behöver</a></li>
  </ul>
</div>

<FAQ items={faqItems} />



  <RetailerCTAs heading="Jämför pris hos våra partnerbutiker" compact />
</ArticleLayout>
