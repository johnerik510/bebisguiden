        </tr>
        <tr class="border-t border-gray-200">
          <td class="p-3 font-medium">Mandelolja (söt)</td>
          <td class="p-3">Rik, bra för torr hud</td>
          <td class="p-3 text-yellow-700">Ja, undvik vid nötallergi</td>
        </tr>
        <tr class="border-t border-gray-200 bg-gray-50">
          <td class="p-3 font-medium">Olivolja</td>
          <td class="p-3">Kan störa hudbarriären</td>
          <td class="p-3 text-red-700">Nej, undvik</td>
        </tr>
        <tr class="border-t border-gray-200">
          <td class="p-3 font-medium">Mineraloljor / paraffinolja</td>
          <td class="p-3">Billiga men andas inte</td>
          <td class="p-3 text-red-700">Nej, undvik</td>
        </tr>
        <tr class="border-t border-gray-200 bg-gray-50">
          <td class="p-3 font-medium">Parfymerade babyprodukter</td>
          <td class="p-3">Risk för sensibilisering</td>
          <td class="p-3 text-red-700">Nej, undvik</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="sm:hidden space-y-3">
    {[
      { name: 'Solrosolja (oparfymerad)', desc: 'Linoleinsyrerikt, mjuk, lätt att skölja', ok: true, note: 'Förstaval' },
      { name: 'Kokosolja (extra virgin)', desc: 'Antimikrobiell, mjuk, glider bra', ok: true, note: 'Bra val' },
      { name: 'Mandelolja', desc: 'Bra för torr hud, undvik vid nötallergi', ok: true, note: 'OK med försiktighet' },
      { name: 'Olivolja', desc: 'Kan störa hudbarriären', ok: false, note: 'Undvik' },
      { name: 'Mineraloljor', desc: 'Andas inte, blockerar porer', ok: false, note: 'Undvik' },
    ].map(item => (
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="flex justify-between items-start">
          <span class="font-medium text-sm">{item.name}</span>
          <span class={`text-xs font-semibold ${item.ok ? 'text-green-700' : 'text-red-700'}`}>{item.note}</span>
