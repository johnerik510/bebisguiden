      <tbody>
        <tr class="border-t border-gray-200">
          <td class="p-3 font-medium">Solrosolja (oparfymerad)</td>
          <td class="p-3">Linoleinsyrerikt, mjuk på huden, lätt att skölja</td>
          <td class="p-3 text-green-700">Ja, förstaval</td>
        </tr>
        <tr class="border-t border-gray-200 bg-gray-50">
