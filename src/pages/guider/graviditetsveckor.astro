const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Guider', href: '/guider/' },
  { label: 'Graviditetsveckor' },
];

const faqItems = [
  {
    question: 'Hur räknar man ut hur många veckor gravid man är?',
    answer: 'Graviditeten räknas från den första dagen i din senaste menstruation — inte från befruktningen. En typisk graviditet är 40 veckor (280 dagar). Befruktning sker vanligtvis i vecka 2. Om du vet ditt beräknade förlossningsdatum: räkna bakåt 40 veckor. Du kan också använda 1177:s graviditetskalkylator.',
  },
  {
    question: 'Vad är KUB-testet och när görs det?',
    answer: 'KUB (Kombinerat Ultraljud och Biokemi) är ett kombinerat screeningtest som erbjuds alla gravida i Sverige. Det görs i vecka 11–14 och kombinerar ett ultraljud (mäter nackuppklaring) med ett blodprov. Testet ger en risksannolikhet för kromosomavvikelser som Downs syndrom, trisomi 18 och trisomi 13. Det är frivilligt och ersätts av regionen.',
  },
  {
    question: 'Vad är morfologiundersökning?',
    answer: 'Morfologiundersökning (fosterskanning) är ett detaljerat ultraljud i vecka 18–20 där barnmorskan/ultraljudsläkaren undersöker fostrets anatomiska struktur — hjärna, hjärta, bukorgan, extremiteter och ansiktsbyggnad. Alla gravida erbjuds detta i Sverige. Undersökningen tar 30–60 minuter och kan också avslöja fler foster och fosterrörelser.',
  },
  {
    question: 'Vad är GTT-test och vem behöver det?',
    answer: 'GTT (Glukostoleranstest) är ett test för graviditetsdiabetes som görs i vecka 24–28. Du dricker en sockerhaltig dryck och blodsocker mäts efter 2 timmar. Det erbjuds vid ökad risk: BMI över 30, tidigare graviditetsdiabetes, diabetes i nära familjen, stort foster eller polyhydramnios. Graviditetsdiabetes ökar risken för komplikationer men kan hanteras väl med kost och motion.',
  },
  {
    question: 'Vad händer om bebisen inte kommit i vecka 40?',
    answer: 'Det är helt normalt att föda i vecka 37–42 — "beräknat datum" är ett medelvärde, inte ett exakt datum. I Sverige brukar man erbjuda igångsättning (induktion) runt vecka 41–42 beroende på regionala rutiner och individuella faktorer. Du följs med extra kontroller (NST-test, ultraljud) efter vecka 40. Diskutera med din barnmorska vad som gäller i din region.',
  },
];

export const articleMeta = {
  title: "Graviditetsveckor och trimestrar 2026 — komplett guide",
  description: "Förstå graviditetsveckorna: vad händer varje trimester, viktiga kontroller (KUB, morfologi, GTT) och milstolpar under de 40 veckorna.",
  publishDate: "2026-04-05",
  category: "Guider",
  image: "/images/hero-bebis.webp",
};
---
