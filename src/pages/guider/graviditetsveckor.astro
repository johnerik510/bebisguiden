  description="Förstå graviditetsveckorna: vad händer varje trimester, viktiga kontroller (KUB, morfologi, GTT) och milstolpar under de 40 veckorna."
  breadcrumbs={breadcrumbs}
  canonical="https://bebisguiden.se/guider/graviditetsveckor/"
  updatedDate="2026-04-19"
  showDisclaimer={true}
  relatedArticles={[
    { title: 'Packlista sjukhuset — vad behöver du ta med?', href: '/guider/packlista-sjukhuset/' },
    { title: 'Bästa bilbarnstolen 2026', href: '/bilbarnstolar/' },
