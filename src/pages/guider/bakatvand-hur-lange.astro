const faqItems = [
  {
    question: 'Hur länge ska barn åka bakåtvänt?',
    answer: 'Trafikverket och NTF rekommenderar bakåtvänd körning så länge barnet ryms i stolen — vanligtvis upp till 3–4 års ålder och runt 18–25 kg beroende på stolsmodell. Det finns inget lagkrav på hur länge, men forskningen är tydlig: längre bakåtvänd körning ger bättre skydd.',
