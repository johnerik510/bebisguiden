---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Babyvakter' },
];

const faqItems = [
  {
    question: 'Behovs en babyvakt med video?',
    answer: 'Det beror pa dina behov. En videobabyvakt later dig se barnet utan att ga in i rummet, vilket ar speciellt vaardefullt for nyfodda. Enbart ljud racker for manga familjer med aldre barn som bara behover horas om de vaknar.',
  },
  {
    question: 'Ar WiFi-babyvakter sakra?',
    answer: 'WiFi-babyvakter ar bekvama men har hogre risk for hackning an slutna system (DECT/FHSS). Valj en modell med krypterad anslutning och starka losenord. For hogsta säkerhet, valj en babyvakt med sluten signal som inte gar via internet.',
  },
  {
    question: 'Hur lang räckvidd behover en babyvakt?',
    answer: 'I en vanlig lagenhet racker 50-100 meter. I ett storre hus behovs minst 200-300 meter. Ange alltid räckvidd inomhus -- utomhusräckviddden ar mycket hogre och missvisande. Vaggar och golv minskar räckviddden avsevart.',
  },
];
---

<ArticleLayout
  title="Bästa babyvakten 2026 - Test och jämförelse"
  description="Vi har testat de bästa babyvakterna 2026. Ljud, video och WiFi -- jämför funktioner, räckvidd och pris."
  breadcrumbs={breadcrumbs}
  updatedDate="2026-03-28"
>
  <p class="text-base text-text-light mb-4 max-w-2xl">
    En babyvakt ger trygghet nar barnet sover i ett annat rum. Vi har jamfort ljud-, video- och WiFi-babyvakter for att hjalpa dig valja ratt.
  </p>

  <h2 class="font-heading text-xl font-bold mt-6 mb-4">Vara toppval 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Philips Avent SCD923"
      badge="Bast i test"
      price="2 490 kr"
      rating={4.7}
      pros={['Kristallklart ljud', 'DECT-teknik (ingen WiFi-risk)', 'Lang batteritid']}
      cons={['Enbart ljud (ingen video)', 'Hogre prisklass for ljudvakt']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="#"
    />

    <ProductCard
      name="Luvion Grand Elite 3 Connect Pro"
      badge="Bästa video"
      price="3 290 kr"
      rating={4.6}
      pros={['Stor 4,3-tumsskarm', 'Nattkamera med bra bild', 'Temperaturvisning']}
      cons={['Tyngre foraldraenhet', 'Kort batteritid vid videovisning']}
      ctaText="Se pris hos Babyshop"
      ctaHref="#"
    />

    <ProductCard
      name="Owlet Cam 2"
      badge="Bästa WiFi"
      price="1 990 kr"
      rating={4.4}
      pros={['HD-video via app', 'Tvavagskommunikation', 'Fungerar overallt med internet']}
      cons={['Beroende av WiFi-anslutning', 'Manadskostnad for molnlagring']}
      ctaText="Se pris"
      ctaHref="#"
    />
  </div>

  <div class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold mb-3">Relaterade guider</h2>
    <ul class="space-y-2 text-sm">
      <li>
        <a href="/babyvakter/video/" class="text-accent hover:underline">Bästa videobabyvakten 2026 — test och jämförelse</a>
      </li>
      <li>
        <a href="/babyvakter/wifi/" class="text-accent hover:underline">Bästa WiFi-babyvakten 2026 — test och jämförelse</a>
      </li>
    </ul>
  </div>

  <FAQ items={faqItems} />
</ArticleLayout>
