---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Babyvakter' },
];

const faqItems = [
  {
    question: 'Behövs en babyvakt med video?',
    answer: 'Det beror på dina behov. En videobabyvakt låter dig se barnet utan att gå in i rummet, vilket är speciellt vaardefullt för nyfödda. Enbart ljud räcker för många familjer med äldre barn som bara behöver horas om de vaknar.',
  },
  {
    question: 'Är WiFi-babyvakter sakra?',
    answer: 'WiFi-babyvakter är bekvama men har högre risk for hackning än slutna system (DECT/FHSS). Välj en modell med krypterad anslutning och starka lösenord. För högsta säkerhet, välj en babyvakt med sluten signal som inte gar via internet.',
  },
  {
    question: 'Hur lång räckvidd behöver en babyvakt?',
    answer: 'I en vanlig lägenhet räcker 50-100 meter. I ett större hus behövs minst 200-300 meter. Ange alltid räckvidd inomhus -- utomhusräckviddden är mycket högre och missvisande. Vaggar och golv minskar räckviddden avsevärt.',
  },
];
---

<ArticleLayout
  title="Bästa babyvakten 2026 - Test och jämförelse"
  description="Vi har testat de bästa babyvakterna 2026. Ljud, video och WiFi -- jämför funktioner, räckvidd och pris."
  breadcrumbs={breadcrumbs}
  updatedDate="2026-03-28"
>
  <p class="text-base text-text-light mb-4 max-w-2xl">
    En babyvakt ger trygghet när barnet sover i ett annat rum. Vi har jämfört ljud-, video- och WiFi-babyvakter för att hjälpa dig välja ratt.
  </p>

  <h2 class="font-heading text-xl font-bold mt-6 mb-4">Våra toppval 2026</h2>

  <div class="space-y-4">
    <ProductCard
      name="Philips Avent SCD923"
      badge="Bäst i test"
      price="2 490 kr"
      rating={4.7}
      pros={['Kristallklart ljud', 'DECT-teknik (ingen WiFi-risk)', 'Lång batteritid']}
      cons={['Enbart ljud (ingen video)', 'Högre prisklass for ljudvakt']}
      ctaText="Se pris hos Jollyroom"
      ctaHref="https://www.elgiganten.se/product/personvard-halsa-skonhet/babyprodukter/babyvakt/philips-avent-babymonitor-scd92326/456938"
    />

    <ProductCard
      name="Luvion Grand Elite 3 Connect Pro"
      badge="Bästa video"
      price="3 290 kr"
      rating={4.6}
      pros={['Stor 4,3-tumsskärm', 'Nättkamera med bra bild', 'Temperaturvisning']}
      cons={['Tyngre föräldraenhet', 'Kort batteritid vid videovisning']}
      ctaText="Se pris hos Babyshop"
      ctaHref="https://www.luvion.com/grand-elite-3-connect/"
    />

    <ProductCard
      name="Owlet Cam 2"
      badge="Bästa WiFi"
      price="1 990 kr"
      rating={4.4}
      pros={['HD-video via app', 'Tvåvägskommunikation', 'Fungerår överallt med internet']}
      cons={['Beroende av WiFi-anslutning', 'Månadskostnad for molnlagring']}
      ctaText="Se pris"
      ctaHref="https://www.jollyroom.se/babyprodukter/barnsakerhet/babyvakter/owlet-cam-2-babyvakt-white"
    />
  </div>

  <div class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold mb-3">Relåterade guider</h2>
    <ul class="space-y-2 text-sm">
      <li>
        <a href="/babyvakter/video/" class="text-accent hover:underline">Bästa videobabyvakten 2026 — test och jämförelse</a>
      </li>
      <li>
        <a href="/babyvakter/wifi/" class="text-accent hover:underline">Bästa WiFi-babyvakten 2026 — test och jämförelse</a>
      </li>
    </ul>
  </div>

  <FAQ items={faqItems} />
</ArticleLayout>
