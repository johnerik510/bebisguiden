const breadcrumbs = [
  { label: 'Hem', href: '/' },
  { label: 'Babyvakter', href: '/babyvakter/' },
  { label: 'App' },
];

const products = [
  {
    name: 'Nanit Pro',
    badge: 'Bäst i test',
    price: '3 299 kr',
    rating: 4.8,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'App (iOS/Android)': 'Ja (Nanit)',
      'Live-ström': 'Ja, 1080p',
      'Rörelselarm': 'Ja',
      'Nattseende': 'Ja, IR',
      'Tvåvägsljud': 'Ja',
      'Pris': '3 299 kr',
    },
  },
  {
    name: 'Owlet Cam 2',
    badge: 'Enklast setup',
    price: '1 299 kr',
    rating: 4.5,
