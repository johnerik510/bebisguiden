    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'App (iOS/Android)': 'Ja (Hubble)',
      'Live-ström': 'Ja, 720p',
      'Rörelselarm': 'Ja',
      'Nattseende': 'Ja, IR',
      'Tvåvägsljud': 'Ja',
      'Pris': '1 599 kr',
    },
  },
  {
    name: 'iBaby M7',
    badge: '360° kamera',
    price: '1 799 kr',
    rating: 4.3,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'App (iOS/Android)': 'Ja (iBaby)',
      'Live-ström': 'Ja, 1080p',
      'Rörelselarm': 'Ja',
      'Nattseende': 'Ja, IR',
      'Tvåvägsljud': 'Ja',
      'Pris': '1 799 kr',
    },
  },
  {
    name: 'VTech VM819',
    badge: 'Budgetval',
    price: '1 199 kr',
    rating: 4.2,
    ctaHref: 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
    features: {
      'App (iOS/Android)': 'Ja (MyVTech)',
      'Live-ström': 'Ja, 720p',
      'Rörelselarm': 'Ja',
      'Nattseende': 'Ja, IR',
