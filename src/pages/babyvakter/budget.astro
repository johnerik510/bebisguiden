export const articleMeta = {
  title: "Billig babyvakt bäst i test 2026: DECT från 299 kr",
  description: "Billig babyvakt bäst i test 2026: Vtech DM1111 är vår budgetfavorit. 5 budgetvakter jämförda på räckvidd, batteritid och video, DECT och WiFi, från 299 kr.",
