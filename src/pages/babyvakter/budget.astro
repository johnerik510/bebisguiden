      imageUrl="/images/products/miniland-compact-3-5-video-babyvakt.webp"
      imageAlt="Miniland Compact 3.5 Video Babyvakt"
      store="Jollyroom"
      buyUrl="https://dot.jollyroom.se/t/t?a=1487384677&as=2065068845&t=2&tk=1&cupa_sku=10305054&url=https://www.jollyroom.se/babyprodukter/barnsakerhet/babyvakter/miniland-compact-3-5-video-babyvakt"
      pros={['Video med 3,5-tumsskärm utan WiFi', 'DECT-signal, pålitlig utan internet', 'Kompakt och enkel att ta med på resor']}
