    <h2 class="font-heading text-2xl font-bold text-primary mt-8 mb-6">1. Vtech DM1111, billigast</h2>
    <MoneyProductCard
      brand="VTech"
      name="Vtech DM1111 Babyvakt, Vit"
      rating={4.2}
      rank={1}
