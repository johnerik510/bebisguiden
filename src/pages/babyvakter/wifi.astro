        "description": p.desc || `${p.name} - ${p.badge}. Betyg: ${p.rating}/5.`,
        "brand": { "@type": "Brand", "name": p.brand },
        "review": {
          "@type": "Review",
          "reviewRating": { "@type": "Rating", "ratingValue": p.rating, "bestRating": 5 },
          "author": { "@type": "Person", "name": "Axel Jönemyr", "url": "https://bebisguiden.se/om-redaktionen/" }
        },
        "aggregateRating": { "@type": "AggregateRating", "ratingValue": p.rating, "bestRating": 5, "ratingCount": 1 }
      }
    }))
