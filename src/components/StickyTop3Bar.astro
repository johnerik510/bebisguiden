---
import { resolveMultiCTA } from '../lib/multi-cta';
import { retailerMeta, type Retailer } from '../data/affiliates';

interface Product {
 name: string;
 badge?: string;
 price?: string | number;
 image: string;
 ctaHref?: string;
 brand?: string;
}

interface Props {
 products: Product[];
 max?: number;
}

const { products, max = 3 } = Astro.props;

function detectRetailer(url: string | undefined): Retailer | undefined {
 if (!url) return undefined;
 for (const key of Object.keys(retailerMeta) as Retailer[]) {
  const meta = retailerMeta[key];
  if (url.includes(meta.domain) || url.includes(meta.trackBase.split('?')[0])) return key;
 }
 return undefined;
}

const top = products
 .map((p) => {
  const detected = detectRetailer(p.ctaHref);
  const fallbackStoreName = detected ? retailerMeta[detected].name : undefined;
  const fallback = p.ctaHref && fallbackStoreName ? { store: fallbackStoreName, url: p.ctaHref } : undefined;
  const multi = resolveMultiCTA(p.name, { brand: p.brand, fallback, max: 1 });
  const href = multi?.primary?.url || p.ctaHref;
  return { ...p, resolvedHref: href };
 })
 .filter((p) => p.resolvedHref)
 .slice(0, max);
---

{top.length > 0 && (
 <div
 id="sticky-top3"
 class="fixed left-0 right-0 bottom-0 z-50 bg-white border-t border-border shadow-[0_-4px_12px_rgba(0,0,0,0.08)] md:hidden translate-y-full transition-transform duration-300"
 style="padding-bottom: env(safe-area-inset-bottom, 0px);"
 >
 <div class="flex divide-x divide-border">
 {top.map((p, i) => (
 <a
 href={p.resolvedHref}
 target="_blank"
 rel="nofollow sponsored noopener noreferrer"
 class:list={[
 'flex-1 flex flex-col items-center text-center px-2 py-2.5 no-underline transition-colors active:bg-sand/40',
 i === 0? '!text-cta-dark': '!text-dark',
 ]}
 >
 <span class="text-[10px] font-bold uppercase tracking-wide leading-tight mb-1 line-clamp-1 w-full">
 {p.badge || 'Toppval'}
 </span>
 <img src={p.image} alt="" class="w-9 h-9 object-contain mb-1" loading="lazy" />
 <span class="text-[11px] font-semibold leading-tight line-clamp-1 w-full px-1">{p.name.split(' ').slice(0,3).join(' ')}</span>
 {/* Pris dolt i UI, kvar i data */}
 </a>
 ))}
 </div>
 </div>
)}

<script>
 const bar = document.getElementById('sticky-top3');
 if (bar) {
 let visible = false;
 const show = () => { if (!visible) { visible = true; bar.classList.remove('translate-y-full'); } };
 const hide = () => { if (visible) { visible = false; bar.classList.add('translate-y-full'); } };
 window.addEventListener('scroll', () => {
 if (window.scrollY > 500) show();
 else if (window.scrollY < 250) hide();
 }, { passive: true });
 }
</script>
