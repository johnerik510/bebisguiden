---
import { retailerMeta, sortByCommission, track, defaultRetailers, resolveTarget, type Retailer } from '../data/affiliates';

interface Props {
  name: string;
  image?: string;
  price?: string;
  rating?: number;
  badge?: string;
  pros?: string[];
  cons?: string[];
  ctaText?: string;
  ctaHref?: string;
  ageRange?: string;
  /**
   * Lista av butiker att visa som CTA:er. Default: alla 5 i provisionsordning.
   * Om ctaHref anges exkluderas den butik vars domän matchar ctaHref från sekundärlistan
   * (autodetekteras) så att Jollyroom-produktlänk inte dubbletteras som "Jämför pris hos Jollyroom".
   * Sätt till [] för att dölja sekundära CTA:er helt.
   */
  retailers?: Retailer[];
  /**
   * Valfria deeplink-paths per butik (t.ex. "/barnvagnar" eller fullständig produkt-URL).
   * Om saknas används butikens startsida via tracking-länken.
   */
  retailerPaths?: Partial<Record<Retailer, string>>;
}

const {
  name,
  image,
  price,
  rating,
  badge,
  pros = [],
  cons = [],
  ctaText = 'Se pris',
  ctaHref,
  ageRange,
  retailers = defaultRetailers,
  retailerPaths = {},
} = Astro.props;

// Autodetektera primär retailer från ctaHref så vi inte dubbletterar butiken som sekundär.
function detectRetailer(url: string | undefined): Retailer | undefined {
  if (!url) return undefined;
  for (const key of Object.keys(retailerMeta) as Retailer[]) {
    const meta = retailerMeta[key];
    if (url.includes(meta.domain) || url.includes(meta.trackBase.split('?')[0])) return key;
  }
  return undefined;
}

const detectedPrimary = detectRetailer(ctaHref);
const hasCustomCta = Boolean(ctaHref);
const sortedRetailers = retailers.length > 0 ? sortByCommission(retailers) : [];

// Hitta första retailer som har en resolverbar produkt-URL (inte fallback till sökning)
const firstRetailerWithPath = !hasCustomCta
  ? sortedRetailers.find((r) => resolveTarget(r, retailerPaths[r]) !== null)
  : undefined;
const primaryRetailer = hasCustomCta ? detectedPrimary : firstRetailerWithPath;
const primaryMeta = primaryRetailer ? retailerMeta[primaryRetailer] : null;
const primaryTarget = !hasCustomCta && primaryRetailer
  ? resolveTarget(primaryRetailer, retailerPaths[primaryRetailer])
  : null;

// Primary CTA byggs bara om vi har antingen custom ctaHref eller en retailer med riktig produkt-URL.
// Search-fallback har tagits bort — det är bättre att inte visa CTA än att visa en länk till 0 träffar.
const primaryHref = hasCustomCta
  ? ctaHref!
  : (primaryRetailer && primaryTarget ? track(primaryRetailer, primaryTarget) : null);
// Auto-label: "Se pris hos BUTIK" när butik kan detekteras, annars ctaText.
const primaryLabel = primaryMeta
  ? `Se pris hos ${primaryMeta.name}`
  : (ctaText !== 'Se pris' ? ctaText : 'Se pris');

const secondaryBase = hasCustomCta ? sortedRetailers : sortedRetailers.filter((r) => r !== primaryRetailer);
// Filtrera bort retailers utan resolverbar produkt-URL — annars genereras söklänkar (brutna djuplänkar)
const secondaryRetailers = (detectedPrimary ? secondaryBase.filter((r) => r !== detectedPrimary) : secondaryBase)
  .filter((r) => resolveTarget(r, retailerPaths[r]) !== null);
---

<div class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow overflow-hidden">
  {badge && (
    <div class="px-4 py-2 text-white text-sm font-bold text-center bg-gradient-to-r from-primary to-primary/70">
      {badge}
    </div>
  )}
  <div class="flex flex-col sm:flex-row gap-4 p-4 sm:p-5">
    {image && (
      <div class="w-full sm:w-48 md:w-56 flex-shrink-0 bg-gray-50 rounded-xl p-3 flex items-center justify-center">
        <img src={image} alt={name} class="w-full h-auto max-h-52 rounded-lg object-contain" loading="lazy" width="208" height="208" />
      </div>
    )}
    <div class="flex-1">
      <div class="flex items-start gap-2">
        <h3 class="font-heading text-lg font-bold text-text">{name}</h3>
      </div>
      {ageRange && <p class="text-sm text-text-light mt-1">Alder: {ageRange}</p>}
      <div class="flex items-center gap-4 mt-2">
        {rating && (
          <div class="flex items-center gap-1">
            <span class="text-star font-bold text-sm">{rating}/5</span>
            <div class="flex" role="img" aria-label={`Betyg ${rating} av 5`}>
              {[1,2,3,4,5].map(s => (
                <svg class={`w-4 h-4 ${s <= Math.round(rating) ? 'text-star' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
          </div>
        )}
        {price && <span class="font-bold text-text">{price}</span>}
      </div>
      {(pros.length > 0 || cons.length > 0) && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-3 text-sm">
          {pros.length > 0 && (
            <ul class="space-y-1">
              {pros.map(p => <li class="flex items-start gap-1.5"><span class="text-safe flex-shrink-0">+</span> {p}</li>)}
            </ul>
          )}
          {cons.length > 0 && (
            <ul class="space-y-1">
              {cons.map(c => <li class="flex items-start gap-1.5"><span class="text-accent-dark flex-shrink-0">-</span> {c}</li>)}
            </ul>
          )}
        </div>
      )}
      {primaryHref && (
        <a href={primaryHref} target="_blank" rel="nofollow sponsored noopener noreferrer" class="inline-flex items-center justify-center mt-4 bg-cta text-white font-semibold text-sm px-6 py-3 rounded-lg hover:bg-cta-dark transition-colors min-h-[44px]">
          {primaryLabel}
          <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      )}
      {secondaryRetailers.length > 0 && (
        <div class="mt-3">
          <p class="text-xs text-text-light mb-1.5">Jämför pris hos:</p>
          <div class="flex flex-wrap gap-2">
            {secondaryRetailers.map((r) => {
              const meta = retailerMeta[r];
              const target = resolveTarget(r, retailerPaths[r]);
              if (!target) return null;
              return (
                <a
                  href={track(r, target)}
                  target="_blank"
                  rel="nofollow sponsored noopener noreferrer"
                  class={`${meta.color} text-white text-xs font-semibold px-3 py-1.5 rounded-md transition-colors`}
                  aria-label={`Se pris hos ${meta.name}`}
                >
                  {meta.name}
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </div>
</div>
