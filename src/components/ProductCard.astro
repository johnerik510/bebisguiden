---
interface Props {
  name: string;
  image?: string;
  price?: string;
  rating?: number;
  badge?: string;
  pros?: string[];
  cons?: string[];
  ctaText?: string;
  ctaHref?: string;
  ageRange?: string;
}

const {
  name,
  image,
  price,
  rating,
  badge,
  pros = [],
  cons = [],
  ctaText = 'Se pris',
  ctaHref = '#',
  ageRange,
} = Astro.props;
---

<div class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow overflow-hidden">
  {badge && (
    <div class="px-4 py-2 text-white text-sm font-bold text-center bg-gradient-to-r from-primary to-primary/70">
      {badge}
    </div>
  )}
  <div class="flex flex-col sm:flex-row gap-4 p-4 sm:p-5">
    {image && (
      <div class="w-full sm:w-72 md:w-80 flex-shrink-0 bg-gray-50 rounded-xl p-3 flex items-center justify-center">
        <img src={image} alt={name} class="w-full h-auto max-h-80 rounded-lg object-contain" loading="lazy" />
      </div>
    )}
    <div class="flex-1">
      <div class="flex items-start gap-2">
        <h3 class="font-heading text-lg font-bold text-text">{name}</h3>
      </div>
      {ageRange && <p class="text-sm text-text-light mt-1">Alder: {ageRange}</p>}
      <div class="flex items-center gap-4 mt-2">
        {rating && (
          <div class="flex items-center gap-1">
            <span class="text-star font-bold text-sm">{rating}/5</span>
            <div class="flex" aria-label={`Betyg ${rating} av 5`}>
              {[1,2,3,4,5].map(s => (
                <svg class={`w-4 h-4 ${s <= Math.round(rating) ? 'text-star' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
          </div>
        )}
        {price && <span class="font-bold text-text">{price}</span>}
      </div>
      {(pros.length > 0 || cons.length > 0) && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-3 text-sm">
          {pros.length > 0 && (
            <ul class="space-y-1">
              {pros.map(p => <li class="flex items-start gap-1.5"><span class="text-safe flex-shrink-0">+</span> {p}</li>)}
            </ul>
          )}
          {cons.length > 0 && (
            <ul class="space-y-1">
              {cons.map(c => <li class="flex items-start gap-1.5"><span class="text-accent-dark flex-shrink-0">-</span> {c}</li>)}
            </ul>
          )}
        </div>
      )}
      <a href={ctaHref} target="_blank" rel="sponsored noopener noreferrer" class="inline-flex items-center justify-center mt-4 bg-cta text-white font-semibold text-sm px-6 py-3 rounded-lg hover:bg-cta-dark transition-colors min-h-[44px]">
        {ctaText}
        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</div>
