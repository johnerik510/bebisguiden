---
interface Props {
 name: string;
 image?: string;
 price?: string;
 rating?: number;
 badge?: string;
 pros?: string[];
 cons?: string[];
 ctaText?: string;
 ctaHref?: string;
 ageRange?: string;
 /** Explicita "Även hos"-länkar, måste komma från feed eller verified-links */
 additionalCtaHrefs?: { store: string; url: string }[];
 /** Legacy-props, ignoreras */
 brand?: string;
}

const {
 name,
 image,
 rating,
 badge,
 pros = [],
 cons = [],
 ctaText,
 ctaHref,
 ageRange,
 additionalCtaHrefs = [],
} = Astro.props;

const primaryHref = ctaHref;
const primaryLabel = ctaText ?? 'Se pris';
---

<div class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow overflow-hidden">
 {badge && (
 <div class="px-4 py-2 text-white text-sm font-bold text-center bg-gradient-to-r from-primary to-primary/70">
 {badge}
 </div>
 )}
 <div class="flex flex-col sm:flex-row gap-4 p-4 sm:p-5">
 {image && (
 <div class="w-full sm:w-48 md:w-56 flex-shrink-0 bg-gray-50 rounded-xl p-3 flex items-center justify-center">
 {primaryHref ? (
 <a href={primaryHref} target="_blank" rel="nofollow sponsored noopener noreferrer" aria-label={`Bra pris hos ${name}`} class="block w-full h-full">
 <img src={image} alt={name} class="w-full h-auto max-h-52 rounded-lg object-contain" loading="lazy" width="208" height="208" />
 </a>
 ) : (
 <img src={image} alt={name} class="w-full h-auto max-h-52 rounded-lg object-contain" loading="lazy" width="208" height="208" />
 )}
 </div>
 )}
 <div class="flex-1 min-w-0">
 <div class="flex items-start gap-2">
 <h3 class="font-heading text-lg font-bold text-text">
 {primaryHref ? (
 <a href={primaryHref} target="_blank" rel="nofollow sponsored noopener noreferrer" class="!text-text hover:!text-accent-dark transition-colors no-underline">{name}</a>
 ) : (
 name
 )}
 </h3>
 </div>
 {ageRange && <p class="text-sm text-text-light mt-1">Ålder: {ageRange}</p>}
 <div class="flex items-center gap-4 mt-2">
 {rating && (
 <div class="flex items-center gap-1">
 <span class="text-star font-bold text-sm">{rating}/5</span>
 <div class="flex" role="img" aria-label={`Betyg ${rating} av 5`}>
 {[1,2,3,4,5].map(s => (
 <svg class={`w-4 h-4 ${s <= Math.round(rating) ? 'text-star' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
 <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
 </svg>
 ))}
 </div>
 </div>
 )}
 {/* Pris dolt i UI, kvar i schema/data */}
 </div>
 {(pros.length > 0 || cons.length > 0) && (
 <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-3 text-sm">
 {pros.length > 0 && (
 <ul class="space-y-1">
 {pros.map(p => <li class="flex items-start gap-1.5"><span class="text-accent-dark flex-shrink-0">+</span> {p}</li>)}
 </ul>
 )}
 {cons.length > 0 && (
 <ul class="space-y-1">
 {cons.map(c => <li class="flex items-start gap-1.5"><span class="text-accent-dark flex-shrink-0">-</span> {c}</li>)}
 </ul>
 )}
 </div>
 )}
 {primaryHref && (
 <div class="mt-4">
 <span class="block text-xs font-semibold text-text-light mb-1">Bra pris hos:</span>
 <a href={primaryHref} target="_blank" rel="nofollow sponsored noopener noreferrer" class="relative flex w-full items-center justify-center bg-cta text-white font-bold text-base px-7 py-4 rounded-lg hover:bg-cta-dark transition-colors min-h-[56px]">
 <span class="absolute -top-2 right-3 inline-block bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full shadow-sm">Redaktionens val</span>
 {primaryLabel}
 <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
 </a>
 </div>
 )}
 {additionalCtaHrefs.length > 0 && (
 <div class="flex flex-wrap items-center gap-2 mt-1">
 <span class="text-xs font-semibold text-text-light uppercase tracking-wide">Även hos:</span>
 {additionalCtaHrefs.map((o) => (
 <a href={o.url} rel="nofollow sponsored noopener noreferrer" target="_blank"
 class="inline-flex items-center px-3 py-1.5 rounded-lg border border-border text-xs font-semibold text-text-light hover:border-primary hover:text-primary transition-colors">
 {o.store}
 </a>
 ))}
 </div>
 )}
 </div>
 </div>
</div>
