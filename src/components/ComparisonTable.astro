---
import { resolveMultiCTA } from '../lib/multi-cta';
import { retailerMeta, type Retailer } from '../data/affiliates';

interface Product {
 name: string;
 image?: string;
 price?: string;
 rating?: number;
 badge?: string;
 ctaHref?: string;
 features: Record<string, string>;
 /** Märke , används för att hitta alla butiker som säljer det via feed. */
 brand?: string;
 /** Legacy-prop, ignoreras av multi-CTA men kvar för bakåtkompat. */
 retailers?: Retailer[];
 /** Legacy-prop, ignoreras av multi-CTA men kvar för bakåtkompat. */
 retailerPaths?: Partial<Record<Retailer, string>>;
}

interface Props {
 products: Product[];
 featureLabels: string[];
}

const { products: rawProducts, featureLabels } = Astro.props;

function detectRetailer(url: string | undefined): Retailer | undefined {
 if (!url) return undefined;
 for (const key of Object.keys(retailerMeta) as Retailer[]) {
  const meta = retailerMeta[key];
  if (url.includes(meta.domain) || url.includes(meta.trackBase.split('?')[0])) return key;
 }
 return undefined;
}

// Multi-CTA per produkt: primary = högst commission, others sorterade efter commission desc
const products = rawProducts.map((p) => {
 const detected = detectRetailer(p.ctaHref);
 const fallbackStore = detected ? retailerMeta[detected].name : undefined;
 const fallback = p.ctaHref && fallbackStore ? { store: fallbackStore, url: p.ctaHref } : undefined;
 const multi = resolveMultiCTA(p.name, { brand: p.brand, fallback, max: 4 });
 return {
  ...p,
  primary: multi?.primary,
  others: multi?.others ?? [],
 };
});
---

{/* Mobile: stacked product cards */}
<div class="md:hidden space-y-3 mb-6">
 {products.map(p => (
 <div class="bg-white rounded-xl border border-border overflow-hidden">
 {p.badge && (
 <div class="bg-accent/10 px-4 py-1.5 border-b border-accent/20">
 <span class="text-xs font-bold text-accent-dark uppercase tracking-wide">{p.badge}</span>
 </div>
 )}
 <div class="p-4">
 {p.image && (
 <div class="bg-gray-50 rounded-lg p-3 mb-3 flex items-center justify-center">
 <img src={p.image} alt={p.name} class="max-h-40 w-auto object-contain" loading="lazy" width="200" height="160" />
 </div>
 )}
 <div class="flex items-start justify-between gap-3 mb-3">
 <h3 class="font-semibold text-text text-sm leading-snug">{p.name}</h3>
 {p.rating && <span class="text-star font-bold text-sm whitespace-nowrap">{p.rating}/5</span>}
 </div>
 {p.price && (
 <p class="text-lg font-bold text-text mb-3">{p.price}</p>
 )}
 <dl class="space-y-1.5 mb-4">
 {featureLabels.map(label => (
 <div class="flex justify-between gap-2 text-sm">
 <dt class="text-text-light">{label}</dt>
 <dd class="font-medium text-text text-right">{p.features[label] || '-'}</dd>
 </div>
 ))}
 </dl>
 {p.primary && (
 <a href={p.primary.url} target="_blank" rel="nofollow sponsored noopener noreferrer"
 class="flex items-center justify-center gap-1.5 w-full bg-cta text-white font-semibold text-sm py-3 rounded-lg hover:bg-cta-dark transition-colors min-h-[44px]">
 Se pris hos {p.primary.store}
 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
 </a>
 )}
 {p.others.length > 0 && (
 <div class="mt-2.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-text-light">
 <span class="font-semibold uppercase tracking-wide">Även hos:</span>
 {p.others.map((o, i) => (
 <>
 <a href={o.url} rel="nofollow sponsored noopener noreferrer" target="_blank"
 class="hover:text-accent-dark underline decoration-dotted underline-offset-4">
 {o.store}
 </a>
 {i < p.others.length - 1 && <span class="text-text-light/50">·</span>}
 </>
 ))}
 </div>
 )}
 </div>
 </div>
 ))}
</div>

{/* Desktop: full comparison table */}
<div class="hidden md:block mb-6">
 <table class="w-full border-collapse bg-white rounded-xl border border-border text-sm">
 <thead>
 <tr class="bg-bg-alt">
 <th class="text-left p-3 font-semibold text-text min-w-[120px]">Produkt</th>
 {products.map(p => (
 <th class="text-center p-3 font-semibold text-text min-w-[160px] align-bottom">
 {p.image && (
 <div class="bg-gray-50 rounded-lg p-2 mb-2 flex items-center justify-center mx-auto" style="height: 130px;">
 <img src={p.image} alt={p.name} class="max-h-28 w-auto object-contain" loading="lazy" width="160" height="120" />
 </div>
 )}
 {p.badge && <span class="block text-xs text-accent-dark font-bold mb-1">{p.badge}</span>}
 <span class="block leading-snug">{p.name}</span>
 </th>
 ))}
 </tr>
 </thead>
 <tbody>
 {products.some(p => p.price) && (
 <tr class="border-t border-border">
 <td class="p-3 font-medium text-text-light">Pris</td>
 {products.map(p => <td class="p-3 text-center font-bold">{p.price || '-'}</td>)}
 </tr>
 )}
 <tr class="border-t border-border bg-bg-alt/50">
 <td class="p-3 font-medium text-text-light">Betyg</td>
 {products.map(p => <td class="p-3 text-center font-bold text-star">{p.rating ? `${p.rating}/5` : '-'}</td>)}
 </tr>
 {featureLabels.map((label, i) => (
 <tr class={`border-t border-border ${i % 2 === 0 ? '' : 'bg-bg-alt/50'}`}>
 <td class={`p-3 font-medium text-text-light`}>{label}</td>
 {products.map(p => <td class="p-3 text-center">{p.features[label] || '-'}</td>)}
 </tr>
 ))}
 <tr class="border-t border-border">
 <td class="p-3"></td>
 {products.map(p => (
 <td class="p-3 text-center align-top">
 {p.primary && (
 <a href={p.primary.url} target="_blank" rel="nofollow sponsored noopener noreferrer"
 class="inline-flex items-center justify-center gap-1 bg-cta text-white font-bold text-sm px-5 py-3 rounded-lg hover:bg-cta-dark transition-colors min-h-[48px]">
 Se pris hos {p.primary.store}
 <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
 </a>
 )}
 {p.others.length > 0 && (
 <div class="mt-2 text-xs text-text-light leading-relaxed">
 <span class="font-semibold">Även hos:</span>{' '}
 {p.others.map((o, i) => (
 <>
 <a href={o.url} rel="nofollow sponsored noopener noreferrer" target="_blank"
 class="hover:text-accent-dark underline decoration-dotted underline-offset-4">
 {o.store}
 </a>
 {i < p.others.length - 1 && <span class="text-text-light/50">{' · '}</span>}
 </>
 ))}
 </div>
 )}
 </td>
 ))}
 </tr>
 </tbody>
 </table>
</div>
