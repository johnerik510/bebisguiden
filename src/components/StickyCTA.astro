---
interface Props {
  text?: string;
  href: string;
  productName?: string;
}

const { text = 'Se basta pris', href, productName } = Astro.props;
---

<div class="fixed bottom-0 inset-x-0 z-50 md:hidden bg-white border-t border-border shadow-lg p-3">
  <a href={href} target="_blank" rel="sponsored noopener" class="flex items-center justify-center w-full bg-cta text-white font-bold text-sm py-3.5 rounded-lg hover:bg-cta-dark transition-colors min-h-[44px]">
    {text}
    {productName && <span class="ml-1.5 font-normal opacity-90">- {productName}</span>}
    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
  </a>
</div>
