---
interface Props {
  text?: string;
  href: string;
  productName?: string;
}

const { text = 'Se bästa pris', href } = Astro.props;
---

<div class="fixed bottom-0 inset-x-0 z-50 md:hidden bg-white border-t border-border shadow-lg px-4 py-3">
  <a href={href} target="_blank" rel="nofollow sponsored noopener noreferrer"
     class="flex items-center justify-center w-full bg-cta text-white font-bold text-sm py-3.5 rounded-lg hover:bg-cta-dark transition-colors min-h-[44px]">
    {text}
    <svg class="w-4 h-4 ml-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
  </a>
</div>
