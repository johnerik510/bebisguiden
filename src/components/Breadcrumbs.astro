---
interface Props {
 items: { label: string; href?: string }[];
}

const { items } = Astro.props;
const jsonLd = {
 "@context": "https://schema.org",
 "@type": "BreadcrumbList",
 "itemListElement": items.map((item, i) => ({
 "@type": "ListItem",
 "position": i + 1,
 "name": item.label,
...(item.href? { "item": `https://bebisguiden.se${item.href}` }: {}),
 })),
};
---

<nav aria-label="Brödsmulor" class="text-sm text-text-light overflow-hidden">
 <ol class="whitespace-nowrap overflow-hidden text-ellipsis">
 {items.map((item, i) => (
 <li class="inline">
 {i > 0 && <span class="mx-0.5" aria-hidden="true">/</span>}
 {item.href? (
 <a href={item.href} class="hover:text-accent transition-colors">{item.label}</a>
 ): (
 <span aria-current="page">{item.label}</span>
 )}
 </li>
 ))}
 </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
