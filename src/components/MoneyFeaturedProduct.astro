---
/**
 * Featured-block för redaktionens topp-rekommendation på money pages.
 * Trogen port av tillskottsguidens HSNGFeaturedProduct (money page-mallen),
 * tematiserad till bebisguiden och utan resolveMultiCTA-beroende: sidan
 * skickar in primary-URL + ev. alsoAt-butiker direkt (verifierade feeds).
 */
interface AlsoAt {
  store: string;
  url: string;
}

interface Props {
  brand: string;
  name: string;
  price?: string;
  image: string;
  imageAlt?: string;
  trackedUrl: string;
  store: string;
  description: string;
  badge?: string;
  alsoAt?: AlsoAt[];
}

const {
  brand,
  name,
  price = '',
  image,
  imageAlt,
  trackedUrl,
  store,
  description,
  badge = 'Redaktionens val',
  alsoAt = [],
} = Astro.props;
---

<div class="not-prose my-6 bg-gradient-to-br from-accent-light/10 via-white to-accent-light/5 border-2 border-accent rounded-2xl p-5 sm:p-6 shadow-md relative overflow-hidden">
  <div class="absolute top-0 right-0 bg-accent text-white text-[10px] sm:text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-bl-xl">
    {badge}
  </div>
  <div class="flex flex-col sm:flex-row gap-4 sm:gap-5">
    <div class="flex-shrink-0 mx-auto sm:mx-0">
      <a href={trackedUrl} rel="nofollow sponsored noopener noreferrer" target="_blank" class="block w-32 h-32 sm:w-36 sm:h-36 rounded-xl bg-white shadow-sm overflow-hidden">
        <img
          src={image}
          alt={imageAlt || `${brand} ${name}`}
          loading="eager"
          width="144"
          height="144"
          class="w-full h-full object-contain p-2"
        />
      </a>
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-xs font-semibold text-accent-dark uppercase tracking-wide mb-1">{brand}</p>
      <h2 class="font-heading text-lg sm:text-xl font-bold text-text leading-tight mb-2">
        <a href={trackedUrl} rel="nofollow sponsored noopener noreferrer" target="_blank" class="!text-text hover:!text-accent-dark transition-colors no-underline">{name}</a>
      </h2>
      <p class="text-sm text-text-light leading-relaxed mb-3">{description}</p>
      <div class="flex flex-wrap items-center gap-3">
        {price && <span class="text-xl font-heading font-bold text-text">{price}</span>}
        <div class="w-full">
          <span class="block text-xs font-semibold text-text-light mb-1">Bra pris hos:</span>
          <a
            href={trackedUrl}
            rel="nofollow sponsored noopener noreferrer"
            target="_blank"
            data-product={name}
            class="inline-flex w-full items-center justify-center gap-2 px-5 py-3 bg-cta hover:bg-cta-dark text-white font-bold text-base rounded-lg transition-colors shadow-sm no-underline"
          >
            Bra pris hos {store}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        </div>
      </div>
      {alsoAt.length > 0 && (
      <div class="flex flex-wrap items-center gap-2 mt-3">
        <span class="text-xs font-semibold text-text-light">Även hos:</span>
        {alsoAt.map((o) => (
        <a
          href={o.url}
          rel="nofollow sponsored noopener noreferrer"
          target="_blank"
          class="inline-flex items-center px-3 py-1.5 rounded-lg bg-white border border-border text-xs font-semibold text-text-light hover:border-accent-dark hover:text-accent-dark transition-colors no-underline"
        >
          {o.store}
        </a>
        ))}
      </div>
      )}
    </div>
  </div>
</div>
