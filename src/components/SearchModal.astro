---
---

<dialog
  id="search-dialog"
  class="fixed inset-0 z-[200] m-0 max-w-none max-h-none w-full h-full bg-transparent p-0 border-0"
  aria-label="Sök på Bebisguiden"
>
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="search-backdrop"></div>

  <div class="relative z-10 flex flex-col items-center pt-16 sm:pt-24 px-4 min-h-full">
    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden">

      <!-- Search input -->
      <div class="flex items-center gap-3 px-4 py-3.5 border-b border-gray-100">
        <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Sök produkter, guider, kategorier..."
          class="flex-1 text-base text-gray-900 placeholder:text-gray-400 bg-transparent outline-none min-w-0"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
        />
        <button
          id="search-close-btn"
          class="text-xs text-gray-500 border border-gray-200 rounded-md px-2 py-1 hover:bg-gray-50 transition-colors flex-shrink-0 hidden sm:block"
          aria-label="Stäng sök"
        >
          Esc
        </button>
        <button
          id="search-close-mobile"
          class="sm:hidden p-1 text-gray-500 hover:text-gray-800 transition-colors"
          aria-label="Stäng sök"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Results list -->
      <ul
        id="search-results"
        role="listbox"
        aria-label="Sökresultat"
        class="max-h-[60vh] overflow-y-auto divide-y divide-gray-50 hidden"
      ></ul>

      <!-- No results -->
      <div id="search-no-results" class="hidden py-10 text-center text-gray-400 text-sm">
        <svg class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        Inga resultat hittades
      </div>

      <!-- Initial state: popular searches -->
      <div id="search-initial" class="py-4 px-4">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Populart</p>
        <div class="flex flex-wrap gap-2">
          {[
            { label: 'Bilbarnstolar', url: '/bilbarnstolar/' },
            { label: 'Barnvagnar', url: '/barnvagnar/' },
            { label: 'Babyvakter', url: '/babyvakter/' },
            { label: 'Matstolar', url: '/matstolar/' },
            { label: 'Bröstpumpar', url: '/amning/brostpump/' },
            { label: 'Blöjor', url: '/blojor/' },
            { label: 'Sövsäckar', url: '/sovsackar/' },
            { label: 'Guider', url: '/guider/' },
          ].map(s => (
            <a
              href={s.url}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-50 hover:bg-accent hover:text-white text-gray-700 text-sm rounded-lg transition-colors border border-gray-100 hover:border-accent"
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Footer hint -->
      <div class="border-t border-gray-100 px-4 py-2.5 flex items-center gap-4 text-xs text-gray-400">
        <span class="flex items-center gap-1">
          <kbd class="border border-gray-200 rounded px-1 py-0.5 font-mono text-gray-500">↵</kbd>
          <span>Navigera</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="border border-gray-200 rounded px-1 py-0.5 font-mono text-gray-500">↑↓</kbd>
          <span>Bläddra</span>
        </span>
        <span class="flex items-center gap-1 ml-auto">
          <kbd class="border border-gray-200 rounded px-1 py-0.5 font-mono text-gray-500">Esc</kbd>
          <span>Stäng</span>
        </span>
      </div>
    </div>
  </div>
</dialog>

<script>
(function () {
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const resultsList = document.getElementById('search-results') as HTMLUListElement | null;
  const noResults = document.getElementById('search-no-results') as HTMLElement | null;
  const initialView = document.getElementById('search-initial') as HTMLElement | null;
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close-btn');
  const closeMobile = document.getElementById('search-close-mobile');

  let index: Array<{ title: string; description: string; url: string; category: string }> | null = null;
  let activeIdx = -1;

  function openSearch() {
    if (!dialog) return;
    dialog.showModal();
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 50);
    if (!index) loadIndex();
  }

  function closeSearch() {
    if (!dialog) return;
    dialog.close();
    document.body.style.overflow = '';
    if (input) input.value = '';
    showInitial();
    activeIdx = -1;
  }

  async function loadIndex() {
    try {
      const res = await fetch('/search-index.json');
      index = await res.json();
    } catch {
      index = [];
    }
  }

  function showInitial() {
    resultsList?.classList.add('hidden');
    noResults?.classList.add('hidden');
    if (initialView) initialView.style.display = '';
  }

  function showResults(items: typeof index) {
    if (!resultsList || !items) return;
    if (initialView) initialView.style.display = 'none';

    if (items.length === 0) {
      resultsList.classList.add('hidden');
      noResults?.classList.remove('hidden');
      return;
    }

    noResults?.classList.add('hidden');
    resultsList.classList.remove('hidden');
    resultsList.innerHTML = items
      .map((item, i) => `
        <li role="option" aria-selected="false" data-idx="${i}">
          <a
            href="${item.url}"
            class="result-link flex items-start gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group"
            data-idx="${i}"
          >
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                ${item.category === 'Kategori'
                  ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>'
                  : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>'}
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors truncate">${escHtml(item.title)}</div>
              <div class="text-xs text-gray-500 mt-0.5 line-clamp-1">${escHtml(item.description)}</div>
            </div>
            ${item.category ? `<span class="flex-shrink-0 text-xs text-gray-400 bg-gray-100 rounded-full px-2 py-0.5 self-center">${escHtml(item.category)}</span>` : ''}
          </a>
        </li>
      `)
      .join('');
    activeIdx = -1;
  }

  function escHtml(str: string) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function search(query: string) {
    if (!query.trim()) { showInitial(); return; }
    if (!index) { showResults([]); return; }

    const words = query.toLowerCase().trim().split(/\s+/).filter(Boolean);

    const scored = index
      .map(item => {
        const titleLow = item.title.toLowerCase();
        const descLow = item.description.toLowerCase();
        const catLow = item.category.toLowerCase();
        let score = 0;
        for (const w of words) {
          if (titleLow.includes(w)) score += 3;
          if (catLow.includes(w)) score += 2;
          if (descLow.includes(w)) score += 1;
        }
        return { item, score };
      })
      .filter(x => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 8)
      .map(x => x.item);

    showResults(scored);
  }

  function setActive(idx: number) {
    const items = resultsList?.querySelectorAll('.result-link');
    if (!items || items.length === 0) return;
    items.forEach((el, i) => {
      el.closest('li')?.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      if (i === idx) {
        el.classList.add('bg-gray-50');
        el.scrollIntoView({ block: 'nearest' });
      } else {
        el.classList.remove('bg-gray-50');
      }
    });
    activeIdx = idx;
  }

  // Event handlers
  input?.addEventListener('input', (e) => {
    search((e.target as HTMLInputElement).value);
    activeIdx = -1;
  });

  input?.addEventListener('keydown', (e) => {
    const items = resultsList?.querySelectorAll('.result-link');
    const count = items?.length ?? 0;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, count - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIdx - 1, 0));
    } else if (e.key === 'Enter' && activeIdx >= 0 && items) {
      e.preventDefault();
      (items[activeIdx] as HTMLAnchorElement).click();
    } else if (e.key === 'Escape') {
      closeSearch();
    }
  });

  backdrop?.addEventListener('click', closeSearch);
  closeBtn?.addEventListener('click', closeSearch);
  closeMobile?.addEventListener('click', closeSearch);

  dialog?.addEventListener('close', () => {
    document.body.style.overflow = '';
    if (input) input.value = '';
    showInitial();
    activeIdx = -1;
  });

  // Global keyboard shortcut Cmd+K / Ctrl+K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (dialog?.open) closeSearch(); else openSearch();
    }
    if (e.key === 'Escape' && dialog?.open) closeSearch();
  });

  // Expose open function globally so header buttons can call it
  (window as any).openBebisSearch = openSearch;
})();
</script>

<style>
  #search-dialog::backdrop {
    background: transparent;
  }
  .line-clamp-1 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }
</style>
