---
interface Offer {
  price: number;
  currency?: string;
  url: string;
  availability?: string;
  seller?: string;
}

interface ProductItem {
  name: string;
  description?: string;
  image?: string;
  brand?: string;
  ratingValue?: number;
  reviewCount?: number;
  reviewBody?: string;
  offers?: Offer[];
}

interface Props {
  products: ProductItem[];
}

const { products } = Astro.props;

const shippingDetails = {
  "@type": "OfferShippingDetails",
  "shippingRate": {
    "@type": "MonetaryAmount",
    "value": "0",
    "currency": "SEK",
  },
  "shippingDestination": {
    "@type": "DefinedRegion",
    "addressCountry": "SE",
  },
  "deliveryTime": {
    "@type": "ShippingDeliveryTime",
    "handlingTime": {
      "@type": "QuantitativeValue",
      "minValue": 1,
      "maxValue": 3,
      "unitCode": "DAY",
    },
    "transitTime": {
      "@type": "QuantitativeValue",
      "minValue": 1,
      "maxValue": 5,
      "unitCode": "DAY",
    },
  },
};

const merchantReturnPolicy = {
  "@type": "MerchantReturnPolicy",
  "applicableCountry": "SE",
  "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
  "merchantReturnDays": 30,
  "returnMethod": "https://schema.org/ReturnByMail",
  "returnFees": "https://schema.org/FreeReturn",
};

const buildOffer = (offer: Offer) => ({
  "@type": "Offer",
  "priceCurrency": offer.currency || "SEK",
  "price": offer.price,
  "url": offer.url,
  "availability": offer.availability || "https://schema.org/InStock",
  "shippingDetails": shippingDetails,
  "hasMerchantReturnPolicy": merchantReturnPolicy,
  ...(offer.seller ? {
    "seller": {
      "@type": "Organization",
      "name": offer.seller,
    },
  } : {}),
});

const schemas = products.map((product) => ({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description || product.name,
  "image": product.image || `https://bebisguiden.se/og-default.png`,
  "brand": {
    "@type": "Brand",
    "name": product.brand || "Okänt",
  },
  ...(product.ratingValue ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": product.ratingValue,
      "bestRating": 5,
      "worstRating": 1,
      "reviewCount": product.reviewCount || 1,
    },
  } : {}),
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": product.ratingValue || 4,
      "bestRating": 5,
    },
    "author": {
      "@type": "Organization",
      "name": "Bebisguiden",
    },
    ...(product.reviewBody ? { "reviewBody": product.reviewBody } : {}),
  },
  ...(product.offers && product.offers.length > 0 ? {
    "offers": product.offers.length === 1
      ? buildOffer(product.offers[0])
      : product.offers.map(buildOffer),
  } : {}),
}));
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
