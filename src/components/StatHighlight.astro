---
/**
 * StatHighlight - GEO/AEO-komponent för verifierad statistik med källhänvisning.
 * Används för att lyfta fram nyckeltal med princetonfaktorn source citation (+115 %).
 *
 * Användning:
 * <StatHighlight figure="48 %" source="Folksam" sourceUrl="https://..." year="2025">
 *   Barn som åkte bakåtvänt och dog i bilkrock hade med stor sannolikhet överlevt.
 * </StatHighlight>
 */
interface Props {
  figure: string;
  source: string;
  sourceUrl: string;
  year?: string | number;
}
const { figure, source, sourceUrl, year } = Astro.props;
---
<div class="bg-rose-50 border border-rose-200 rounded-xl p-4 flex flex-col gap-2">
  <p class="font-heading text-3xl font-bold text-accent leading-none">{figure}</p>
  <div class="text-sm text-text leading-snug">
    <slot />
  </div>
  <p class="text-xs text-text-light mt-auto">
    Källa: <a href={sourceUrl} rel="noopener noreferrer" class="underline hover:text-accent" target="_blank">{source}{year ? ` (${year})` : ''}</a>
  </p>
</div>
