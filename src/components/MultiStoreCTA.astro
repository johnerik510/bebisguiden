---
/**
 * Multi-store CTA-block.
 * Visar bara butiker med explicit verifierade URL:er — ingen auto-resolution.
 * primaryStore + primaryUrl är primär CTA.
 * verified[] är övriga "Även hos"-knappar.
 */

interface Props {
  productName: string;
  primaryStore: string;
  primaryUrl: string;
  verified?: { name: string; url: string }[];
  description?: string;
  /** Legacy-props, ignoreras */
  brand?: string;
  price?: string;
  max?: number;
}

const { productName, primaryStore, primaryUrl, verified = [], description } = Astro.props;
---

<div class="not-prose bg-accent/5 border border-accent/20 rounded-xl p-5 my-6" data-product={productName}>
  <div class="mb-4">
    <p class="font-heading font-bold text-dark text-base">{productName}</p>
    {description && <p class="text-sm text-text-light mt-1.5 leading-relaxed">{description}</p>}
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
    <a
      href={primaryUrl}
      rel="nofollow sponsored noopener noreferrer"
      target="_blank"
      class="no-underline relative flex w-full items-center justify-between gap-2 px-5 py-4 rounded-lg font-bold text-base transition-colors min-h-[56px] bg-accent hover:bg-accent-dark text-white shadow-sm"
    >
      <span class="absolute -top-2 right-3 inline-block bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full shadow-sm">
        Redaktionens val
      </span>
      <span>Bra pris hos {primaryStore}</span>
      <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
    {verified.map((v) => (
    <a
      href={v.url}
      rel="nofollow sponsored noopener noreferrer"
      target="_blank"
      class="no-underline flex w-full items-center justify-between gap-2 px-5 py-4 rounded-lg font-bold text-base transition-colors min-h-[56px] bg-white hover:bg-sand text-dark border border-sand-dark"
    >
      <span>Bra pris hos {v.name}</span>
      <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
    ))}
  </div>

  <p class="text-xs text-gray mt-3">Annonslänkar, vi får provision om du handlar via knapparna.</p>
</div>
