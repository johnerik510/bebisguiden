---
const kategorier = [
  { label: 'Bilbarnstolar', href: '/bilbarnstolar/' },
  { label: 'Barnvagnar', href: '/barnvagnar/' },
  { label: 'Babyvakter', href: '/babyvakter/' },
  { label: 'Bärselen', href: '/barselen/' },
  { label: 'Matstolar', href: '/matstolar/' },
  { label: 'Spjälsängar', href: '/spjalsangar/' },
  { label: 'Amning', href: '/amning/' },
  { label: 'Leksaker', href: '/leksaker/' },
  { label: 'Blöjor', href: '/blojor/' },
  { label: 'Bebisbadkar', href: '/badkar/' },
  { label: 'Säkerhet', href: '/sakerhet/' },
  { label: 'Märken', href: '/marken/' },
];

const guider = [
  { label: 'Alla guider', href: '/guider/' },
  { label: 'Bebis-checklista', href: '/guider/bebis-checklista/' },
  { label: 'Säker sovmiljö', href: '/guider/saker-sovmiljo/' },
  { label: 'Välja bilbarnstol', href: '/guider/valja-bilbarnstol/' },
  { label: 'Välja barnvagn', href: '/guider/valja-barnvagn/' },
  { label: 'Välja babyvakt', href: '/guider/valja-babyvakt/' },
  { label: 'Välja bärsele', href: '/guider/valja-barsele/' },
  { label: 'Välja matstol', href: '/guider/valja-matstol/' },
  { label: 'Bilbarnstolsregler', href: '/guider/bilbarnstol-regler/' },
  { label: 'Bakåtvänd — hur länge?', href: '/guider/bakatvand-hur-lange/' },
  { label: 'Barnvagn på flyg', href: '/guider/barnvagn-flyg/' },
  { label: 'Amma eller flaska?', href: '/guider/amma-eller-flaska/' },
];

const marken = [
  { label: 'Alla märken', href: '/marken/' },
  { label: 'Britax recension', href: '/marken/britax/' },
  { label: 'BabyBjörn recension', href: '/marken/babybjorn/' },
  { label: 'Stokke recension', href: '/marken/stokke/' },
  { label: 'Bugaboo recension', href: '/marken/bugaboo/' },
  { label: 'Emmaljunga recension', href: '/marken/emmaljunga/' },
  { label: 'Cybex recension', href: '/marken/cybex/' },
];

const legal = [
  { label: 'Om oss', href: '/om-oss/' },
  { label: 'Om redaktionen', href: '/om-redaktionen/' },
  { label: 'Så testar vi', href: '/sa-testar-vi/' },
  { label: 'Redaktionell policy', href: '/redaktionell-policy/' },
  { label: 'Kontakt', href: '/kontakt/' },
  { label: 'Integritetspolicy', href: '/integritetspolicy/' },
  { label: 'Affiliate-disclaimer', href: '/affiliate-disclaimer/' },
];
---

<footer class="bg-primary text-gray-300">
  <!-- Nyhetsbrev-sektion -->
  <div class="bg-primary-dark border-b border-primary-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div class="max-w-xl">
          <h3 class="font-heading text-white text-xl font-bold mb-2">Få våra bästa köpråd — rakt i inboxen</h3>
          <p class="text-sm text-gray-300">Nya tester, prisbevakningar och exklusiva rabatter. Inga spam, avsluta när du vill.</p>
        </div>
        <form
          action="https://formspree.io/f/xkgjlojq"
          method="POST"
          class="flex flex-col sm:flex-row gap-2 w-full md:w-auto md:min-w-[420px]"
        >
          <label for="newsletter-email" class="sr-only">E-postadress</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            placeholder="din@epost.se"
            class="flex-1 px-4 py-3 rounded-xl text-gray-900 placeholder-gray-500 bg-white focus:outline-none focus:ring-2 focus:ring-accent"
          />
          <button
            type="submit"
            class="bg-accent hover:bg-accent-dark text-white font-bold px-6 py-3 rounded-xl transition-colors whitespace-nowrap"
          >
            Prenumerera
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <h3 class="font-heading text-white text-lg font-bold mb-4">Bebisguiden</h3>
        <p class="text-sm leading-relaxed">
          Oberoende tester och jämförelser av barnprodukter. Vi granskar bilbarnstolar, barnvagnar, babyvakter och mer — så du väljer säkert och smart för ditt barn.
        </p>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Kategorier</h4>
        <ul class="space-y-2">
          {kategorier.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Guider</h4>
        <ul class="space-y-2">
          {guider.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Märken</h4>
        <ul class="space-y-2">
          {marken.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Information</h4>
        <ul class="space-y-2">
          {legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-primary-light">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm">
          &copy; 2026 Bebisguiden.se. Alla rättigheter förbehållna.
        </p>
        <p class="text-xs text-gray-300">
          Bebisguiden.se innehåller affiliatelänkar. Vi kan få provision när du handlar via våra länkar, utan extra kostnad för dig.
        </p>
      </div>
    </div>
  </div>
</footer>
