---
import { findHubForSlug, getSlugFromPathname, hubs } from '../data/hubMap';

const pathname = Astro.url.pathname;
const slug = getSlugFromPathname(pathname);
const hub = slug ? findHubForSlug(slug) : null;
const slugIsHub = slug !== null && (Object.keys(hubs) as string[]).includes(slug);
const showWidget = hub && !slugIsHub;

let siblings: { slug: string; title: string }[] = [];
let breadcrumbJsonLd: object | null = null;

if (showWidget && hub && slug) {
  siblings = hub.children.filter((c) => c.slug !== slug).slice(0, 3);
  breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Hem', item: 'https://bebisguiden.se/' },
      { '@type': 'ListItem', position: 2, name: 'Guider', item: 'https://bebisguiden.se/guider/' },
      { '@type': 'ListItem', position: 3, name: hub.title, item: `https://bebisguiden.se${hub.href}` },
      { '@type': 'ListItem', position: 4, name: hub.children.find((c) => c.slug === slug)?.title || slug, item: `https://bebisguiden.se/guider/${slug}/` },
    ],
  };
}
---
{showWidget && hub && (
  <section class="max-w-4xl mx-auto px-4 py-10 border-t border-border mt-10">
    <div class="bg-bg-soft border border-border rounded-xl p-5 mb-6">
      <p class="text-sm text-text-light mb-1">Den här guiden är en del av</p>
      <a href={hub.href} class="font-bold text-accent hover:underline text-lg">
        {hub.title} →
      </a>
    </div>
    {siblings.length > 0 && (
      <>
        <h2 class="text-xl font-bold text-text mb-4">Läs också</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {siblings.map((s) => (
            <a href={`/guider/${s.slug}/`} class="block bg-white border border-border rounded-xl p-4 hover:shadow-md hover:border-accent transition-all group">
              <h3 class="font-semibold text-text group-hover:text-accent transition-colors leading-snug">{s.title}</h3>
            </a>
          ))}
        </div>
      </>
    )}
  </section>
)}
{breadcrumbJsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
)}
