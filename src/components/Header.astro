---
const navItems = [
  { label: 'Bilbarnstolar', href: '/bilbarnstolar/' },
  { label: 'Barnvagnar', href: '/barnvagnar/' },
  { label: 'Babyvakter', href: '/babyvakter/' },
  { label: 'Bärselen', href: '/barselen/' },
  { label: 'Matstolar', href: '/matstolar/' },
  { label: 'Spjälsängar', href: '/spjalsangar/' },
  { label: 'Amning & matning', href: '/amning/', dropdown: [
    { label: 'Bröstpumpar', href: '/amning/brostpump/' },
    { label: 'Amningskuddar', href: '/amning/amningskudde/' },
    { label: 'Nappflaskor', href: '/amning/nappflaska/' },
  ]},
  { label: 'Leksaker', href: '/leksaker/' },
  { label: 'Guider', href: '/guider/' },
];

const uspItems = [
  '100+ produkter testade',
  'Oberoende recensioner',
  'Uppdaterat 2026',
  'Alltid gratis',
];
---

<header class="sticky top-0 z-50 shadow-sm">
  <!-- USP bar -->
  <div class="bg-accent text-white text-xs font-semibold py-2 px-4">
    <div class="max-w-7xl mx-auto flex items-center justify-center gap-4 sm:gap-8 flex-wrap">
      {uspItems.map((item, i) => (
        <span class={`flex items-center gap-1.5 ${i > 1 ? 'hidden md:flex' : ''}`}>
          <svg class="w-3 h-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          {item}
        </span>
      ))}
    </div>
  </div>
  <!-- White nav -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 font-heading text-xl font-bold tracking-tight text-primary hover:text-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-7 h-7 flex-shrink-0" aria-hidden="true">
            <circle cx="16" cy="12" r="8" fill="currentColor" opacity="0.12"/>
            <circle cx="16" cy="12" r="5" fill="#e8788a"/>
            <circle cx="14" cy="11" r="1" fill="white"/>
            <circle cx="18" cy="11" r="1" fill="white"/>
            <path d="M14 14 Q16 16 18 14" fill="none" stroke="white" stroke-width="0.8"/>
          </svg>
          Bebisguiden
        </a>
        <nav class="hidden md:flex items-center gap-1" aria-label="Huvudnavigering">
          {navItems.map((item) => (
            item.dropdown ? (
              <div class="relative group">
                <a href={item.href} class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-primary rounded-lg hover:bg-gray-50 transition-colors flex items-center gap-1">
                  {item.label}
                  <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </a>
                <div class="absolute left-0 top-full pt-1 hidden group-hover:block z-50">
                  <div class="bg-white border border-gray-200 rounded-xl shadow-lg py-1 min-w-[180px]">
                    {item.dropdown.map((sub) => (
                      <a href={sub.href} class="block px-4 py-2 text-sm text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors">
                        {sub.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
            <a href={item.href} class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-primary rounded-lg hover:bg-gray-50 transition-colors">
              {item.label}
            </a>
            )
          ))}
          <a href="/bilbarnstolar/" class="ml-2 px-4 py-2 text-sm font-semibold bg-accent text-white rounded-lg hover:opacity-90 transition-opacity">
            Se tester
          </a>
        </nav>
        <button id="mobile-menu-btn" class="md:hidden p-2.5 rounded-md hover:bg-gray-100 transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center text-gray-700" aria-label="Öppna meny" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100" aria-label="Mobilnavigering">
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => (
        <div>
          <a href={item.href} class="block py-2.5 text-sm text-gray-700 hover:text-primary transition-colors font-medium">
            {item.label}
          </a>
          {item.dropdown && (
            <div class="ml-4 space-y-0.5 mb-1">
              {item.dropdown.map((sub) => (
                <a href={sub.href} class="block py-1.5 text-sm text-gray-500 hover:text-primary transition-colors">
                  {sub.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
  });
</script>
