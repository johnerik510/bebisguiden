---
import { resolveMultiCTA } from '../lib/multi-cta';
import { type Retailer } from '../data/affiliates';

interface Props {
 productName: string;
 /** Märke , används för att hitta alla butiker via feed-data. */
 brand?: string;
 /** Primär butik (om hand-verifierad URL skickas via affiliateUrl). */
 store?: string;
 /** Hand-verifierad URL , används som fallback om feed missar för butiken. */
 affiliateUrl?: string;
 price?: string;
 description?: string;
 /** Visa sekundär "Även hos"-rad med övriga feed-resolverade butiker. */
 showCompare?: boolean;
 /** Legacy-prop, ignoreras av multi-CTA men kvar för bakåtkompat. */
 retailers?: Retailer[];
 /** Legacy-prop, ignoreras av multi-CTA men kvar för bakåtkompat. */
 retailerPaths?: Partial<Record<Retailer, string>>;
}

const {
 productName,
 brand,
 store,
 affiliateUrl,
 price,
 description,
 showCompare = true,
} = Astro.props;

const fallback = store && affiliateUrl ? { store, url: affiliateUrl } : undefined;
const multi = resolveMultiCTA(productName, { brand, fallback, max: 5 });
const primary = multi?.primary;
const others = multi?.others ?? [];
---

<div class="bg-cta/5 border border-cta/20 rounded-xl p-5 my-6 flex flex-col gap-3" data-product={productName}>
 <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
 <div>
 <p class="font-heading font-bold text-dark text-base">{productName}</p>
 {description && <p class="text-sm text-text-light mt-1">{description}</p>}
 {/* Pris dolt i UI, kvar i data */}
 </div>
 {primary && (
 <a
 href={primary.url}
 rel="nofollow sponsored noopener noreferrer"
 target="_blank"
 class="flex w-full items-center justify-center gap-2 bg-cta hover:bg-cta-dark text-white font-bold py-4 px-7 rounded-lg transition-colors text-base min-h-[56px]"
 >
 Se pris hos {primary.store}
 <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
 </a>
 )}
 </div>
 {showCompare && others.length > 0 && (
 <div class="pt-2 border-t border-cta/10 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-text-light">
 <span class="font-semibold uppercase tracking-wide">Även hos:</span>
 {others.map((o, i) => (
 <>
 <a
 href={o.url}
 rel="nofollow sponsored noopener noreferrer"
 target="_blank"
 class="hover:text-cta underline decoration-dotted underline-offset-4"
 >
 {o.store}
 </a>
 {i < others.length - 1 && <span class="text-text-light/50">·</span>}
 </>
 ))}
 </div>
 )}
</div>
