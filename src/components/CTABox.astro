  'Leas Lillebror': 'https://addrevenue.io/t?a=985469&c=3467325&url=https%3A%2F%2Fwww.lealillebror.se%2F',
  'Leksaksaffären': 'https://addrevenue.io/t?a=987009&c=3467325&url=https%3A%2F%2Fwww.leksaksaffaren.com%2F',
  'inoki': 'https://addrevenue.io/t?a=987691&c=3467325&url=https%3A%2F%2Finoki.se%2F',
  'Nanobebe': 'https://addrevenue.io/t?a=985384&c=3467325&url=https%3A%2F%2Fwww.nanobebe.com%2F',
