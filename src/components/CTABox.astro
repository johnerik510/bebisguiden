---
import { retailerMeta, sortByCommission, track, defaultRetailers, resolveTarget, type Retailer } from '../data/affiliates';

interface Props {
  productName: string;
  store?: string;
  affiliateUrl?: string;
  price?: string;
  description?: string;
  /**
   * Visa sekundär "Jämför pris hos:"-rad med Adtraction-butikerna sorterade efter provision.
   * Default true — sätt false för nisch-produkter som inte säljs via de stora babybutikerna.
   */
  showCompare?: boolean;
  retailers?: Retailer[];
  retailerPaths?: Partial<Record<Retailer, string>>;
}

const {
  productName,
  store = 'Reirei',
  affiliateUrl,
  price,
  description,
  showCompare = true,
  retailers = defaultRetailers,
  retailerPaths = {},
} = Astro.props;

const storeUrls: Record<string, string> = {
  'Jollyroom': 'https://dot.jollyroom.se/t/t?a=1222362818&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.jollyroom.se%2F',
  'Reirei': 'https://addrevenue.io/t?a=987575&c=3467325&url=https%3A%2F%2Freirei.se%2F',
  'Babyonline': 'https://addrevenue.io/t?a=987081&c=3467325&url=https%3A%2F%2Fwww.babyonline.se%2F',
  'Crescent Barnvagnar': 'https://addrevenue.io/t?a=986149&c=3467325&url=https%3A%2F%2Fwww.crescentbarnvagnar.se%2F',
  'Najell': 'https://addrevenue.io/t?a=984973&c=3467325&url=https%3A%2F%2Fnajell.com%2F',
  'Summerville': 'https://addrevenue.io/t?a=985585&c=3467325&url=https%3A%2F%2Fsummervilleorganic.com%2F',
  'Micki': 'https://addrevenue.io/t?a=984911&c=3467325&url=https%3A%2F%2Fwww.micki.se%2F',
  'Namnlappskungen': 'https://addrevenue.io/t?a=984852&c=3467325&url=https%3A%2F%2Fwww.namnlappskungen.se%2F',
  'Litenleker': 'https://addrevenue.io/t?a=985276&c=3467325&url=https%3A%2F%2Fwww.litenleker.se%2F',
  'Leas Lillebror': 'https://addrevenue.io/t?a=985469&c=3467325&url=https%3A%2F%2Fwww.lealillebror.se%2F',
  'Leksaksaffären': 'https://addrevenue.io/t?a=987009&c=3467325&url=https%3A%2F%2Fwww.leksaksaffaren.com%2F',
  'inoki': 'https://addrevenue.io/t?a=987691&c=3467325&url=https%3A%2F%2Finoki.se%2F',
  'Nanobebe': 'https://addrevenue.io/t?a=985384&c=3467325&url=https%3A%2F%2Fwww.nanobebe.com%2F',
  'Knattis': 'https://addrevenue.io/t?a=986599&c=3467325&url=https%3A%2F%2Fwww.knattis.se%2F',
  'Min lilla Sötnos': 'https://addrevenue.io/t?a=986377&c=3467325&url=https%3A%2F%2Fwww.minlillasotnos.se%2F',
  'Leksaker Plus': 'https://addrevenue.io/t?a=985346&c=3467325&url=https%3A%2F%2Fleksakerplus.se%2F',
  'Pixido': 'https://addrevenue.io/t?a=987854&c=3467325&url=https%3A%2F%2Fwww.pixido.se%2F',
  'Polarn O. Pyret': 'https://pin.polarnopyret.se/t/t?a=1126522829&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.polarnopyret.se%2Fbarnklader%2F',
  'Babysam': 'https://to.babyworld.se/t/t?a=1945556823&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.babysam.se%2F',
  'Toyspace': 'https://id.toyspace.se/t/t?a=1984734030&as=2065068845&t=2&tk=1&url=https%3A%2F%2Fwww.toyspace.se%2F',
};

// affiliateUrl är förstaval (specifik produkt-URL).
// Fallback: storeUrls ger en spårad butikssida även utan djuplänk — bättre än ingen CTA.
const finalUrl: string | null = affiliateUrl || (store && storeUrls[store]) || null;

// Autodetektera om primär CTA går till en av våra 5 huvudbutiker, så vi inte dubbletterar.
function detectRetailer(url: string | undefined): Retailer | undefined {
  if (!url) return undefined;
  for (const key of Object.keys(retailerMeta) as Retailer[]) {
    const meta = retailerMeta[key];
    if (url.includes(meta.domain) || url.includes(meta.trackBase.split('?')[0])) return key;
  }
  return undefined;
}
const detectedPrimary = detectRetailer(finalUrl);
// Filtrera bort retailers utan resolverbar produkt-URL — search-fallback är borttagen
const sortedRetailers = sortByCommission(retailers)
  .filter((r) => r !== detectedPrimary)
  .filter((r) => resolveTarget(r, retailerPaths[r]) !== null);
---

<div class="bg-cta/5 border border-cta/20 rounded-xl p-5 my-6 flex flex-col gap-3" data-product={productName}>
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
    <div>
      <p class="font-heading font-bold text-dark text-base">{productName}</p>
      {description && <p class="text-sm text-text-light mt-1">{description}</p>}
      {price && <p class="text-sm text-text-light">{price} hos {store}</p>}
    </div>
    {finalUrl && (
      <a
        href={finalUrl}
        rel="nofollow sponsored noopener noreferrer"
        target="_blank"
        class="inline-flex items-center gap-2 bg-cta hover:bg-cta-dark text-white font-bold py-3 px-6 rounded-lg transition-colors text-sm whitespace-nowrap"
      >
        Se pris hos {store}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    )}
  </div>
  {showCompare && sortedRetailers.length > 0 && (
    <div class="pt-2 border-t border-cta/10">
      <p class="text-xs text-text-light mb-1.5">Jämför pris hos:</p>
      <div class="flex flex-wrap gap-2">
        {sortedRetailers.map((r) => {
          const meta = retailerMeta[r];
          const target = resolveTarget(r, retailerPaths[r]);
          if (!target) return null;
          return (
            <a
              href={track(r, target)}
              target="_blank"
              rel="nofollow sponsored noopener noreferrer"
              class={`${meta.color} text-white text-xs font-semibold px-3 py-1.5 rounded-md transition-colors`}
              aria-label={`Se pris hos ${meta.name}`}
            >
              {meta.name}
            </a>
          );
        })}
      </div>
    </div>
  )}
</div>
