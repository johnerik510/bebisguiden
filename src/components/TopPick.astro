---
import { resolveMultiCTA } from '../lib/multi-cta';
import { retailerMeta, type Retailer } from '../data/affiliates';

interface Product {
 name: string;
 badge?: string;
 price?: string;
 rating?: number;
 image: string;
 ctaHref?: string;
 brand?: string;
}

interface Props {
 product: Product;
 description?: string;
 store?: string;
 microcopy?: string[];
}

const STORE_MAP: Record<string, string> = {
 'jollyroom': 'Jollyroom',
 'apotea': 'Apotea',
 'babyland': 'Babyland',
 'babyv': 'Baby V',
 'babybjorn': 'BabyBjörn',
 'stokke': 'Stokke',
 'lekmer': 'Lekmer',
 'cdon': 'CDON',
 'amazon': 'Amazon',
 'elgiganten': 'Elgiganten',
 'kjell': 'Kjell & Co',
 'mediamarkt': 'MediaMarkt',
 'klarna': 'Klarna',
 'awin1': 'butiken',
};

function detectStore(href?: string): string {
 if (!href) return 'butiken';
 for (const key of Object.keys(STORE_MAP)) {
 if (href.toLowerCase().includes(key)) return STORE_MAP[key];
 }
 return 'butiken';
}

function detectRetailer(url: string | undefined): Retailer | undefined {
 if (!url) return undefined;
 for (const key of Object.keys(retailerMeta) as Retailer[]) {
  const meta = retailerMeta[key];
  if (url.includes(meta.domain) || url.includes(meta.trackBase.split('?')[0])) return key;
 }
 return undefined;
}

const {
 product,
 description,
 store: storeProp,
 microcopy: microcopyProp,
} = Astro.props;

// Multi-CTA: använd högsta-provisionsbutik som primary, fall tillbaka på hardcoded ctaHref.
const detectedRetailer = detectRetailer(product.ctaHref);
const fallbackStoreName = detectedRetailer ? retailerMeta[detectedRetailer].name : undefined;
const fallback = product.ctaHref && fallbackStoreName
 ? { store: fallbackStoreName, url: product.ctaHref }
 : undefined;
const multi = resolveMultiCTA(product.name, { brand: product.brand, fallback, max: 4 });
const primary = multi?.primary;
const others = multi?.others ?? [];

const primaryHref = primary?.url || product.ctaHref;
const store = primary?.store || storeProp || detectStore(product.ctaHref);
const microcopy = microcopyProp || ['Snabb leverans', 'Fri retur', `I lager hos ${store}`];

const fallbackDescription = product.badge
? `Vårt toppval i kategorin "${product.badge.toLowerCase()}". Bästa balansen mellan kvalitet, prestanda och pris i vår jämförelse.`
: 'Vårt högst rankade val i jämförelsen. Bästa balansen mellan kvalitet, prestanda och pris.';

const finalDescription = description || fallbackDescription;
const fullStars = product.rating? Math.round(product.rating): 0;
const stars = '★'.repeat(fullStars) + '☆'.repeat(Math.max(0, 5 - fullStars));
---

<aside class="not-prose mb-6 rounded-2xl border-2 border-cta/30 bg-gradient-to-br from-sand/40 to-white shadow-md overflow-hidden">
 <div class="bg-cta text-white text-xs font-bold uppercase tracking-wider px-4 py-2 flex items-center gap-2">
 <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.286 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.175 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.286-3.957a1 1 0 00-.364-1.118L2.05 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z"/></svg>
 Vår topprekommendation
 </div>
 <div class="p-4 sm:p-5 flex flex-col sm:flex-row gap-4 sm:gap-5 items-start">
 <img src={product.image} alt={product.name} class="w-32 h-32 sm:w-40 sm:h-40 object-contain mx-auto sm:mx-0 shrink-0" loading="eager" />
 <div class="flex-1 w-full">
 <h2 class="font-heading text-xl sm:text-2xl font-bold text-dark mb-1">{product.name}</h2>
 <div class="flex flex-wrap items-center gap-3 mb-2 text-sm">
 {product.rating && (
 <span class="text-accent font-bold">{product.rating}/5 <span class="text-accent">{stars}</span></span>
 )}
 {/* Pris dolt i UI, kvar i data */}
 </div>
 <p class="text-sm sm:text-base text-text-light mb-4 leading-relaxed">{finalDescription}</p>
 {primaryHref && (
 <a href={primaryHref} target="_blank" rel="nofollow sponsored noopener noreferrer" class="flex w-full items-center justify-center gap-2 bg-cta hover:bg-cta-dark text-white font-bold text-base sm:text-lg px-7 py-4 rounded-lg transition-colors min-h-[56px] shadow-sm hover:shadow-md">
 Se pris hos {store}
 <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
 </a>
 )}
 {others.length > 0 && (
 <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-text-light">
 <span class="font-semibold uppercase tracking-wide">Även hos:</span>
 {others.map((o) => (
 <a href={o.url} target="_blank" rel="nofollow sponsored noopener noreferrer"
 class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg border border-border bg-white font-semibold text-text hover:border-primary hover:text-primary transition-colors no-underline">
 {o.store}
 <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
 </a>
 ))}
 </div>
 )}
 <p class="text-xs text-text-light mt-2 flex flex-wrap items-center gap-x-3 gap-y-1">
 {microcopy.map((m) => (
 <span class="inline-flex items-center gap-1">
 <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
 {m}
 </span>
 ))}
 </p>
 </div>
 </div>
</aside>
