---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import AuthorByline from '../components/AuthorByline.astro';
import { buildArticleSchema, DEFAULT_PUBLISHED, DEFAULT_MODIFIED } from '../utils/schema.js';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  breadcrumbs: { label: string; href?: string }[];
  updatedDate?: string;
  showDisclaimer?: boolean;
  datePublished?: string;
  dateModified?: string;
  image?: string;
  showAuthor?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonical,
  breadcrumbs,
  updatedDate,
  showDisclaimer = true,
  datePublished = DEFAULT_PUBLISHED,
  dateModified = DEFAULT_MODIFIED,
  image,
  showAuthor = true,
} = Astro.props;

const articleSchema = buildArticleSchema({
  title,
  description,
  image,
  datePublished,
  dateModified,
  pathname: Astro.url.pathname,
});
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="font-heading text-3xl sm:text-4xl lg:text-4xl font-bold text-text mt-3 mb-2">{title}</h1>
    {updatedDate && (
      <p class="text-sm text-text-light mb-2">Senast uppdaterad: {updatedDate}</p>
    )}
    {showAuthor && (
      <AuthorByline
        datePublished={datePublished}
        dateModified={dateModified}
      />
    )}
    <div class="mt-4">
      <slot />
    </div>
    {showDisclaimer && <AffiliateDisclaimer />}
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
