---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import AuthorByline from '../components/AuthorByline.astro';
import StickyCTA from '../components/StickyCTA.astro';
import { buildArticleSchema } from '../utils/schema.js';

interface Props {
 title: string;
 description: string;
 ogImage?: string;
 canonical?: string;
 breadcrumbs: { label: string; href?: string }[];
 updatedDate?: string;
 showDisclaimer?: boolean;
 datePublished?: string;
 dateModified?: string;
 image?: string;
 showAuthor?: boolean;
 relatedTitle?: string;
 stickyCtaHref?: string;
 stickyCtaProduct?: string;
 stickyCtaBrand?: string;
}

const {
 title,
 description,
 ogImage,
 canonical,
 breadcrumbs,
 updatedDate,
 showDisclaimer = true,
 datePublished,
 dateModified,
 image,
 showAuthor = true,
 relatedTitle = 'Relaterade guider',
 stickyCtaHref,
 stickyCtaProduct,
 stickyCtaBrand,
} = Astro.props;

// Lästid: rendera default-sloten, räkna ord, dela på 200 ord/min
let readingTimeMinutes: number | undefined;
if (Astro.slots.has('default')) {
 const slotHtml = await Astro.slots.render('default');
 const words = slotHtml.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().split(' ').filter(Boolean).length;
 readingTimeMinutes = Math.max(1, Math.round(words / 200));
}

// Resolva datum för schema + byline:
// - datePublished: från explicit prop
// - dateModified: prefer updatedDate-prop (manuellt curaterad per sida)
//   över script-tillagd dateModified, fall tillbaka på datePublished
const resolvedPublished = datePublished;
const resolvedModified = updatedDate || dateModified || datePublished;

const articleSchema = buildArticleSchema({
 title,
 description,
 image,
 datePublished: resolvedPublished,
 dateModified: resolvedModified,
 pathname: Astro.url.pathname,
});

// Auto-generera relaterade artiklar från samma sektion
const pathname = Astro.url.pathname.replace(/\/$/, '');
const section = pathname.split('/').filter(Boolean)[0];
let autoRelated: { title: string; href: string }[] = [];
if (section) {
 const pagesGlob = import.meta.glob('/src/pages/**/*.astro', { eager: false });
 const mdGlob = import.meta.glob('/src/pages/**/*.md', { eager: false });
 const allPaths = [...Object.keys(pagesGlob),...Object.keys(mdGlob)];
 autoRelated = allPaths
.map((p) => {
 const rel = p.replace('/src/pages', '').replace(/\.(astro|md)$/, '').replace(/\/index$/, '');
 return rel || '/';
 })
.filter((href) => {
 if (href === pathname || href === pathname + '/') return false;
 if (href.startsWith('/404') || href.includes('[')) return false;
 if (href === '/' || href === `/${section}` || href === `/${section}/`) return false;
 return href.startsWith(`/${section}/`);
 })
.slice(0, 6)
.map((href) => {
 const slug = href.split('/').filter(Boolean).pop() || '';
 const label = slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
 return { title: label, href: href.endsWith('/')? href: href + '/' };
 });
}
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical}>
 <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
 <Breadcrumbs items={breadcrumbs} />
 <h1 class="font-heading text-3xl sm:text-4xl lg:text-4xl font-bold text-text mt-3 mb-2">{title}</h1>
 {showAuthor && (
 <AuthorByline
 datePublished={resolvedPublished}
 dateModified={resolvedModified}
 readingTimeMinutes={readingTimeMinutes}
 />
 )}
 {image && (
 <div class="mt-4 mb-6 rounded-xl overflow-hidden aspect-[16/9] bg-sand">
 <img src={image} alt={title} class="w-full h-full object-cover" loading="lazy" />
 </div>
 )}
 <div class="mt-4">
 <slot />
 </div>
 {autoRelated.length > 0 && (
 <aside class="mt-12 pt-8 border-t border-sand-dark">
 <h2 class="font-heading text-xl font-bold text-text mb-4">{relatedTitle}</h2>
 <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
 {autoRelated.map((article) => (
 <a href={article.href} class="block p-4 bg-white rounded-lg border border-sand-dark hover:border-primary hover:shadow-md transition-all">
 <span class="font-body font-medium text-text hover:text-primary">{article.title}</span>
 </a>
 ))}
 </div>
 </aside>
 )}
 {showDisclaimer && <AffiliateDisclaimer />}
 </article>
 {stickyCtaHref && (
 <StickyCTA href={stickyCtaHref} productName={stickyCtaProduct} brand={stickyCtaBrand} />
 )}
 <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
 <script>
  function transformProseTablesForMobile() {
   if (window.innerWidth >= 768) return;
   document.querySelectorAll('article table:not([data-mobile]):not([data-mobile-simple])').forEach((table) => {
    const ths = Array.from(table.querySelectorAll('thead th'));
    // Jämförelsetabell: 3+ kolumner (Egenskap + 2+ produkter)
    if (ths.length >= 3) {
     const productNames = ths.slice(1).map((th) => th.textContent?.trim() ?? '');
     const rows = Array.from(table.querySelectorAll('tbody tr'));
     const newTbody = document.createElement('tbody');
     // Produktnamnsrad
     const namesTr = document.createElement('tr');
     namesTr.className = 'mp-names';
     productNames.forEach((name) => {
      const td = document.createElement('td');
      td.textContent = name;
      namesTr.appendChild(td);
     });
     newTbody.appendChild(namesTr);
     // Egenskapsrader
     rows.forEach((row) => {
      const cells = Array.from(row.querySelectorAll('td'));
      if (!cells.length) return;
      // USP-rad: visa direkt utan feature-label
      if (row.classList.contains('usp-row')) {
       const uspTr = document.createElement('tr');
       uspTr.className = 'mp-values mp-usp';
       cells.slice(1).forEach((cell) => {
        const td = document.createElement('td');
        td.innerHTML = cell.innerHTML;
        uspTr.appendChild(td);
       });
       newTbody.appendChild(uspTr);
       return;
      }
      const labelTr = document.createElement('tr');
      labelTr.className = 'mp-label';
      const labelTd = document.createElement('td');
      labelTd.colSpan = productNames.length;
      labelTd.textContent = cells[0].textContent?.trim() ?? '';
      labelTr.appendChild(labelTd);
      newTbody.appendChild(labelTr);
      const valuesTr = document.createElement('tr');
      valuesTr.className = 'mp-values';
      cells.slice(1).forEach((cell) => {
       const td = document.createElement('td');
       td.innerHTML = cell.innerHTML;
       valuesTr.appendChild(td);
      });
      newTbody.appendChild(valuesTr);
     });
     table.querySelector('tbody')?.replaceWith(newTbody);
     const thead = table.querySelector('thead');
     if (thead) thead.style.display = 'none';
     table.setAttribute('data-mobile', '1');
    } else {
     // Enkel 2-kolumnstabell
     table.setAttribute('data-mobile-simple', '1');
    }
   });
  }
  transformProseTablesForMobile();
 </script>
</BaseLayout>
