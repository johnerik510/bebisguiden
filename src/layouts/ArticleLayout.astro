---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import AuthorByline from '../components/AuthorByline.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  breadcrumbs: { label: string; href?: string }[];
  updatedDate?: string;
  showDisclaimer?: boolean;
  datePublished?: string;
  dateModified?: string;
  image?: string;
  showAuthor?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonical,
  breadcrumbs,
  updatedDate,
  showDisclaimer = true,
  datePublished = '2026-03-28',
  dateModified = '2026-04-05',
  image,
  showAuthor = true,
} = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: image ? `https://bebisguiden.se${image}` : undefined,
  datePublished: datePublished,
  dateModified: dateModified,
  author: {
    '@type': 'Person',
    name: 'John Erik Johansson',
    url: 'https://bebisguiden.se/om-redaktionen/',
    image: 'https://bebisguiden.se/images/john-erik-johansson.webp',
    jobTitle: 'Grundare & barnproduktexpert'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Bebisguiden.se',
    url: 'https://bebisguiden.se',
    logo: { '@type': 'ImageObject', url: 'https://bebisguiden.se/favicon.svg' }
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://bebisguiden.se${Astro.url.pathname}` }
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold text-text mt-3 mb-2">{title}</h1>
    {updatedDate && (
      <p class="text-sm text-text-light mb-2">Senast uppdaterad: {updatedDate}</p>
    )}
    {showDisclaimer && <AffiliateDisclaimer />}
    {showAuthor && (
      <AuthorByline
        datePublished={datePublished}
        dateModified={dateModified}
      />
    )}
    <div class="mt-4">
      <slot />
    </div>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
